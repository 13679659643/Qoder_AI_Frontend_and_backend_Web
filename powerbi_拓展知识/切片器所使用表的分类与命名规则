)
```

## 六、高级模式：参数表模板

### 6.1 通用参数表结构

```dax
// 通用参数表模板
Template_ParameterTable = 
VAR ParameterName = "Template"  // 修改为实际参数名
RETURN
DATATABLE(
    // 基础字段
    ParameterName & "_ID", INTEGER,
    ParameterName & "_Label", STRING,
    ParameterName & "_Sort", INTEGER,
    ParameterName & "_Description", STRING,
    
    // 扩展字段
    ParameterName & "_IsDefault", BOOLEAN,
    ParameterName & "_IsActive", BOOLEAN,
    ParameterName & "_Group", STRING,
    
    // 数据行
    {
        {1, "Option 1", 1, "First option", TRUE, TRUE, "Group A"},
        {2, "Option 2", 2, "Second option", FALSE, TRUE, "Group A"},
        {3, "Option 3", 3, "Third option", FALSE, TRUE, "Group B"}
    }
)
```

### 6.2 动态参数表生成器

```dax
// 动态生成参数表的函数
GenerateParameterTable = 
(
    TableName as text,
    Values as list,
    Labels as list,
    Optional SortOrder as list,
    Optional Groups as list
) =>
let
    // 构建基础表
    BaseTable = Table.FromColumns(
        {
            List.Generate(
                () => 0,
                each _ < List.Count(Values),
                each _ + 1,
                each _ + 1
            ),  // ID列
            Values,  // 值列
            Labels,  // 标签列
            SortOrder ?? List.Generate(
                () => 0,
                each _ < List.Count(Values),
                each _ + 1,
                each _ + 1
            ),  // 排序列（默认）
            Groups ?? List.Repeat(
                {"Default"},
                List.Count(Values)
            )  // 分组列（默认）
        },
        {
            TableName & "_ID",
            TableName & "_Value",
            TableName & "_Label",
            TableName & "_Sort",
            TableName & "_Group"
        }
    ),
    
    // 添加元数据
    MetaTable = Table.AddColumn(
        BaseTable,
        TableName & "_IsSelected",
        each true,
        type logical
    )
in
    MetaTable
```

## 七、实际项目应用示例

### 7.1 电商分析项目切片器表

```dax
// 项目：电商销售分析
// 位置：📁 Slicers/

// 1. 时间切片器
Slicer_Time_Period = 
DATATABLE(
    "Period_ID", INTEGER,
    "Period_Label", STRING,
    "Period_Sort", INTEGER,
    "Period_Type", STRING,  // Daily, Weekly, Monthly, Quarterly, Yearly
    {
        {1, "今日", 1, "Daily"},
        {2, "本周", 2, "Weekly"},
        {3, "本月", 3, "Monthly"},
        {4, "本季度", 4, "Quarterly"},
        {5, "本年", 5, "Yearly"},
        {6, "自定义", 6, "Custom"}
    }
)

// 2. 产品分类切片器
Slicer_Product_Hierarchy = 
ADDCOLUMNS(
    SUMMARIZE(
        'Product',
        'Product'[Category],
        'Product'[Subcategory],
        'Product'[Brand]
    ),
    "Hierarchy_Level", 
        SWITCH(
            TRUE(),
            NOT(ISBLANK([Brand])), "Brand",
            NOT(ISBLANK([Subcategory])), "Subcategory",
            NOT(ISBLANK([Category])), "Category",
            "All"
        ),
    "Hierarchy_Path",
        [Category] & " > " & 
        IF(ISBLANK([Subcategory]), "", [Subcategory] & " > ") &
        IF(ISBLANK([Brand]), "", [Brand])
)

// 3. 度量值选择器
MeasureSwitch_SalesMetrics = 
DATATABLE(
    "Metric_ID", INTEGER,
    "Metric_Name", STRING,
    "Metric_DAX", STRING,
    "Metric_Format", STRING,
    "Metric_Category", STRING,
    "Sort_Order", INTEGER,
    {
        {1, "销售额", "[Sales Amount]", "Currency", "Financial", 1},
        {2, "订单数", "[Order Count]", "Whole Number", "Volume", 2},
        {3, "平均订单价", "[Avg Order Value]", "Currency", "Financial", 3},
        {4, "毛利率", "[Gross Margin %]", "Percentage", "Profitability", 4},
        {5, "客户数", "[Customer Count]", "Whole Number", "Customer", 5},
        {6, "转化率", "[Conversion Rate]", "Percentage", "Performance", 6}
    }
)
```

