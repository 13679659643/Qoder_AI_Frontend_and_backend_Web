```dax
// ========================================
// 度量值: DDPP_Dynamic_Metric_Color
// 用途: 根据指标值和指标类型返回条件格式颜色代码
// 依赖: [DDPP_Dynamic_Metric_Value_Optimized]
//       'D_Dcom-Platform Performance_Metrics_Dim'[R1Name], [R2Name]
// 作者: Gutao | 日期: 2026-03-12
// 颜色方案:
//   - 增长 > 0 : 绿色 #1A9018
//   - 增长 = 0 : 黄色 #E1C233
//   - 增长 < 0 : 红色 #D64550
//   - Cancel / Return 语义反转（负增长为好 → 绿色）
//   - 实际值指标 / BLANK: 黑色 #000000
// ========================================
DDPP_Dynamic_Metric_Color = 
    VAR __MetricValue = [DDPP_Dynamic_Metric_Value_Optimized]
    VAR __SelR1 = 
        SELECTEDVALUE(
            'D_Dcom-Platform Performance_Metrics_Dim'[R1Name]
        )
    VAR __SelR2 = 
        SELECTEDVALUE(
            'D_Dcom-Platform Performance_Metrics_Dim'[R2Name]
        )

    // 颜色常量
    VAR __ColorGreen = "#1A9018"
    VAR __ColorYellow = "#E1C233"
    VAR __ColorRed = "#D64550"
    VAR __ColorDefault = "#000000"

    RETURN
        SWITCH(
            TRUE(),
            // BLANK 值 → 黑色
            ISBLANK(__MetricValue),
                __ColorDefault,

            // 增长指标（vs LY%, vs Target%）
            __SelR2 IN {"vs LY%", "vs Target%"},
                // Cancel / Return: 语义反转（负增长是好事）
                IF(
                    __SelR1 IN {"Cancel", "Return"},
                    SWITCH(
                        TRUE(),
                        __MetricValue < 0, __ColorGreen,
                        __MetricValue = 0, __ColorYellow,
                        __ColorRed
                    ),
                    // 其他指标: 正增长是好事
                    SWITCH(
                        TRUE(),
                        __MetricValue > 0, __ColorGreen,
                        __MetricValue = 0, __ColorYellow,
                        __ColorRed
                    )
                ),

            // 实际值指标 → 黑色
            __ColorDefault
        )
