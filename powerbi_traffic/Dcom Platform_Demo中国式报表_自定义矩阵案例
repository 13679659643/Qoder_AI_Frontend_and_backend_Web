## 6.2 计算表：指标行标题维度表

| Display Folder | Base Metrics / Dimensions |
|----------------|--------------------------|

```dax
// ========================================
// 计算表: D_Dcom-Platform Performance_Metrics_Dim
// 用途: 创建矩阵行标题维度表，支持多层级指标显示
// 依赖: 无（静态数据）
// 作者: Gutao | 日期: 2026-03-12
// 修改: 2026-03-12 — vs Target% 仅出现在 SLS DCOM 指标组
// 注意:
//   1. 此表用于 Matrix 视觉对象的行标题
//   2. 通过 CROSSJOIN 生成指标组 x 指标类型的笛卡尔积
//   3. SLS DCOM 和其他指标组分别生成组合后 UNION 合并
//   4. Sort_Order 字段确保矩阵中的正确显示顺序
// ========================================
D_Dcom-Platform Performance_Metrics_Dim = 

-- Step 1: 定义一级标题（指标组）
VAR __R1Groups = 
    DATATABLE(
        "R1Name", STRING,
        "R1NameOrder", INTEGER,
        {
            {"SLS DCOM", 1},
            {"Demand Sales", 2},
            {"Traffic", 3},
            {"CVR", 4},
            {"AUR", 5},
            {"UPT", 6},
            {"Cancel", 7},
            {"Return", 8}
        }
    )

-- Step 2: 定义总计行的特殊一级标题
VAR __R1SpecTotal = 
    DATATABLE(
        "R1Name", STRING,
        "R1NameOrder", INTEGER,
        {
            {"Total", 100}
        }
    )

-- Step 3: 定义总计行的特殊二级标题
VAR __R2SpecTotal = 
    DATATABLE(
        "R2Name", STRING,
        "R2NameOrder", INTEGER,
        {
            {"Total", 100}
        }
    )

-- Step 4: 定义三级标题（预留扩展）
VAR __R3Default = 
    DATATABLE(
        "R3Name", STRING,
        "R3NameOrder", INTEGER,
        {
            {"Value", 1}
        }
    )

-- Step 5: SLS DCOM 的二级标题（含 vs Target%）
VAR __R2_SLS_DCOM = 
    DATATABLE(
        "R2Name", STRING,
        "R2NameOrder", INTEGER,
        {
            {"Act", 1},
            {"vs LY%", 2},
            {"vs Target%", 3}
        }
    )

-- Step 6: 其他指标组的二级标题（不含 vs Target%）
VAR __R2_Other = 
    DATATABLE(
        "R2Name", STRING,
        "R2NameOrder", INTEGER,
        {
            {"Act", 1},
            {"vs LY%", 2}
        }
    )

-- Step 7: 生成 SLS DCOM 指标组的行组合
VAR __CombSLS = 
    SELECTCOLUMNS(
        CROSSJOIN(
            FILTER(__R1Groups, [R1Name] = "SLS DCOM"),
            __R2_SLS_DCOM,
            __R3Default
        ),
        "R1Name", [R1Name],
        "R1NameOrder", [R1NameOrder],
        "R2Name", [R2Name],
        "R2NameOrder", [R2NameOrder],
        "R3Name", [R3Name],
        "R3NameOrder", [R3NameOrder]
    )

-- Step 8: 生成其他指标组的行组合
VAR __CombOther = 
    SELECTCOLUMNS(
        CROSSJOIN(
            FILTER(__R1Groups, [R1Name] <> "SLS DCOM"),
            __R2_Other,
            __R3Default
        ),
        "R1Name", [R1Name],
        "R1NameOrder", [R1NameOrder],
        "R2Name", [R2Name],
        "R2NameOrder", [R2NameOrder],
        "R3Name", [R3Name],
        "R3NameOrder", [R3NameOrder]
    )

-- Step 9: 生成特殊行组合（总计行）
VAR __CombSpecial = 
    SELECTCOLUMNS(
        CROSSJOIN(__R1SpecTotal, __R2SpecTotal, __R3Default),
        "R1Name", [R1Name],
        "R1NameOrder", [R1NameOrder],
        "R2Name", [R2Name],
        "R2NameOrder", [R2NameOrder],
        "R3Name", [R3Name],
        "R3NameOrder", [R3NameOrder]
    )

-- Step 10: 合并所有行组合
RETURN
    UNION(__CombSLS, __CombOther, __CombSpecial)
```

### 生成的指标行结构
