## 6.4 度量值：非 DY 平台路由（DDPP_Measure_Router_NonDY）

| Display Folder | _Internal / Routing |
|----------------|---------------------|

```dax
// ========================================
// 度量值: DDPP_Measure_Router_NonDY
// 用途: 处理 Total / TM / JD / RLE / DY_Family / DY_W 平台的指标路由
//       通过 CALCULATE 应用平台筛选，调用基础度量值
// 依赖: 全部 17 个基础度量值（见 §2.3）
//       'D_Dcom-Platform Performance'[platform], [store]
//       'D_Dcom-Platform Performance_Platform_Dim'[Platform_Code]
//       'D_Dcom-Platform Performance_Metrics_Dim'[R1Name], [R2Name]
// 作者: Gutao | 日期: 2026-03-12
// 性能: 🟡 中等 — 多层 SWITCH 嵌套，但每次仅执行一条路径
// ========================================
DDPP_Measure_Router_NonDY = 
    VAR __SelPlatform = 
        SELECTEDVALUE(
            'D_Dcom-Platform Performance_Platform_Dim'[Platform_Code]
        )
    VAR __SelR1 = 
        SELECTEDVALUE(
            'D_Dcom-Platform Performance_Metrics_Dim'[R1Name]
        )
    VAR __SelR2 = 
        SELECTEDVALUE(
            'D_Dcom-Platform Performance_Metrics_Dim'[R2Name]
        )

    // 平台代码 → 事实表 platform 字段映射
    // DY_Family / DY_W 对应 platform="DY"，需额外 store 筛选
    VAR __PlatformFilter = 
        SWITCH(
            __SelPlatform,
            "Total", "Total",
            "TM", "TM",
            "JD", "JD",
            "RLE", "RLE",
            "DY_Family", "DY",
            "DY_W", "DY",
            BLANK()
        )

    // DY_Family / DY_W 的 store 筛选条件
    VAR __StoreFilter =
        SWITCH(
            __SelPlatform,
            "DY_Family", "DY_Family",
            "DY_W", "DY_W",
            BLANK()
        )

    // 路由到基础度量值的通用函数
    // 根据 R1Name（指标组）和 R2Name（指标类型）定位目标度量值
    RETURN
        IF(
            ISBLANK(__PlatformFilter),
            BLANK(),
            SWITCH(
                __SelR1,
                "SLS DCOM",
                    SWITCH(
                        __SelR2,
                        "Act",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([SLS DCOM Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([SLS DCOM Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        "vs LY%",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([SLS DCOM vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([SLS DCOM vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        "vs Target%",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([SLS DCOM vs Target%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([SLS DCOM vs Target%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        BLANK()
                    ),
                "Demand Sales",
                    SWITCH(
                        __SelR2,
                        "Act",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([Demand Sales Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([Demand Sales Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        "vs LY%",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([Demand Sales vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([Demand Sales vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        BLANK()
                    ),
                "Traffic",
                    SWITCH(
                        __SelR2,
                        "Act",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([Traffic Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([Traffic Act], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        "vs LY%",
                            IF(
                                ISBLANK(__StoreFilter),
                                CALCULATE([Traffic vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter),
                                CALCULATE([Traffic vs LY%], 'D_Dcom-Platform Performance'[platform] = __PlatformFilter,
                                    'D_Dcom-Platform Performance'[store] = __StoreFilter)
                            ),
                        BLANK()
                    ),
