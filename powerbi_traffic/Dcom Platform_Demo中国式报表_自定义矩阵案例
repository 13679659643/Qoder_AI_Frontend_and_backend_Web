                    "Act",
                        CALCULATE([Traffic Act],
                            'D_Dcom-Platform Performance'[platform] = __PlatformDY,
                            'D_Dcom-Platform Performance'[store] = __StoreW),
                    "vs LY%",
                        CALCULATE([Traffic vs LY%],
                            'D_Dcom-Platform Performance'[platform] = __PlatformDY,
                            'D_Dcom-Platform Performance'[store] = __StoreW),
                    BLANK()
