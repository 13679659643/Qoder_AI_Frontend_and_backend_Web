				    VAR __TotalSales = CALCULATE(
				        SUM('G帕累托分析模板数据'[销售额]),
				        ALLSELECTED('G帕累托分析模板数据')
				    )
				    
				    // ── Step 4: 返回累计占比 = 累计值 / 总计 ──
