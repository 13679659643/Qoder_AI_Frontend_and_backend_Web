				    // 对每一行做 CALCULATE(SUM(...)) 获取该子类别的销售额，
				    // 仅保留销售额 >= 当前行值的子类别，外层 CALCULATE 对筛选结果求和
				    VAR __CumulativeSales = 
				        CALCULATE(
				            SUM('G帕累托分析模板数据'[销售额]),
				            FILTER(
				                ALLSELECTED('G帕累托分析模板数据'),
				                CALCULATE(SUM('G帕累托分析模板数据'[销售额])) >= __CurrentSales
