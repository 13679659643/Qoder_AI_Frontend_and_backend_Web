				VAR vIsRatio =
				    IF (
				        IFERROR ( FIND ( "%", MeasureValue ), BLANK () ) <> BLANK (),
				        TRUE (),
				        FALSE ()
				    )
				// 根据柱形值的大小和是否包含百分比信息，定义了柱形值的格式。
				/*
