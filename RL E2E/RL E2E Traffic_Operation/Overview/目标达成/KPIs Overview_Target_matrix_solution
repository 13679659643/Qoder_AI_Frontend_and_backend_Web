2. 构建列维度字段 DIM_ColMetric_Target（新建）
================================================================================

DIM_ColMetric_Target = 
// ========================================
// 表: DIM_ColMetric_Target
// 类型: 断开维度（新建）
// 用途: 目标达成矩阵列维度（10 个指标）
// 设计: 内嵌格式与颜色定义，度量值通过 SELECTEDVALUE 动态读取
//
// 列名去重说明：
//   4 个"vs目标"列通过 UNICHAR(8203)（零宽空格 ZWS）实现技术唯一
//   Power BI Matrix 视觉对象中显示名称视觉一致，均呈现为"vs目标"
//   UNICHAR(8203) 是不可见字符，不影响视觉显示
//   使用 UNION + ROW 构建计算表以支持 UNICHAR 表达式
//
// 格式类型清单：
//   decimal_2     → 两位小数千分位：22.30
//   percent_1dp   → 百分比1位小数：84.8%
//   currency      → 货币整数千分位：¥3,301,263（货币符号由币种切片器决定）
//
// 说明：
//   vs目标列的格式与对应实际值列一致（ROI→decimal_2, 占比→percent_1dp, 成本→currency）
//   vs目标列直接展示目标值，非偏差/delta 值
//
// 颜色说明：
//   所有列统一使用 Metric_ColorDefault（#212121 黑色）
//   Metric_IsVsTarget 标记仅用于标识该列为目标值列，不驱动条件颜色
//
// 汇率转换标记：
//   Metric_IsCurrencyAmount = TRUE → 金额类指标，切换币种时乘以汇率
//   Metric_IsCurrencyAmount = FALSE → 比率/计数类指标，不受汇率影响
// ========================================
VAR __Rows =
    UNION(
        // ═══════════════════════════════════════════════════════
        // ID 1: ROI — 实际 ROI（媒体成交金额 / 调整花费）
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 1,
            "Metric_Name", "ROI",
            "Metric_Sort", 1,
            "Metric_Format", "decimal_2",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 2: vs目标（ROI）— 目标 ROI（fcst_media_sales_amt / fcst_cost_amt）
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 2,
            "Metric_Name", "vs目标",
            "Metric_Sort", 2,
            "Metric_Format", "decimal_2",
            "Metric_IsVsTarget", TRUE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 3: 新客花费占比 — 新客花费 / (新客+老客花费)
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 3,
            "Metric_Name", "新客花费占比",
            "Metric_Sort", 3,
            "Metric_Format", "percent_1dp",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 4: vs目标（新客花费占比）— 目标占比（fcst_cost_amt(new) / fcst_cost_amt(all)）
        // 列名: "vs目标" & UNICHAR(8203)  ← 追加1个零宽空格以区分ID 2
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 4,
            "Metric_Name", "vs目标" & UNICHAR(8203),
            "Metric_Sort", 4,
            "Metric_Format", "percent_1dp",
            "Metric_IsVsTarget", TRUE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 5: 新客成本 — 调整花费 / 媒体新客人数
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 5,
            "Metric_Name", "新客成本",
            "Metric_Sort", 5,
            "Metric_Format", "currency",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", TRUE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 6: vs目标（新客成本）— 目标新客成本（fcst_cost_amt(new) / fcst_user_cnt(new)）
        // 列名: UNICHAR(8203) & "vs目标"  ← 追加1个前置零宽空格以区分ID 2/4
        // 注意: 目标新客成本为金额类指标，IsCurrencyAmount = TRUE，需汇率转换
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 6,
            "Metric_Name", UNICHAR(8203) & "vs目标",
            "Metric_Sort", 6,
            "Metric_Format", "currency",
            "Metric_IsVsTarget", TRUE,
            "Metric_IsCurrencyAmount", TRUE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 7: Acc花费占比 — 目标Acc推广花费 / 目标全部推广花费
        // 注意: 使用 fcst(目标) 花费数据，非实际花费
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 7,
            "Metric_Name", "Acc花费占比",
            "Metric_Sort", 7,
            "Metric_Format", "percent_1dp",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 8: vs销售占比 — 实际Acc推广成交 / 实际全部推广成交
        // 注意: 使用实际销售数据，与 Acc花费占比(目标) 并列对比
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 8,
            "Metric_Name", "vs销售占比",
            "Metric_Sort", 8,
            "Metric_Format", "percent_1dp",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 9: Acc ROI — 实际Acc推广成交 / 实际Acc推广花费
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 9,
            "Metric_Name", "Acc ROI",
            "Metric_Sort", 9,
            "Metric_Format", "decimal_2",
            "Metric_IsVsTarget", FALSE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        ),

        // ═══════════════════════════════════════════════════════
        // ID 10: vs目标（Acc ROI）— 目标 Acc ROI（fcst_promotion_sales_amt(Acc) / fcst_promotion_cost_amt(Acc)）
        // 列名: "vs目标" & UNICHAR(8203) & UNICHAR(8203)  ← 追加2个零宽空格
        // ═══════════════════════════════════════════════════════
        ROW(
            "Metric_ID", 10,
            "Metric_Name", "vs目标" & UNICHAR(8203) & UNICHAR(8203),
            "Metric_Sort", 10,
            "Metric_Format", "decimal_2",
            "Metric_IsVsTarget", TRUE,
            "Metric_IsCurrencyAmount", FALSE,
            "Metric_ColorPositive", "#1A9018",
            "Metric_ColorNegative", "#D64550",
            "Metric_ColorZero", "#E1C233",
            "Metric_ColorDefault", "#212121"
        )
    )
RETURN __Rows

