5.1 目标达成指标 SWITCH 分发 — KPIs Overview Target Base Value
──────────────────────────────────────────────────────────────

KPIs Overview Target Base Value = 
// ========================================
// 度量值: KPIs Overview Target Base Value
// Display Folder: KPIs Overview Target
// 用途: 按渠道（TM/JD/TTL）的目标达成指标 SWITCH 分发器
//       根据 DIM_ColMetric_Target[Metric_ID] 路由到 10 个指标计算逻辑
//       平台筛选由行维度 DIM_RowKPIs_Overview_Channel[Channel_PlatformID] 控制
//       不依赖 Slicer_Platform_Selection
//       TTL 行 = TM + JD 合并汇总（FILTER platform IN {"TM","JD"}）
//       TM/JD 行 = 单平台筛选（platform = __ChannelID）
//       vs目标 列直接计算目标值（fcst_ 前缀字段），非偏差/delta
//       日期上下文由 Dim_Date_Current 关系自然筛选
//       币种转换在 Cell Value 层通过汇率乘数实现（数据源仅 RMB）
// 依赖: DIM_ColMetric_Target[Metric_ID]
//       DIM_RowKPIs_Overview_Channel[Channel_PlatformID]
//       Slicer_DataCaliber_Selection[DataCaliber_ID]
//       a05_e2e_paid_media_channel_data_d, a05_e2e_paid_media_summary_d,
//       a05_e2e_paid_media_product_data_d
// 模式: Disconnected Dimension + Metric_ID SWITCH Dispatch + Channel Row Routing
// ========================================

    // ── 列指标与行渠道上下文 ──
    VAR __SelID = SELECTEDVALUE(DIM_ColMetric_Target[Metric_ID])
    VAR __ChannelID = SELECTEDVALUE(DIM_RowKPIs_Overview_Channel[Channel_PlatformID])
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ── 平台筛选表（根据渠道行维度动态构建）──
    // TM/JD: 筛选对应单一平台
    // TTL: 筛选 TM + JD 两个平台，SUM 自然聚合
    VAR __PlatformFilter_CD =
        FILTER(
            ALL(a05_e2e_paid_media_channel_data_d[platform]),
            IF(
                __ChannelID = "TTL",
                a05_e2e_paid_media_channel_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_channel_data_d[platform] = __ChannelID
            )
        )
    VAR __PlatformFilter_SD =
        FILTER(
            ALL(a05_e2e_paid_media_summary_d[platform]),
            IF(
                __ChannelID = "TTL",
                a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_summary_d[platform] = __ChannelID
            )
        )
    VAR __PlatformFilter_PD =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[platform]),
            IF(
                __ChannelID = "TTL",
                a05_e2e_paid_media_product_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_product_data_d[platform] = __ChannelID
            )
        )

    RETURN
    SWITCH(
        __SelID,

        // ═══════════════════════════════════════════════════════
        // ID 1: ROI — 实际媒体投资回报率
        // 口径: SUM(summary_d[media_sales_amt]) / SUM(summary_d[adj_cost_amt])
        // 来源: 汇总粒度事实表
        // TTL: 合并分子 / 合并分母（加权 ROI，非简单平均）
        // ═══════════════════════════════════════════════════════
        1, VAR __MediaSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[media_sales_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __AdjCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[adj_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__MediaSales, __AdjCost),

        // ═══════════════════════════════════════════════════════
        // ID 2: vs目标（ROI）— 目标 ROI
        // 口径: SUM(summary_d[fcst_media_sales_amt]) / SUM(summary_d[fcst_cost_amt])
        // 来源: 汇总粒度事实表（fcst 目标数据）
        // TTL: 合并目标分子 / 合并目标分母（加权目标 ROI）
        // ═══════════════════════════════════════════════════════
        2, VAR __TgtMediaSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_media_sales_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __TgtCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__TgtMediaSales, __TgtCost),

        // ═══════════════════════════════════════════════════════
        // ID 3: 新客花费占比 — 实际新客花费占总花费（新客+老客）的比例
        // 口径: nc_cost_amt / (nc_cost_amt + ec_cost_amt)
        // 来源: 渠道粒度事实表
        // TTL: 合并 nc_cost / (合并 nc_cost + 合并 ec_cost)
        // ═══════════════════════════════════════════════════════
        3, VAR __NC_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[nc_cost_amt]),
                    __PlatformFilter_CD,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           VAR __EC_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[ec_cost_amt]),
                    __PlatformFilter_CD,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__NC_Cost, __NC_Cost + __EC_Cost),

        // ═══════════════════════════════════════════════════════
        // ID 4: vs目标（新客花费占比）— 目标新客花费占比
        // 口径: SUM(summary_d[fcst_cost_amt] WHERE customer_type='new')
        //       / SUM(summary_d[fcst_cost_amt])
        // 来源: 汇总粒度事实表（fcst 目标数据）
        // TTL: 合并目标新客花费 / 合并目标总花费
        // ═══════════════════════════════════════════════════════
        4, VAR __TgtNC_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle,
                    a05_e2e_paid_media_summary_d[customer_type] = "new"
                )
           VAR __TgtAll_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__TgtNC_Cost, __TgtAll_Cost),

        // ═══════════════════════════════════════════════════════
        // ID 5: 新客成本 — 实际每新客获取成本
        // 口径: SUM(summary_d[adj_cost_amt]) / SUM(summary_d[media_new_member_cnt])
        // 来源: 汇总粒度事实表
        // TTL: 合并分子 / 合并分母（加权成本，非简单平均）
        // 注意: media_new_member_cnt 最细到月度粒度，
        //       需确认 SQL 层已做好粒度处理
        // ═══════════════════════════════════════════════════════
        5, VAR __AdjCostForNC =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[adj_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __NewMemberCnt =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[media_new_member_cnt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__AdjCostForNC, __NewMemberCnt),

        // ═══════════════════════════════════════════════════════
        // ID 6: vs目标（新客成本）— 目标新客成本
        // 口径: SUM(summary_d[fcst_cost_amt] WHERE customer_type='new')
        //       / SUM(summary_d[fcst_user_cnt] WHERE customer_type='new')
        // 来源: 汇总粒度事实表（fcst 目标数据）
        // TTL: 合并目标新客花费 / 合并目标新客人数
        // 注意: 目标新客成本为金额类指标，Cell Value 层需汇率转换
        // ═══════════════════════════════════════════════════════
        6, VAR __TgtNC_FcstCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_cost_amt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle,
                    a05_e2e_paid_media_summary_d[customer_type] = "new"
                )
           VAR __TgtNC_FcstUser =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_user_cnt]),
                    __PlatformFilter_SD,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle,
                    a05_e2e_paid_media_summary_d[customer_type] = "new"
                )
           RETURN DIVIDE(__TgtNC_FcstCost, __TgtNC_FcstUser),

        // ═══════════════════════════════════════════════════════
        // ID 7: Acc花费占比 — 目标 Acceleration 推广花费占全部推广花费的比例
        // 口径: SUM(product_d[fcst_promotion_cost_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[fcst_promotion_cost_amt])
        // 来源: 产品粒度事实表（使用 fcst 目标数据）
        // TTL: 合并 Acc 目标花费 / 合并 全部目标推广花费
        // ═══════════════════════════════════════════════════════
        7, VAR __TgtAccCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[fcst_promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           VAR __TgtAllCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[fcst_promotion_cost_amt]),
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__TgtAccCost, __TgtAllCost),

        // ═══════════════════════════════════════════════════════
        // ID 8: vs销售占比 — 实际 Acceleration 推广成交占全部推广成交的比例
        // 口径: SUM(product_d[promotion_sales_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[promotion_sales_amt])
        // 来源: 产品粒度事实表（使用实际数据）
        // 说明: 与 Acc花费占比(目标) 并列展示，对比花费结构目标与销售结构实际
        // TTL: 合并 Acc 实际成交 / 合并 全部实际成交
        // ═══════════════════════════════════════════════════════
        8, VAR __ActAccSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_sales_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           VAR __ActAllSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_sales_amt]),
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__ActAccSales, __ActAllSales),

        // ═══════════════════════════════════════════════════════
        // ID 9: Acc ROI — 实际 Acceleration 推广 ROI
        // 口径: SUM(product_d[promotion_sales_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[promotion_cost_amt] WHERE framework='Acceleration')
        // 来源: 产品粒度事实表
        // TTL: 合并 Acc 成交 / 合并 Acc 花费（加权 ROI）
        // ═══════════════════════════════════════════════════════
        9, VAR __AccSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_sales_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           VAR __AccCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__AccSales, __AccCost),

        // ═══════════════════════════════════════════════════════
        // ID 10: vs目标（Acc ROI）— 目标 Acc ROI
        // 口径: SUM(product_d[fcst_promotion_sales_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[fcst_promotion_cost_amt] WHERE framework='Acceleration')
        // 来源: 产品粒度事实表（fcst 目标数据）
        // TTL: 合并目标 Acc 成交 / 合并目标 Acc 花费（加权目标 ROI）
        // ═══════════════════════════════════════════════════════
        10, VAR __TgtAccSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[fcst_promotion_sales_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            VAR __TgtAccCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[fcst_promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    __PlatformFilter_PD,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            RETURN DIVIDE(__TgtAccSales, __TgtAccCost),

        // ─── 默认 ──────────────────────────────────────────
        BLANK()
    )

