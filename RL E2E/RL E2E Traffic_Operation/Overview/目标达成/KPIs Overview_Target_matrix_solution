    "Platform_Icon", STRING,       // 图标标识，可用于报表中的可视化显示
    
    // 数据行
    {
        // ALL - 全平台聚合（默认选中）
        {
            "ALL",                 // 平台代码：ALL 代表 TM + JD 全部聚合
            "ALL",                 // 平台显示名称
            10,                    // 排序顺序（起始10，步长10，优先级最高）
            "全平台汇总，聚合 TM + JD 全部数据",  // 平台描述
            TRUE,                  // 默认选中，报表初始展示全平台数据
            TRUE,                  // 激活状态，当前可用
            "全平台",               // 分组
            "聚合",                 // 平台类型
            "🌐"                   // 图标标识
        },
        
