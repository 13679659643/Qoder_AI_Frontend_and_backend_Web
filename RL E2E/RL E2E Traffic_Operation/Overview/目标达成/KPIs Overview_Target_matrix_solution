//     负值（未达成）  → #D64550 玫瑰红
//     零值（恰好达成）→ #E1C233 亮黄色
//   Actual / Target 行：
//     统一使用 #5f6165（不论数值正负）
//
// 注意：对于"越低越好"的指标（如 Cost Rate、Cost Per New Acquisition），
//   如需反转颜色逻辑（正值红、负值绿），可在 DIM_ColMetric_Target 中
//   对该行交换 Metric_ColorPositive 和 Metric_ColorNegative：
//   Metric_ColorPositive = "#D64550"   // 超支 → 红色
//   Metric_ColorNegative = "#1A9018"   // 节省 → 绿色
//
// 依赖: [KPIs Overview Target Cell Value],
//       DIM_RowKPIs_Overview_Target[Indicator_Type],
//       DIM_ColMetric_Target[Metric_Color*]
// ========================================
    VAR __Value = [KPIs Overview Target Cell Value]
    VAR __Indicator = SELECTEDVALUE(DIM_RowKPIs_Overview_Target[Indicator_Type])
    RETURN
        SWITCH(
            TRUE(),

            // 空值：使用默认色
            ISBLANK(__Value),
                SELECTEDVALUE(DIM_ColMetric_Target[Metric_ColorDefault], "#5f6165"),

            // ── 仅 ±Actual vs Target 行启用条件颜色 ──
            __Indicator = "±Actual vs Target-GT" && __Value > 0,
                SELECTEDVALUE(DIM_ColMetric_Target[Metric_ColorPositive], "#1A9018"),
            __Indicator = "±Actual vs Target-GT" && __Value < 0,
                SELECTEDVALUE(DIM_ColMetric_Target[Metric_ColorNegative], "#D64550"),
            __Indicator = "±Actual vs Target-GT" && __Value = 0,
                SELECTEDVALUE(DIM_ColMetric_Target[Metric_ColorZero], "#E1C233"),

            // ── Actual / Target 行：统一默认色 #5f6165 ──
            SELECTEDVALUE(DIM_ColMetric_Target[Metric_ColorDefault], "#5f6165")
        )

