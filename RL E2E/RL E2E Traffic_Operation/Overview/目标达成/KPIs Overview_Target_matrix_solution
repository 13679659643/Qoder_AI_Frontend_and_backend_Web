5. 核心度量值
================================================================================

架构说明：
────────────────────────────
Base Value 拆分为 Actual / Target 两个独立度量值（日期范围不同：Actual=切片器，Target=补满月）。
Cell Value 直接调用这两个度量值，消除 CALCULATE 覆盖行上下文的不确定性。
历史变更详见 changelog.md。

5.1a Actual 实际值 SWITCH 分发 — KPIs Overview Target Actual Base Value
──────────────────────────────────────────────────────────────────────────

KPIs Overview Target Actual Base Value = 
// Actual 行专用：Metric_ID SWITCH 分发（10 列），日期范围=切片器选择
// Platform 单选：ALL→IN{"TM","JD"}；单平台→=__ChannelID

    VAR __SelID = SELECTEDVALUE(DIM_ColMetric_Target[Metric_ID])
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __IsAllPlatform = (__ChannelID = "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    RETURN
    SWITCH(
        __SelID,

        // ID 1: Cost Rate = SUM(cost_amt)/SUM(net_sales_amt) × 1.13 / 1.06；customer_type="ALL" AND page_type="1"
        1,
        VAR __CostAmt = IF(__IsAllPlatform,
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] IN {"TM","JD"},
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle),
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] = __ChannelID,
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle))
        VAR __NetSalesAmt = IF(__IsAllPlatform,
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] IN {"TM","JD"},
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle),
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] = __ChannelID,
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle))
        RETURN DIVIDE(DIVIDE(__CostAmt, __NetSalesAmt) * 1.13 , 1.06),

        // ID 2: RTB Cost ACH% = SUM(cost_amt)（RTB渠道）；customer_type="ALL" AND channel_type="RTB" AND page_type="1"
        2,
        IF(__IsAllPlatform,
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[channel_type] = "RTB",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] IN {"TM","JD"},
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle),
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[channel_type] = "RTB",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] = __ChannelID,
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle)),

        // ID 3: Cost ACH% = SUM(cost_amt)；customer_type="ALL" AND page_type="1"
        3,
        IF(__IsAllPlatform,
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] IN {"TM","JD"},
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle),
            CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] = __ChannelID,
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle)),

        // ID 4: Cost ACH%(Exclude Refund) = SUM(cost_amt - red_packet - rebate)；customer_type="ALL" AND page_type="1"
        4,
        IF(__IsAllPlatform,
            CALCULATE(SUMX(a05_e2e_paid_media_summary_d,
                    a05_e2e_paid_media_summary_d[cost_amt]
                  - a05_e2e_paid_media_summary_d[red_packet]
                  - a05_e2e_paid_media_summary_d[rebate]),
                a05_e2e_paid_media_summary_d[customer_type] = "ALL",
                a05_e2e_paid_media_summary_d[page_type] = "1",
                a05_e2e_paid_media_summary_d[platform] IN {"TM","JD"},
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle),
            CALCULATE(SUMX(a05_e2e_paid_media_summary_d,
                    a05_e2e_paid_media_summary_d[cost_amt]
                  - a05_e2e_paid_media_summary_d[red_packet]
