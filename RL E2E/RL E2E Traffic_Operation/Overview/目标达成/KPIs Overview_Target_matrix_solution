5.2 行路由度量值 — KPIs Overview Target Cell Value
================================================================================

KPIs Overview Target Cell Value = 
// ========================================
// 度量值: KPIs Overview Target Cell Value
// Display Folder: KPIs Overview Target
// 用途: 根据行类型路由到不同的计算逻辑
//       - Actual：直接调用 [Actual Base Value]，金额类指标乘以汇率
//       - Target：直接调用 [Target Base Value]，金额类指标乘以汇率
//       - ±Actual vs Target：(Actual - Target) / Target，不受汇率影响
//
// 架构说明（2026-05-28）：
//   原设计通过 CALCULATE 覆盖行上下文来从单个 Base Value 中取 Actual/Target 值，
//   经测试发现在 ±Actual vs Target 行渲染时 CALCULATE 行上下文覆盖存在问题。
//   改为直接调用两个独立的 Base Value 度量值，彻底消除上下文歧义：
//     [KPIs Overview Target Actual Base Value] → 专门返回实际值
//     [KPIs Overview Target Target Base Value] → 专门返回目标值（含粒度路由）
//   所有行（含 ±Actual vs Target 行）均可直接获取正确的 Actual / Target，
//   不再依赖 CALCULATE 覆盖行维度筛选上下文。
//
// 币种转换说明：
//   数据源仅存储 RMB，Base Value 返回 RMB 原始值
//   切片器选择 RMB → ExchangeRate = 1（原值）
//   切片器选择 USD → ExchangeRate = 7（乘以汇率）
//   仅 Metric_IsCurrencyAmount = TRUE 的金额类指标需要转换
//   ±Actual vs Target 行是比率：(C×R - T×R) / (T×R) = (C-T)/T，汇率约分抵消
//
// 边界：Target=0/空→BLANK；Actual=0/空且 Target 有值→0；否则直接相除
//
// 依赖: [KPIs Overview Target Actual Base Value],
//       [KPIs Overview Target Target Base Value],
//       DIM_RowKPIs_Overview_Target[Indicator_Type],
//       Slicer_Currency_Selection[Currency_ExchangeRate],
//       DIM_ColMetric_Target[Metric_IsCurrencyAmount]
// ========================================
    VAR __Indicator = SELECTEDVALUE(DIM_RowKPIs_Overview_Target[Indicator_Type])
    VAR __ExchangeRate = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)
    VAR __IsCurrencyAmt = SELECTEDVALUE(DIM_ColMetric_Target[Metric_IsCurrencyAmount], FALSE)

    VAR __ActualValue = [KPIs Overview Target Actual Base Value]
    VAR __TargetValue = [KPIs Overview Target Target Base Value]

    VAR __ActualConverted =
        IF(__IsCurrencyAmt, DIVIDE(__ActualValue, __ExchangeRate), __ActualValue)
    VAR __TargetConverted =
        IF(__IsCurrencyAmt, DIVIDE(__TargetValue, __ExchangeRate), __TargetValue)

    // ── 判断分子分母是否为 0 或 空 ──
    VAR __ActIsEmpty = ISBLANK(__ActualValue) || __ActualValue = 0
    VAR __TgtIsEmpty = ISBLANK(__TargetValue) || __TargetValue = 0

    // ── ±Actual vs Target 统一口径：Actual / Target ──
    VAR __VsDelta =
        IF(
            __TgtIsEmpty, 
            BLANK(),                // 1. 分母为0/空 → 返回空
            IF(
                __ActIsEmpty, 
                0,                   // 2. 分母不为0，分子为0/空 → 返回 0
                DIVIDE(__ActualValue, __TargetValue)  // 3. 正常情况 → 直接相除
            )
        )

    RETURN
    SWITCH(
        TRUE(),
        __Indicator = "Actual",            __ActualConverted,
        __Indicator = "Target",            __TargetConverted,
        __Indicator = "±Actual vs Target", __VsDelta,
        BLANK()
    )


