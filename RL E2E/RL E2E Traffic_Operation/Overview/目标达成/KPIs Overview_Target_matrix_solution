6. 格式化显示度量值 — KPIs Overview Target Cell Display
================================================================================

KPIs Overview Target Cell Display = 
// ========================================
// 度量值: KPIs Overview Target Cell Display
// Display Folder: KPIs Overview Target > Formatting
// 用途: 根据列指标的 Metric_Format 返回格式化文本
//       所有行（TM/JD/TTL）统一使用同一格式
//       货币符号从 Slicer_Currency_Selection 动态读取
// 依赖: [KPIs Overview Target Cell Value],
//       DIM_ColMetric_Target[Metric_Format],
//       Slicer_Currency_Selection[Currency_Symbol]
// ========================================

    VAR __Value = [KPIs Overview Target Cell Value]

    // ── 格式类型（从列维度表获取）──
    VAR __Format = SELECTEDVALUE(DIM_ColMetric_Target[Metric_Format])

    // ── 货币符号（由币种切片器决定）──
    VAR __CurrencySymbol =
        SELECTEDVALUE(Slicer_Currency_Selection[Currency_Symbol], "¥")

    RETURN
        IF(
            ISBLANK(__Value),
            "-",                                                                // 空值显示 "-"
            SWITCH(
                __Format,

                // ─── 货币 ───────────────────────────────────────────
                "currency",
                    __CurrencySymbol & FORMAT(__Value, "#,##0"),                 // ¥3,301,263 / $3,301,263

                // ─── 整数 ───────────────────────────────────────────
                "integer",
                    FORMAT(__Value, "#,##0"),                                    // 1,000

                // ─── 两位小数 ───────────────────────────────────────
                "decimal_2",
                    FORMAT(__Value, "#,##0.00"),                                 // 22.30

                // ─── 百分比 1 位小数 ────────────────────────────────
                "percent_1dp",
                    FORMAT(__Value, "0.0%"),                                     // 84.8%

                // ─── 增减百分比 1 位小数（含正负号）─────────────────
                "delta_pct_1dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.0%"),          // +31.5% / -3.2% / 0.0%

                // ─── 扩展格式（预留）─────────────────────────────────
                "currency_k",
                    __CurrencySymbol & FORMAT(__Value / 1000, "#,##0") & "k",
                "percent_2dp",
                    FORMAT(__Value, "0.00%"),
                "delta_pct_2dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.00%"),
                "delta_bp",
                    IF(__Value >= 0, "+", "") & FORMAT(__Value * 10000, "#,##0") & "bp",

                // ─── 默认 ───────────────────────────────────────────
                FORMAT(__Value, "#,##0.00")
            )
        )

