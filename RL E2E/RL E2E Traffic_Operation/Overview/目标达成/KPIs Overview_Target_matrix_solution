// 依赖: DIM_ColMetric_Target[Metric_ID]
//       Slicer_Platform_Selection[Platform_ID]
//       Slicer_DataCaliber_Selection[DataCaliber_ID]
// 模式: Disconnected Dimension + Metric_ID SWITCH Dispatch（Actual only）
