    "Platform_Description", STRING, // 详细描述，说明该平台的具体特点和业务含义
    
    // 扩展字段 - 可选字段
    "Platform_IsDefault", BOOLEAN,  // 是否默认选中
    "Platform_IsActive", BOOLEAN,   // 是否激活状态
    "Platform_Group", STRING,       // 分组标识，用于对相关平台进行逻辑分组
    
