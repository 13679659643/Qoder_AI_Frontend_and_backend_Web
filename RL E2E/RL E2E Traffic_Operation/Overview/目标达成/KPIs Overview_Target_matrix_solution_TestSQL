-- ████████████████████████████████████████████████████████████████████████████████
-- PART 8: TTL 加权验证 — 确认 TTL ≠ 简单平均
-- ████████████████████████████████████████████████████████████████████████████████
-- 此查询同时输出 TM 值、JD 值、TTL 加权值、以及简单平均值
-- 用于验证 TTL 行采用的是加权比率（合并分子/分母）而非简单平均

WITH
tm AS (
    SELECT
        SUM(media_sales_amt) AS ms, SUM(adj_cost_amt) AS ac,
        SUM(fcst_media_sales_amt) AS fms, SUM(fcst_cost_amt) AS fc
    FROM indep_rl_ads.a05_e2e_paid_media_summary_d
    WHERE platform = 'TM' AND trans_cycle = 'T+1'
      AND data_date >= '2026-04-01' AND data_date <= '2026-04-15'
),
jd AS (
    SELECT
        SUM(media_sales_amt) AS ms, SUM(adj_cost_amt) AS ac,
        SUM(fcst_media_sales_amt) AS fms, SUM(fcst_cost_amt) AS fc
    FROM indep_rl_ads.a05_e2e_paid_media_summary_d
    WHERE platform = 'JD' AND trans_cycle = 'T+1'
      AND data_date >= '2026-04-01' AND data_date <= '2026-04-15'
)
SELECT
    -- TM ROI
    tm.ms / NULLIF(tm.ac, 0)                   AS `TM_ROI`,
    -- JD ROI
    jd.ms / NULLIF(jd.ac, 0)                   AS `JD_ROI`,
    -- TTL 加权 ROI（正确）
    (tm.ms + jd.ms) / NULLIF(tm.ac + jd.ac, 0) AS `TTL_ROI_加权`,
    -- TTL 简单平均（错误，仅用于对比）
    (tm.ms / NULLIF(tm.ac, 0) + jd.ms / NULLIF(jd.ac, 0)) / 2
                                                AS `TTL_ROI_简单平均_错误`,
    -- TM 目标 ROI
    tm.fms / NULLIF(tm.fc, 0)                   AS `TM_vs目标_ROI`,
    -- JD 目标 ROI
    jd.fms / NULLIF(jd.fc, 0)                   AS `JD_vs目标_ROI`,
    -- TTL 加权目标 ROI（正确）
    (tm.fms + jd.fms) / NULLIF(tm.fc + jd.fc, 0) AS `TTL_vs目标_ROI_加权`,
    -- TTL 简单平均目标 ROI（错误）
    (tm.fms / NULLIF(tm.fc, 0) + jd.fms / NULLIF(jd.fc, 0)) / 2
                                                AS `TTL_vs目标_ROI_简单平均_错误`
FROM tm, jd;


-- ================================================================================
-- 比对方法说明
-- ================================================================================
--
-- 1. 在 Power BI 中设置切片器：
--    本期日期 = 2026-04-01 ~ 2026-04-15
--    数据口径 = T+1，币种 = RMB
--    Channel 切片器 = 任意值（本矩阵不受 Channel 切片器影响）
--
-- 2. 执行 PART 1 → 比对 Power BI「TM」行的 10 个指标值
--    将 platform = 'TM' 改为 'JD' 后执行 → 比对「JD」行
--    执行 PART 2 → 比对「TTL」行（TM + JD 合并）
--    或执行 PART 3 → 一次性比对全部 3 行 × 10 列
--
-- 3. 如有差异，执行 PART 4 逐指标核查中间值（分子/分母）
--    如仍有差异，执行 PART 5 按日展开定位差异日期
--
-- 4. 验证 USD 时，执行 PART 6 → 比对 Power BI 币种切换为 USD 后的值
--    金额类指标（ID 5 新客成本、ID 6 目标新客成本）应 = RMB × 7
--    比率类指标（ID 1~4, 7~10）应不变
--
-- 5. 验证 Channel 切片器隔离：
--    在 Power BI 中切换 Channel 切片器选择（如从 TM 改为 JD）
--    本矩阵（目标达成）的 3 行 × 10 列数据应完全不变
--    仅 TTL 汇总矩阵会响应 Channel 切片器变化
--
-- 6. 常见差异原因：
--    a) customer_type 过滤：ID 4 分子需过滤 customer_type = 'new'，分母不过滤
--       ID 6 分子和分母均需过滤 customer_type = 'new'
--       → 用 PART 7.2 检查 customer_type 分布
--    b) framework 筛选：ID 7~10 的 Acceleration 过滤
--       确认 framework 字段值拼写一致（大小写敏感）
--       → 用 PART 7.3 检查 framework 分布
--    c) fcst 字段为空：vs目标 列依赖 fcst_ 字段
--       如 fcst 字段全为 NULL，目标值会显示为 "-"
--       → 用 PART 0.4 / 0.5 检查
--    d) TTL 加权 vs 简单平均：TTL 行应为加权比率
--       → 用 PART 8 对比加权值和简单平均值
--    e) NULL 处理：DAX SUM 忽略 NULL，SQL SUM 同样忽略 NULL
--       但 DIVIDE(x, 0) 在 DAX 返回 BLANK，SQL 中用 NULLIF 模拟
--    f) 日期边界：确认两端切片器选择的是 >= AND <=（闭区间）
--    g) 浮点精度：比率类指标小数位可能有微小差异，属正常
-- ================================================================================
