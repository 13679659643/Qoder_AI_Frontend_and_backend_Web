6. 格式化显示度量值 — KPIs Overview Channel Cell Display
================================================================================

KPIs Overview Channel Cell Display = 
// ========================================
// 度量值: KPIs Overview Channel Cell Display
// Display Folder: KPIs Overview Channel > Formatting
// 用途: 根据列指标的 Metric_Format_Current 返回格式化文本
//       所有行（TM/JD/TTL）统一使用本期格式
//       货币符号从 Slicer_Currency_Selection 动态读取
// 依赖: [KPIs Overview Channel Cell Value],
//       DIM_ColMetric_Overview[Metric_Format_Current],
//       Slicer_Currency_Selection[Currency_Symbol]
// ========================================

    VAR __Value = [KPIs Overview Channel Cell Value]

    // ── 格式类型（所有行统一使用 Metric_Format_Current）──
    VAR __Format = SELECTEDVALUE(DIM_ColMetric_Overview[Metric_Format_Current])

    // ── 货币符号（由币种切片器决定）──
    VAR __CurrencySymbol =
        SELECTEDVALUE(Slicer_Currency_Selection[Currency_Symbol], "¥")

    RETURN
        IF(
            ISBLANK(__Value),
            "-",                                                                // 空值显示 "-"
            SWITCH(
                __Format,

                // ─── 货币 ───────────────────────────────────────────
                "currency",
                    __CurrencySymbol & FORMAT(__Value, "#,##0"),                 // ¥1,000 / $1,000

                // ─── 整数 ───────────────────────────────────────────
                "integer",
                    FORMAT(__Value, "#,##0"),                                    // 1,000

                // ─── 两位小数 ───────────────────────────────────────
                "decimal_2",
                    FORMAT(__Value, "#,##0.00"),                                 // 1,000.00

                // ─── 百分比 1 位小数 ────────────────────────────────
                "percent_1dp",
                    FORMAT(__Value, "0.0%"),                                     // 40.5%

                // ─── 增减百分比 1 位小数（含正负号）─────────────────
                // 注: 本矩阵实际不会用到此格式，但为保持与原方案格式分支一致而保留
                "delta_pct_1dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.0%"),          // +14.5% / -3.2% / 0.0%

                // ─── 扩展格式（预留，与 KPIs_TimeFrame_solution 保持一致）───
                "currency_k",
                    __CurrencySymbol & FORMAT(__Value / 1000, "#,##0") & "k",
                "percent_2dp",
                    FORMAT(__Value, "0.00%"),
                "delta_pct_2dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.00%"),
                "delta_bp",
                    IF(__Value >= 0, "+", "") & FORMAT(__Value * 10000, "#,##0") & "bp",

                // ─── 默认 ───────────────────────────────────────────
                FORMAT(__Value, "#,##0.00")
            )
        )

