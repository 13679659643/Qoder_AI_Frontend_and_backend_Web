5.1 本期指标 SWITCH 分发 — KPIs Overview Base Value
────────────────────────────────────────────────────

KPIs Overview Base Value = 
// ========================================
// 度量值: KPIs Overview Base Value
// Display Folder: KPIs Overview
// 用途: 纯指标 SWITCH 分发器
//       根据 DIM_ColMetric_Overview[Metric_ID] 路由到 9 个指标计算逻辑
//       全部 9 个分支已填充真实口径，统一使用 summary_d 表
//
// 口径来源: RL E2E/RL E2E Traffic_Operation/口径文档/Overview.md
// 变更: 2026-06-30 全部 9 个分支填充真实口径，底表统一为 summary_d
//
// Platform 筛选模式（单选切片器）：
//   TTL 行（ALL）→ FILTER platform IN {"TM","JD"}（精确圈定，避免误聚合）
//   TM/JD 行    → platform = __ChannelID（单平台精确筛选）
//   统一通过 __IsAllPlatform 变量判断，各 SWITCH 分支直接引用
//
// 业务筛选条件（嵌入各分支）：
//   page_type="1"（通用，ID9 New Customer Cost% 为 page_type="2"）
//   customer_type='ALL'（通用，新客相关指标为 'NEW'）
//   framework='Acceleration'（ID7/ID8 Acceleration 品类分子筛选）
//   channel IN {"直通车","引力魔方"}（ID9 New Customer Cost% 渠道筛选）
//
// 日期上下文由外层度量值控制（This Year = 关系筛选，Last Year = CALCULATE 覆盖）
// 币种转换在 Cell Value 层通过汇率乘数实现（数据源仅 RMB）
// 依赖: DIM_ColMetric_Overview[Metric_ID]
//       Slicer_Platform_Selection[Platform_ID]（单选 → SELECTEDVALUE）
//       Slicer_DataCaliber_Selection[DataCaliber_ID]（单选 → SELECTEDVALUE）
//       a05_e2e_paid_media_summary_d（统一底表，含全部所需字段）
// 模式: Disconnected Dimension + Metric_ID SWITCH Dispatch
// ========================================

    // ── 切片器上下文 ──
    VAR __SelID = SELECTEDVALUE(DIM_ColMetric_Overview[Metric_ID])
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ── Platform 筛选判断 ──
    // TTL（ALL）：FILTER platform IN {"TM","JD"}，精确圈定两个平台
    // 单平台：   FILTER platform = __ChannelID，精确单选
    VAR __IsAllPlatform = (__ChannelID = "ALL")

    // ── 通用基础筛选条件（customer_type='ALL' AND page_type="1"）──
    // 各指标默认使用此筛选，特殊指标在分支内覆盖
    VAR __BaseFilter_ALL =
        FILTER(
            a05_e2e_paid_media_summary_d,
            a05_e2e_paid_media_summary_d[customer_type] = "ALL"
                && a05_e2e_paid_media_summary_d[page_type] = "1"
                && a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                && (
                    __IsAllPlatform
                        && a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"}
                    || NOT __IsAllPlatform
                        && a05_e2e_paid_media_summary_d[platform] = __ChannelID
                )
        )

    RETURN
    SWITCH(
        __SelID,

        // ═══════════════════════════════════════════════════════
        // ID 1: Cost — 花费金额（含红包/返佣返货金）
        // 口径: SUM(summary_d[cost_amt])
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: currency
        // ═══════════════════════════════════════════════════════
        1, CALCULATE(
               SUM(a05_e2e_paid_media_summary_d[cost_amt]),
               __BaseFilter_ALL
           ),

        // ═══════════════════════════════════════════════════════
        // ID 2: Cost Rate — 花费占比（含红包）
        // 口径: Cost(含红包) / Net Sales × 1.13 / 1.06
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: percent_1dp
        // ═══════════════════════════════════════════════════════
        2, VAR __Cost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __BaseFilter_ALL)
           VAR __NetSales = CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]), __BaseFilter_ALL)
           RETURN DIVIDE(__Cost, __NetSales) * 1.13 / 1.06,

        // ═══════════════════════════════════════════════════════
        // ID 3: Cost (Exclude Refund) — 花费（剔除红包/返佣返货金）
        // 口径: SUM(cost_amt - red_packet - rebate)
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: currency
        // ═══════════════════════════════════════════════════════
        3, CALCULATE(
               SUMX(
                   a05_e2e_paid_media_summary_d,
                   a05_e2e_paid_media_summary_d[cost_amt]
                       - a05_e2e_paid_media_summary_d[red_packet]
                       - a05_e2e_paid_media_summary_d[rebate]
               ),
               __BaseFilter_ALL
           ),

        // ═══════════════════════════════════════════════════════
        // ID 4: Cost Rate (Exclude Refund) — 花费占比（剔除红包/返佣返货金）
        // 口径: Cost(Exclude Refund) / Net Sales × 1.13 / 1.06
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: percent_1dp
        // ═══════════════════════════════════════════════════════
        4, VAR __CostExRefund =
               CALCULATE(
                   SUMX(
                       a05_e2e_paid_media_summary_d,
                       a05_e2e_paid_media_summary_d[cost_amt]
                           - a05_e2e_paid_media_summary_d[red_packet]
                           - a05_e2e_paid_media_summary_d[rebate]
                   ),
                   __BaseFilter_ALL
               )
           VAR __NetSales = CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]), __BaseFilter_ALL)
           RETURN DIVIDE(__CostExRefund, __NetSales) * 1.13 / 1.06,

        // ═══════════════════════════════════════════════════════
        // ID 5: Net Sales — 退后销售额
        // 口径: SUM(summary_d[net_sales_amt])
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: currency
        // ═══════════════════════════════════════════════════════
        5, CALCULATE(
               SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
               __BaseFilter_ALL
           ),

        // ═══════════════════════════════════════════════════════
        // ID 6: ROI — 媒体 ROI
        // 口径: SUM(media_sales_amt) / SUM(cost_amt)
        // 注意: 分母使用含红包/返佣返货金的 cost_amt
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: decimal_1dp
        // ═══════════════════════════════════════════════════════
        6, VAR __MediaSales = CALCULATE(SUM(a05_e2e_paid_media_summary_d[media_sales_amt]), __BaseFilter_ALL)
           VAR __Cost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __BaseFilter_ALL)
           RETURN DIVIDE(__MediaSales, __Cost),

        // ═══════════════════════════════════════════════════════
        // ID 7: Acceleration Cost% — 第二品类花费%
        // 口径: SUM(cost_amt WHERE framework='Acceleration') / SUM(cost_amt WHERE 全部 framework)
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: percent_1dp
        // ═══════════════════════════════════════════════════════
        7, VAR __AccFilter =
               FILTER(
                   a05_e2e_paid_media_summary_d,
                   a05_e2e_paid_media_summary_d[customer_type] = "ALL"
                       && a05_e2e_paid_media_summary_d[page_type] = "1"
                       && a05_e2e_paid_media_summary_d[framework] = "Acceleration"
                       && a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                       && (
                           __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"}
                           || NOT __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] = __ChannelID
                       )
               )
           VAR __AccCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __AccFilter)
           VAR __TTLCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __BaseFilter_ALL)
           RETURN DIVIDE(__AccCost, __TTLCost),

        // ═══════════════════════════════════════════════════════
        // ID 8: ±Acceleration Cost% vs Net Sales% — 第二品类花费% vs Net Sales%
        // 口径: 派生指标 = (Acceleration Cost% - Acceleration SLS MOB%) × 100 转 bp
        //   - Acceleration Cost% = cost_amt(Acc) / cost_amt(TTL)
        //   - Acceleration SLS MOB% = net_sales_amt(Acc) / net_sales_amt(TTL)
        // 本期返回 bp 差值；YOY 行在 Cell Value 层计算同比增长率
        // 筛选: customer_type='ALL' AND page_type="1"
        // 数据类型: delta_bp_1dp
        // ═══════════════════════════════════════════════════════
        8, VAR __AccFilter =
               FILTER(
                   a05_e2e_paid_media_summary_d,
                   a05_e2e_paid_media_summary_d[customer_type] = "ALL"
                       && a05_e2e_paid_media_summary_d[page_type] = "1"
                       && a05_e2e_paid_media_summary_d[framework] = "Acceleration"
                       && a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                       && (
                           __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"}
                           || NOT __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] = __ChannelID
                       )
               )
           VAR __AccCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __AccFilter)
           VAR __TTLCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __BaseFilter_ALL)
           VAR __AccCostPct = DIVIDE(__AccCost, __TTLCost)                      // Acceleration Cost%
           VAR __AccSLS = CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]), __AccFilter)
           VAR __TTLSLS = CALCULATE(SUM(a05_e2e_paid_media_summary_d[net_sales_amt]), __BaseFilter_ALL)
           VAR __AccSLSPct = DIVIDE(__AccSLS, __TTLSLS)                         // Acceleration SLS MOB%
           RETURN (__AccCostPct - __AccSLSPct) * 100,                          // 差值×100 转 bp

        // ═══════════════════════════════════════════════════════
        // ID 9: New Customer Cost% — 招募新客花费占比
        // 口径: cost_amt(NEW) / cost_amt(EXISTING + NEW)
        // 分子筛选: customer_type='NEW' AND page_type="2" AND channel IN {"直通车","引力魔方"}
        // 分母筛选: customer_type IN {"EXISTING","NEW"} AND page_type="2" AND channel IN {"直通车","引力魔方"}
        // 数据类型: percent_1dp
        // ═══════════════════════════════════════════════════════
        9, VAR __NewCustomerFilter =
               FILTER(
                   a05_e2e_paid_media_summary_d,
                   a05_e2e_paid_media_summary_d[customer_type] = "NEW"
                       && a05_e2e_paid_media_summary_d[page_type] = "2"
                       && a05_e2e_paid_media_summary_d[channel] IN {"直通车", "引力魔方"}
                       && a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                       && (
                           __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"}
                           || NOT __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] = __ChannelID
                       )
               )
           VAR __NewExistFilter =
               FILTER(
                   a05_e2e_paid_media_summary_d,
                   a05_e2e_paid_media_summary_d[customer_type] IN {"EXISTING", "NEW"}
                       && a05_e2e_paid_media_summary_d[page_type] = "2"
                       && a05_e2e_paid_media_summary_d[channel] IN {"直通车", "引力魔方"}
                       && a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                       && (
                           __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] IN {"TM", "JD"}
                           || NOT __IsAllPlatform
                               && a05_e2e_paid_media_summary_d[platform] = __ChannelID
                       )
               )
           VAR __NewCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __NewCustomerFilter)
           VAR __NewExistCost = CALCULATE(SUM(a05_e2e_paid_media_summary_d[cost_amt]), __NewExistFilter)
           RETURN DIVIDE(__NewCost, __NewExistCost),

        // ─── 默认 ──────────────────────────────────────────
        BLANK()
    )

