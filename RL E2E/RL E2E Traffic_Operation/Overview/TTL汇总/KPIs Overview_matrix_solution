5.2 行路由度量值 — KPIs Overview Cell Value
────────────────────────────────────────────

KPIs Overview Cell Value = 
// ========================================
// 度量值: KPIs Overview Cell Value
// Display Folder: KPIs Overview
// 用途: 根据行维度（本期 / 同期 / vs LP）路由到不同的计算逻辑
//       - 本期：调用 [Base Value]，金额类指标乘以汇率
//       - 同期：CALCULATE([Base Value], LP 日期覆盖)，金额类指标乘以汇率
//       - vs LP：本期/同期 - 1，增长率不受汇率影响
//
// 币种转换说明：
//   数据源仅存储 RMB，Base Value 返回 RMB 原始值
//   切片器选择 RMB → ExchangeRate = 1（原值）
//   切片器选择 USD → ExchangeRate = 7（乘以汇率）
//   仅 Metric_IsCurrencyAmount = TRUE 的金额类指标需要转换
//   比率/计数类指标不受汇率影响
//   vs LP 行是增长率，本期和同期乘相同汇率后约分抵消，无需转换
//
// 依赖: DIM_RowKPIs_Overview[Indicator Type], Dim_Date_Ly,
//       Slicer_Currency_Selection[Currency_ExchangeRate],
//       DIM_ColMetric_Overview[Metric_IsCurrencyAmount]
// ========================================

    // ── 行上下文 ──
    VAR __Indicator = SELECTEDVALUE(DIM_RowKPIs_Overview[Indicator Type])

    // ── 汇率上下文（从币种切片器获取）──
    VAR __ExchangeRate = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)
    VAR __IsCurrencyAmt = SELECTEDVALUE(DIM_ColMetric_Overview[Metric_IsCurrencyAmount], FALSE)

    // ── 同期日期范围（从断开的 Dim_Date_Ly 获取）──
    VAR __LP_Start = MIN(Dim_Date_Ly[LY_数据日期])
    VAR __LP_End = MAX(Dim_Date_Ly[LY_数据日期])

    // ── 本期值（当前日期上下文，由 Dim_Date_Current 关系自然筛选）──
    VAR __CurrentValue = [KPIs Overview Base Value]

    // ── 同期值（覆盖日期上下文为 LP 日期范围）──
    // REMOVEFILTERS 移除 Dim_Date_Current 上的本期日期筛选
    // FILTER(ALL(Dim_Date_Current)) 重新施加 LP 日期范围
    // 其他维度筛选（platform/trans_cycle）不受影响
    VAR __LP_Value =
        IF(
            ISBLANK(__LP_Start) || ISBLANK(__LP_End),
            BLANK(),
            CALCULATE(
                [KPIs Overview Base Value],
                REMOVEFILTERS(Dim_Date_Current),
                FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] >= __LP_Start
                        && Dim_Date_Current[数据日期] <= __LP_End
                )
            )
        )

    // ── 汇率换算（仅金额类指标需要）──
    VAR __CurrentConverted =
        IF(__IsCurrencyAmt, __CurrentValue * __ExchangeRate, __CurrentValue)
    VAR __LP_Converted =
        IF(__IsCurrencyAmt, __LP_Value * __ExchangeRate, __LP_Value)

    // ── vs LP 同比计算（含边界判断）──
    // 判断逻辑：
    //   同期为 0 或空 → BLANK()（包含双零/双空场景）
    //   本期为 0 或空，同期有值 → -1（即 -100%）
    //   双方均有值 → (本期 - 同期) / 同期
    VAR __CurrIsEmpty = ISBLANK(__CurrentValue) || __CurrentValue = 0
    VAR __LPIsEmpty = ISBLANK(__LP_Value) || __LP_Value = 0
    VAR __VsLP_Result =
        IF(
            __LPIsEmpty,
            BLANK(),
            IF(__CurrIsEmpty, -1, DIVIDE(__CurrentValue - __LP_Value, __LP_Value))
        )

    RETURN
    SWITCH(
        TRUE(),

        // ── 本期：返回汇率换算后的值 ──
        // 金额类指标乘以汇率（RMB=1 不变，USD=7 转换）
        // 比率/计数类指标原值返回（__ExchangeRate 不参与）
        __Indicator = "本期", __CurrentConverted,

        // ── 同期：返回汇率换算后的同期值 ──
        // 与本期同样的汇率换算逻辑
        __Indicator = "同期", __LP_Converted,

        // ── vs LP：同比增长率 ──
        // 增长率不受汇率影响：(C*R - L*R) / (L*R) = (C-L) / L
        // 边界处理：同期为0/空→BLANK，本期为0/空且同期有值→-1
        __Indicator = "vs LP", __VsLP_Result,

        BLANK()
    )

同期日期覆盖示意（假设本期 = 2026-04-12 ~ 2026-04-15，同期 = 2025-04-12 ~ 2025-04-15）：
| 行          | 日期上下文来源                                 | 说明 |
|-------------|-----------------------------------------------|------|
| 本期        | Dim_Date_Current 关系自然筛选 2026-04-12~15   | 直接调用 Base Value |
| 同期        | CALCULATE 覆盖 → 2025-04-12~15               | 调用 Base Value + LP 日期覆盖 |
| vs LP       | 计算得出                                       | (本期 - 同期) / 同期 |

