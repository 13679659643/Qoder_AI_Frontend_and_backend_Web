5. 核心度量值
================================================================================

5.1 本期指标 SWITCH 分发 — KPIs Overview Base Value
────────────────────────────────────────────────────

KPIs Overview Base Value = 
// ========================================
// 度量值: KPIs Overview Base Value
// Display Folder: KPIs Overview
// 用途: 纯指标 SWITCH 分发器
//       根据 DIM_ColMetric_Overview[Metric_ID] 路由到 12 个指标计算逻辑
//       包含维度筛选（platform IN 多选, trans_cycle 单选）
//       日期上下文由外层度量值控制（本期 = 关系筛选，同期 = CALCULATE 覆盖）
//       币种转换在 Cell Value 层通过汇率乘数实现（数据源仅 RMB）
// 依赖: DIM_ColMetric_Overview[Metric_ID]
//       Slicer_Platform_Selection[Platform_ID]（多选 → VALUES + IN）
//       Slicer_DataCaliber_Selection[DataCaliber_ID]（单选 → SELECTEDVALUE）
//       a05_e2e_paid_media_summary_d, a05_e2e_paid_media_channel_data_d,
//       a05_e2e_paid_media_product_data_d
// 模式: Disconnected Dimension + Metric_ID SWITCH Dispatch
// ========================================

    // ── 切片器上下文 ──
    VAR __SelID = SELECTEDVALUE(DIM_ColMetric_Overview[Metric_ID])
    VAR __SelectedPlatforms = VALUES(Slicer_Platform_Selection[Platform_ID])
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    RETURN
    SWITCH(
        __SelID,

        // ═══════════════════════════════════════════════════════
        // ID 1: Cost — 花费金额
        // 口径: SUM(a05_e2e_paid_media_summary_d[cost_amt])
        // 来源: 汇总粒度事实表
        // ═══════════════════════════════════════════════════════
        1, CALCULATE(
                SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
           ),

        // ═══════════════════════════════════════════════════════
        // ID 2: 红包 — 平台红包金额
        // 口径: SUM(a05_e2e_paid_media_channel_data_d[red_packet])
        // 来源: 渠道粒度事实表
        // ═══════════════════════════════════════════════════════
        2, CALCULATE(
                SUM(a05_e2e_paid_media_channel_data_d[red_packet]),
                a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
           ),

        // ═══════════════════════════════════════════════════════
        // ID 3: Cost进度 — 花费完成率 = 实际花费 / 目标花费
        // 口径: SUM(summary_d[cost_amt]) / SUM(summary_d[fcst_cost_amt])
        // ═══════════════════════════════════════════════════════
        3, VAR __ActualCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __FcstCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_cost_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__ActualCost, __FcstCost),

        // ═══════════════════════════════════════════════════════
        // ID 4: NetSales进度 — Net销售额完成率 = 实际Net销售额 / 目标Net销售额
        // 口径: SUM(summary_d[net_sales_amt]) / SUM(summary_d[fcst_net_sales_amt])
        // ═══════════════════════════════════════════════════════
        4, VAR __ActualNetSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __FcstNetSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_net_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__ActualNetSales, __FcstNetSales),

        // ═══════════════════════════════════════════════════════
        // ID 5: DemandSales进度 — Demand销售额完成率 = 实际销售额 / 目标销售额
        // 口径: SUM(summary_d[sales_amt]) / SUM(summary_d[fcst_sales_amt])
        // ═══════════════════════════════════════════════════════
        5, VAR __ActualSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __FcstSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[fcst_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__ActualSales, __FcstSales),

        // ═══════════════════════════════════════════════════════
        // ID 6: 费比 — (花费 - 红包 - 返佣返货金) / (net销售额 * 1.13 / 1.06)
        // 口径: (channel.cost_amt - channel.red_packet - channel.rebate) / (summary.net_sales_amt * 1.13 / 1.06)
        // 注意: 分子来自 ChannelData（渠道粒度含 red_packet / rebate）
        //       分母来自 SummaryData（汇总粒度含 net_sales_amt）
        // ═══════════════════════════════════════════════════════
        6, VAR __ChannelCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
                    a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           VAR __RedPacket =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[red_packet]),
                    a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           VAR __Rebate =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[rebate]),
                    a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           VAR __NetSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(
                __ChannelCost - __RedPacket - __Rebate,
                __NetSales * 1.13 / 1.06
           ),

        // ═══════════════════════════════════════════════════════
        // ID 7: 含红包费比 — 总花费 / (net销售额 * 1.13 / 1.06)
        // 口径: SUM(summary_d[cost_amt]) / (SUM(summary_d[net_sales_amt]) * 1.13 / 1.06)
        // 注意: 分子分母均来自 SummaryData
        // ═══════════════════════════════════════════════════════
        7, VAR __SummaryCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[cost_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __NetSalesForRatio =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[net_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(
                __SummaryCost,
                __NetSalesForRatio * 1.13 / 1.06
           ),

        // ═══════════════════════════════════════════════════════
        // ID 8: ROI — 媒体投资回报率 = 媒体成交金额 / 调整花费
        // 口径: SUM(summary_d[media_sales_amt]) / SUM(summary_d[adj_cost_amt])
        // ═══════════════════════════════════════════════════════
        8, VAR __MediaSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[media_sales_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           VAR __AdjCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[adj_cost_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__MediaSales, __AdjCost),

        // ═══════════════════════════════════════════════════════
        // ID 9: 新客花费占比 — 新客花费 / 总花费（新客+老客）
        // 口径: nc_cost_amt / (nc_cost_amt + ec_cost_amt)
        // 来源: 渠道粒度事实表
        // ═══════════════════════════════════════════════════════
        9, VAR __NC_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[nc_cost_amt]),
                    a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           VAR __EC_Cost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_channel_data_d[ec_cost_amt]),
                    a05_e2e_paid_media_channel_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
                )
           RETURN DIVIDE(__NC_Cost, __NC_Cost + __EC_Cost),

        // ═══════════════════════════════════════════════════════
        // ID 10: 新客成本 — 调整花费 / 媒体新客人数
        // 口径: SUM(summary_d[adj_cost_amt]) / SUM(summary_d[media_new_member_cnt])
        // 注意: media_new_member_cnt 最细到月度粒度，日度筛选时
        //       需确认数据源已按日展开或在 SQL 层做好粒度处理
        // ═══════════════════════════════════════════════════════
        10, VAR __AdjCostForNC =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[adj_cost_amt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
            VAR __NewMemberCnt =
                CALCULATE(
                    SUM(a05_e2e_paid_media_summary_d[media_new_member_cnt]),
                    a05_e2e_paid_media_summary_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_summary_d[trans_cycle] = __TransCycle
                )
            RETURN DIVIDE(__AdjCostForNC, __NewMemberCnt),

        // ═══════════════════════════════════════════════════════
        // ID 11: Acc花费占比 — Acceleration推广花费占全部推广花费的比例
        // 口径: SUM(product_d[promotion_cost_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[promotion_cost_amt])
        // 来源: 产品粒度事实表
        // ═══════════════════════════════════════════════════════
        11, VAR __AccCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    a05_e2e_paid_media_product_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            VAR __TotalPromoCost =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            RETURN DIVIDE(__AccCost, __TotalPromoCost),

        // ═══════════════════════════════════════════════════════
        // ID 12: Acc ROI — Acceleration推广 ROI
        // 口径: SUM(product_d[promotion_sales_amt] WHERE framework='Acceleration')
        //       / SUM(product_d[promotion_cost_amt] WHERE framework='Acceleration')
        // 来源: 产品粒度事实表
        // ═══════════════════════════════════════════════════════
        12, VAR __AccSales =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_sales_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    a05_e2e_paid_media_product_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            VAR __AccCostForROI =
                CALCULATE(
                    SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
                    a05_e2e_paid_media_product_data_d[framework] = "Acceleration",
                    a05_e2e_paid_media_product_data_d[platform] IN __SelectedPlatforms,
                    a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
                )
            RETURN DIVIDE(__AccSales, __AccCostForROI),

        // ─── 默认 ──────────────────────────────────────────
        BLANK()
    )

