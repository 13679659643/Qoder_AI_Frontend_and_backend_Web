// ========================================
// 度量值: KPIs Overview Cell Background Color
// Display Folder: KPIs Overview > Formatting
// 用途: 根据行 Indicator Order 返回交替行背景色
//       Indicator Order 采用起始10步长10规范（10, 20, 30）
//       先除以10还原行位次（10→1, 20→2, 30→3），再取 MOD 判断奇偶
//       奇数位次（This Year=10→1, YOY=30→3）→ 白色 #FFFFFF
//       偶数位次（Last Year=20→2）→ 浅灰色 #F5F5F5
// 依赖: DIM_RowKPIs_Overview[Indicator Order]
// ========================================
    VAR __RowID = SELECTEDVALUE(DIM_RowKPIs_Overview[Indicator Order])
    VAR __EffRowID =
        IF(NOT ISBLANK(__RowID), __RowID, SUM(DIM_RowKPIs_Overview[Indicator Order]))
    VAR __RowPos = INT(__EffRowID / 10)    // 还原行位次：10→1, 20→2, 30→3
    RETURN
        IF(
            MOD(__RowPos, 2) = 0,
            "#F5F5F5",                     // 偶数位次（Last Year）：浅灰色
            "#FFFFFF"                      // 奇数位次（This Year / YOY）：白色
        )

