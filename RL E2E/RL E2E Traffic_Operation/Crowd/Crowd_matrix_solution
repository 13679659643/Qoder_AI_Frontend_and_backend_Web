3.1 公共筛选逻辑说明
────────────────────

所有度量值共享相同的筛选变量模式：

// ── 复用切片器（单选）──
VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

// ── Platform 筛选（单选含 ALL）──
VAR __IsAllPlatform = (__ChannelID = "ALL")
// ALL → platform IN {"TM","JD"}；单平台 → platform = __ChannelID
// 使用 FILTER(ALL(table[platform]), IF(...)) 模式：
//   FILTER + ALL 确保覆盖 platform 列的现有筛选上下文
//   IF 返回布尔条件，FILTER 逐行求值

// ── Crowd 专属切片器（多选，多列 TREATAS 模式）──
// 不使用 SELECTEDVALUE（仅支持单选），改用多列 TREATAS：
//   TREATAS(
//       VALUES(Dim_Crowd_Season_C_Label),
//       a05_e2e_paid_media_crowed_data_d[crowed_layer],
//       a05_e2e_paid_media_crowed_data_d[crowed_name],
//       a05_e2e_paid_media_crowed_data_d[crowed_type]
//   )
// VALUES(Dim_Crowd_Season_C_Label) 返回经过三个切片器交叉筛选后存活的所有行（3 列元组）
// TREATAS 将元组组合映射到事实表对应列，按组合筛选，不会产生幽灵组合
// 全选时 VALUES 返回全部行 → 等价于不筛选

3.2 Crowd Cost
──────────────

Crowd Cost = 
// ========================================
// 度量值: Crowd Cost
// Display Folder: Crowd
// 用途: 花费金额
// 口径: SUM(cost_amt) × ExchangeRate
// 类型: 金额类（唯一需要汇率换算的指标）
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")
    VAR __IsAllPlatform = (__ChannelID = "ALL")
    VAR __ExchangeRate = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)
    VAR __BaseValue =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[cost_amt]),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[platform]),
                IF(__IsAllPlatform,
                    a05_e2e_paid_media_crowed_data_d[platform] IN {"TM", "JD"},
                    a05_e2e_paid_media_crowed_data_d[platform] = __ChannelID)),
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            TREATAS(
                VALUES(Dim_Crowd_Season_C_Label),
                a05_e2e_paid_media_crowed_data_d[crowed_layer],
                a05_e2e_paid_media_crowed_data_d[crowed_name],
                a05_e2e_paid_media_crowed_data_d[crowed_type]
            )
        )
    RETURN
        __BaseValue * __ExchangeRate

