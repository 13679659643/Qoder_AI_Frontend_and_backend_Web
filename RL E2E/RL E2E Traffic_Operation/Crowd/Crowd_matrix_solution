5.1 字体颜色
────────────

Crowd Cell Font Color =
// ========================================
// 度量值: Crowd Cell Font Color
// 中文名: 关键词单元格字体颜色
// Display Folder: Crowd > Formatting
// 用途: 根据矩阵视觉层级返回字体颜色
//       用于条件格式 → 字体颜色
// 矩阵结构: 行维度 = channel -> brand -> framework -> category -> season (五级)
// 颜色规则:
//   - 总计行 (Grand Total) -> #252423 (近黑，强调)
//   - 所有小计行和明细行     -> #5F6165 (深灰)
// ========================================
    VAR __IsSeason = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[season])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[category])
    VAR __IsFramework = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[framework])
    VAR __IsBrand = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[brand])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[channel])

    RETURN
        SWITCH(
            TRUE(),
            NOT(__IsChannel) && NOT(__IsBrand) && NOT(__IsFramework) && NOT(__IsCategory) && NOT(__IsSeason),
                "#252423",
            "#5F6165"
        )

5.2 行背景色
────────────

Crowd Cell Background Color =
// ========================================
// 度量值: Crowd Cell Background Color
// Display Folder: Crowd > Formatting
// 用途: 根据矩阵行层级返回背景色（5 级层次）
// 行维度: channel -> brand -> framework -> category -> season
// 注意: 当 channel 下只有一个子级时，ISINSCOPE(Brand) 也会返回 TRUE，
//       此时该行会被染成 brand 颜色（中米色），无法染成 channel 颜色（深米色）。
//       这是 Power BI 矩阵阶梯式布局的已知限制，非代码问题。
// ========================================
    VAR __IsSeason = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[season])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[category])
    VAR __IsFramework = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[framework])
    VAR __IsBrand = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[brand])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[channel])

    RETURN
        SWITCH(
            TRUE(),
            // ── 第5层：season 明细行 ────────
            // 特征：5 个 ISINSCOPE 全部 = TRUE
            __IsSeason, "#FFFFFF",

            // ── 第4层：category 小计行 ─────────
            // 特征：Category=T, Season=F
            __IsCategory, "#FAF6F1",

            // ── 第3层：framework 小计行 ─────────
            // 特征：Framework=T, Category=F
            __IsFramework, "#F4ECE4",

            // ── 第2层：brand 小计行 ────────
            // 特征：Brand=T, Framework=F
            __IsBrand, "#E6D9C7",

            // ── 第1层：channel 行 + 总计行 ────────
            // channel 行特征：Channel=T, Brand=F
            // 总计行特征：全部 = FALSE
            "#DBC6A8"
        )

// ISINSCOPE 函数说明（5 级行维度）：
//   总计行：所有 ISINSCOPE = FALSE
//   channel 行：仅 ISINSCOPE(channel) = TRUE
//   brand 小计行：ISINSCOPE(channel) + ISINSCOPE(brand) = TRUE
//   framework 小计行：前 3 个 = TRUE
//   category 小计行：前 4 个 = TRUE
//   season 明细行：全部 5 个 = TRUE
//   SWITCH 从最深层级开始判断（自底向上），保证匹配到最具体层级

