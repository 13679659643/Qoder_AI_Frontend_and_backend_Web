5.2 行背景色
────────────

Crowd Cell Background Color = 
// ========================================
// 度量值: Crowd Cell Background Color
// Display Folder: Crowd > Formatting
// 用途: 根据行类型返回背景色
//       channel 行（一级行头）和总计行 → #f8f5f1（浅米色）
//       crowed_layer 明细行 → #ffffff（白色）
// ========================================
    VAR __HasCrowedLayer = HASONEVALUE(a05_e2e_paid_media_crowed_data_d[crowed_layer])
    RETURN
        IF(__HasCrowedLayer, "#FFFFFF", "#F8F5F1")

// ────────────────────────────────────────
// HASONEVALUE 函数说明
// ────────────────────────────────────────
// 语法: HASONEVALUE(<列>)
// 返回: BOOLEAN（TRUE / FALSE）
// 功能: 判断当前筛选上下文中，指定列是否恰好只有一个不重复值
//
// 行为详解：
//   在 Table 视觉对象中，每一行对应一个筛选上下文：
//   - channel 行（如 "TM"）：crowed_layer 列在该行上下文中可能有多个值
//     （TM 下有多个 crowed_layer），HASONEVALUE(crowed_layer) = FALSE
//   - crowed_layer 明细行（如 "核心人群"）：crowed_layer 列只有一个值
//     HASONEVALUE(crowed_layer) = TRUE
//   - 总计行：crowed_layer 列有所有值，HASONEVALUE(crowed_layer) = FALSE
//
// 等价写法：
//   HASONEVALUE(表[列]) ≡ COUNTROWS(VALUES(表[列])) = 1
//   但 HASONEVALUE 更简洁，且在无数据时返回 FALSE（COUNTROWS=0 ≠ 1）
//
// 本场景应用：
//   HASONEVALUE = TRUE  → 当前行为 crowed_layer 明细行 → 白色 #ffffff
//   HASONEVALUE = FALSE → 当前行为 channel 行或总计行 → 浅米色 #f8f5f1
// ────────────────────────────────────────

