5. 格式化显示度量值 — Crowd Cell Display
================================================================================

Crowd Cell Display =
// ========================================
// 度量值: Crowd Cell Display
// Display Folder: Crowd YOY > Formatting
// 用途: 根据行类型 + 列指标格式，返回格式化文本
//       格式类型从 DIM_ColMetric_Keyword_Crowd 动态读取
//       货币符号从 Slicer_Currency_Selection 动态读取
//
// 格式类型说明（与口径文档 Crowd.md 一致）：
//   currency              → 币种符号 + #,##0（千分位整数）→ Cost
//   currency_decimal_1dp  → 币种符号 + #,##0.0（千分位一位小数）→ CPC / CPATC
//   decimal_1dp           → #,##0.0（一位小数）→ ROI
//   percent_1dp           → 0.0%（百分比一位小数）→ Cost% / CTR / CVR
//   integer               → #,##0（千分位整数）→ Click / Add to Cart
//
// YOY 行（Period on Period）格式：
//   所有指标统一用 percent_1dp（增长率百分比）
//   由 DIM_ColMetric_Keyword_Crowd[Metric_Format_VsLP] = "percent_1dp" 控制
//
// 依赖: [Crowd Cell Value]
//       DIM_ColMetric_Keyword_Crowd[Metric_Format_*]
//       DIM_RowKPIs_Keyword_Crowd[Indicator Type]
//       Slicer_Currency_Selection[Currency_Symbol]
// ========================================

    VAR __Value          = [Crowd Cell Value]
    VAR __Indicator      = SELECTEDVALUE(DIM_RowKPIs_Keyword_Crowd[Indicator Type])
    VAR __Format         =
        SWITCH(
            __Indicator,
            "This Year",         SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_Format_Current]),
            "Last Year",         SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_Format_LP]),
            "Period on Period",  SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_Format_VsLP]),
            SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_Format_Current])
        )
    VAR __CurrencySymbol =
        SELECTEDVALUE(Slicer_Currency_Selection[Currency_Symbol], "¥")

    RETURN
        IF(
            ISBLANK(__Value),
            "-",
            SWITCH(
                __Format,

                // ─── 1. 基础数字格式 ───────────────────────────────────────────
                "integer",                 FORMAT(__Value, "#,##0"),                                    // 1,000
                "decimal_1dp",             FORMAT(__Value, "#,##0.0"),                                  // 1,000.0

                // ─── 2. 货币格式 ─────────────────────────────────────────────
                "currency",                __CurrencySymbol & FORMAT(__Value, "#,##0"),                 // ¥1,000
                "currency_decimal_1dp",    __CurrencySymbol & FORMAT(__Value, "#,##0.0"),               // ¥1,000.0

                // ─── 3. 百分比格式 ──────────────────────────────────────────
                "percent_1dp",             FORMAT(__Value, "0.0%"),                                     // 40.5%

                // ─── 4. 默认兜底格式 ─────────────────────────────────────────
                FORMAT(__Value, "#,##0.00")                                           // 默认: 1,000.00
            )
        )


