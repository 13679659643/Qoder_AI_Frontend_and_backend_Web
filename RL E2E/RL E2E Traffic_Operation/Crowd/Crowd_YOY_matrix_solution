4. 行路由度量值 — Crowd Cell Value
================================================================================

Crowd Cell Value =
// ========================================
// 度量值: Crowd Cell Value
// Display Folder: Crowd YOY
// 用途: 根据行维度（This Year / Last Year / Period on Period）路由到不同的计算逻辑
//       - This Year          ：调用 [Crowd Base Value]，金额类指标乘以汇率
//       - Last Year          ：CALCULATE([Crowd Base Value], LP 日期覆盖)，金额类指标乘以汇率
//       - Period on Period   ：(This Year - Last Year) / Last Year，增长率不受汇率影响
//
// 同期日期覆盖机制参考 Media Mix_matrix_solution#L820-841（LP 日期覆盖机制）：
//   REMOVEFILTERS(Dim_Date_Current) + FILTER(ALL(Dim_Date_Current), 日期范围)
//   日期范围来自 Dim_Date_Ly[LY_数据日期] 的 MIN/MAX
//
// 依赖: DIM_RowKPIs_Keyword_Crowd[Indicator Type]
//       Dim_Date_Ly
//       Slicer_Currency_Selection[Currency_ExchangeRate]
//       DIM_ColMetric_Keyword_Crowd[Metric_IsCurrencyAmount]
//       [Crowd Base Value]
// ========================================

    // ── 行上下文 ──
    VAR __Indicator     = SELECTEDVALUE(DIM_RowKPIs_Keyword_Crowd[Indicator Type])

    // ── 汇率上下文 ──
    VAR __ExchangeRate  = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)
    VAR __IsCurrencyAmt = SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_IsCurrencyAmount], FALSE)

    // ── 同期日期范围（来自 Dim_Date_Ly 断开维度）──
    VAR __LP_Start      = MIN(Dim_Date_Ly[LY_数据日期])
    VAR __LP_End        = MAX(Dim_Date_Ly[LY_数据日期])

    // ── This Year 值 ──
    VAR __CurrentValue  = [Crowd Base Value]

    // ── Last Year 值（覆盖日期上下文为 LP 日期范围）──
    // 机制：REMOVEFILTERS(Dim_Date_Current) 清除本期日期筛选
    //       + FILTER(ALL(Dim_Date_Current), 日期在 LP 范围内) 重新施加同期日期筛选
    //       其他维度筛选（channel/platform/trans_cycle/season/category/brand）不受影响
    VAR __LP_Value      =
        IF(
            ISBLANK(__LP_Start) || ISBLANK(__LP_End),
            BLANK(),
            CALCULATE(
                [Crowd Base Value],
                REMOVEFILTERS(Dim_Date_Current),
                FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] >= __LP_Start
                        && Dim_Date_Current[数据日期] <= __LP_End
                )
            )
        )

    // ── 汇率换算 ──
    // 仅金额类指标（Metric_IsCurrencyAmount = TRUE）乘以汇率
    // 比率类指标（CPC/CPATC 等）不乘汇率（分子分母同币种，比值无币种维度）
    VAR __CurrentConverted =
        IF(__IsCurrencyAmt, DIVIDE(__CurrentValue, __ExchangeRate), __CurrentValue)
    VAR __LP_Converted     =
        IF(__IsCurrencyAmt, DIVIDE(__LP_Value, __ExchangeRate), __LP_Value)

    // ── YOY 同比计算 ──
    // 口径：(This Year - Last Year) / Last Year
    // 边界处理：
    //   - Last Year 为空或 0 → YOY 返回 BLANK（避免除以 0）
    //   - This Year 为空或 0 且 Last Year 有值 → YOY = -1（即 -100%）
    //   - 增长率不受汇率影响（分子分母同币种，比值无币种维度）
    VAR __CurrIsEmpty   = ISBLANK(__CurrentValue) || __CurrentValue = 0
    VAR __LPIsEmpty     = ISBLANK(__LP_Value)     || __LP_Value = 0
    VAR __YOY_Result    =
        IF(
            __LPIsEmpty,
            BLANK(),
            IF(__CurrIsEmpty, -1, DIVIDE(__CurrentValue - __LP_Value, __LP_Value))
        )

    RETURN
    SWITCH(
        TRUE(),
        __Indicator = "This Year",         __CurrentConverted,
        __Indicator = "Last Year",         __LP_Converted,
        __Indicator = "Period on Period",  __YOY_Result,
        BLANK()
    )

