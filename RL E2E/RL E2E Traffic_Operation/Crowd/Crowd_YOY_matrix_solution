DIM_RowKPIs_Keyword_Crowd =
// ========================================
// 表: DIM_RowKPIs_Keyword_Crowd
// 类型: 断开维度
// 用途: Crowd YOY 矩阵行内层维度（This Year / Last Year / Period on Period）
//       结构与 DIM_RowKPIs_Media_Mix / DIM_RowKPIs_Overview 完全一致，复用同一模式
//       单独建表以避免跨页面相互干扰
// 行标签说明：
//   This Year         — 当期值（本期日期范围对应的实际值）
//   Last Year         — 上期值（同期日期范围 LP 对应的值）
//   Period on Period  — 同比 YOY（(当期 - 上期) / 上期）
// ========================================
DATATABLE(
    "Indicator Type",  STRING,     // 行标签（英文）
    "Indicator Order", INTEGER,    // 排序值（起始10，步长10，便于后续插入新行）
    {
        { "This Year",         10 },
        { "Last Year",         20 },
        { "Period on Period",  30 }
    }
)

