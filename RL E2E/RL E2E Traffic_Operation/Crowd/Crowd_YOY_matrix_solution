3. 指标 SWITCH 分发 — Crowd Base Value
================================================================================

Crowd Base Value =
// ========================================
// 度量值: Crowd Base Value
// Display Folder: Crowd YOY
// 用途: 纯指标 SWITCH 分发器，9 列指标统一聚合分发
//       返回 RMB 原始值（不乘汇率，汇率换算在 Cell Value 层处理）
//
// 架构说明：
//     行维度筛选上下文由矩阵自然传递，无需 DAX 处理
//   - 列上下文：DIM_ColMetric_Keyword[Metric_ID] 由 SELECTEDVALUE 获取
//   - 固定数据范围筛选（SPEC：channel=直通车/引力魔方/全站推）：
//     * channel IN {"直通车","引力魔方","全站推"} 固定筛选
//     * FILTER(VALUES()) 交集模式（channel 不是行维度，但保留筛选语义一致性）
//   - 切片器筛选：
//     * Slicer_Platform_Selection（Platform，单选含 ALL，复用 Overview）
//     * Slicer_DataCaliber_Selection（trans_cycle，单选，复用 Overview）
//     * Dim_Crowd_Season_C_Label（Super Season / Category / Label 三列同源，多选级联）
//       - [Super Season] → 事实表字段 season
//       - [Category]     → 事实表字段 category
//       - [Label]        → 事实表字段 brand
//
// 依赖: DIM_ColMetric_Keyword_Crowd[Metric_ID]
//       Slicer_Platform_Selection[Platform_ID]
//       Slicer_DataCaliber_Selection[DataCaliber_ID]
//       Dim_Crowd_Season_C_Label[Super Season / Category / Label]
//       a05_e2e_paid_media_crowed_data_d
//       Dim_Date_Current（关系传递 data_date 筛选，本度量值不直接引用）
// ========================================

    // ── 列上下文 ──
    VAR __MetricID = SELECTEDVALUE(DIM_ColMetric_Keyword_Crowd[Metric_ID])

    // ── 复用切片器（单选）──
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ── Dim_Crowd_Season_C_Label 切片器值（多选）──
    VAR __SuperSeasonVals = VALUES(Dim_Crowd_Season_C_Label[Super Season])
    VAR __CategoryVals = VALUES(Dim_Crowd_Season_C_Label[Category])
    VAR __LabelVals = VALUES(Dim_Crowd_Season_C_Label[Label])

    // ── Platform FILTER 块 ──
    // __ChannelID = "ALL" → platform IN {"TM","JD"}（精确圈定 TM+JD）
    // __ChannelID = "TM"/"JD" → platform = __ChannelID（单平台精确筛选）
    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_crowed_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_crowed_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_crowed_data_d[platform] = __ChannelID))

    // ── Channel 固定数据范围筛选（SPEC：channel=直通车/引力魔方/全站推）──
    // FILTER(VALUES()) 交集模式：保留行维度筛选，仅保留 channel 在 SPEC 范围内的行
    VAR __ChannelScopeFilter =
        FILTER(
            VALUES(a05_e2e_paid_media_crowed_data_d[channel]),
            a05_e2e_paid_media_crowed_data_d[channel] IN {"直通车", "引力魔方", "全站推"})

    // ── 公共筛选参数（所有指标共用）──
    // 行维度（category / keyword_type / plan_name / keyword_name）由矩阵行上下文自然传递
    // 此处仅施加切片器 + 固定范围筛选
    // ⚠️ 严禁在 CALCULATE 中使用 FILTER(ALL(事实表), ...)，会破坏 Dim_Date_Current
    //    通过关系传递的 data_date 上下文，导致 Cell Value 层 LP 日期覆盖失效

    // ── ID 1: Cost — 花费金额 ──
    VAR __Cost =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[cost_amt]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )

    // ── ID 2: Cost% — 花费占比 ──
    // 口径：DIVIDE(当前行 cost_amt, 总计 cost_amt)
    // 分母移除全部 4 个行维度（category / keyword_type / plan_name / keyword_name）
    // 分母用 FILTER(ALL()) 仅保留切片器 + channel 固定范围筛选
    VAR __TotalCost =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[cost_amt]),
            __PlatformFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(ALLSELECTED(a05_e2e_paid_media_crowed_data_d[channel]),
                a05_e2e_paid_media_crowed_data_d[channel] IN {"直通车", "引力魔方", "全站推"}),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )
    VAR __CostPct = DIVIDE(__Cost, __TotalCost)

    // ── ID 3: ROI — 媒体ROI = sales_amt / cost_amt ──
    VAR __GMV =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[sales_amt]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )
    VAR __ROI = DIVIDE(__GMV, __Cost)

    // ── ID 4: Click — 点击量 ──
    VAR __Click =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[click]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )

    // ── ID 5: CPC — 平均点击花费 = cost_amt / click（比率类，不乘汇率）──
    VAR __CPC = DIVIDE(__Cost, __Click)

    // ── ID 6: CTR — 点击率 = click / pv ──
    VAR __PV =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[pv]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )
    VAR __CTR = DIVIDE(__Click, __PV)

    // ── ID 7: CVR — 点击转化率 = sales_order_cnt / click ──
    VAR __Orders =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[sales_order_cnt]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )
    VAR __CVR = DIVIDE(__Orders, __Click)

    // ── ID 8: Add to Cart — 加购数 ──
    VAR __AddToCart =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[add_cart_cnt]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[season]),
                a05_e2e_paid_media_crowed_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[category]),
                a05_e2e_paid_media_crowed_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[brand]),
                a05_e2e_paid_media_crowed_data_d[brand] IN __LabelVals)
        )

    // ── ID 9: CPATC — 加购成本 = cost_amt / add_cart_num（比率类，不乘汇率）──
    VAR __CPATC = DIVIDE(__Cost, __AddToCart)

    RETURN
    SWITCH(
        __MetricID,

        // ═══════════════════════════════════════════════════════
        // ID 1: Cost — 花费金额
        // 口径: SUM(cost_amt)
        // ═══════════════════════════════════════════════════════
        1, __Cost,

        // ═══════════════════════════════════════════════════════
        // ID 2: Cost% — 花费占比
        // 口径: 当前行 cost / 总计 cost
        // ═══════════════════════════════════════════════════════
        2, __CostPct,

        // ═══════════════════════════════════════════════════════
        // ID 3: ROI — 媒体ROI
        // 口径: sales_amt / cost_amt = GMV / Cost
        // ═══════════════════════════════════════════════════════
        3, __ROI,

        // ═══════════════════════════════════════════════════════
        // ID 4: Click — 点击量
        // 口径: SUM(click)
        // ═══════════════════════════════════════════════════════
        4, __Click,

        // ═══════════════════════════════════════════════════════
        // ID 5: CPC — 平均点击花费
        // 口径: Cost / Click = DIVIDE(__Cost, __Click)
        // ═══════════════════════════════════════════════════════
        5, __CPC,

        // ═══════════════════════════════════════════════════════
        // ID 6: CTR — 点击率
        // 口径: Click / Impression = DIVIDE(__Click, __PV)
        // ═══════════════════════════════════════════════════════
        6, __CTR,

        // ═══════════════════════════════════════════════════════
        // ID 7: CVR — 点击转化率
        // 口径: Orders / Click = DIVIDE(__Orders, __Click)
        // ═══════════════════════════════════════════════════════
        7, __CVR,

        // ═══════════════════════════════════════════════════════
        // ID 8: Add to Cart — 加购数
        // 口径: SUM(add_cart_cnt)
        // ═══════════════════════════════════════════════════════
        8, __AddToCart,

        // ═══════════════════════════════════════════════════════
        // ID 9: CPATC — 加购成本
        // 口径: Cost / Add to Cart = DIVIDE(__Cost, __AddToCart)
        // ═══════════════════════════════════════════════════════
        9, __CPATC,

        // ─── 默认 ──────────────────────────────────────────────
        BLANK()
    )

