Crowd_matrix_TA_solution — 基于 Crowd_matrix_solution 的 DAX 差异补丁

> 本文件仅记录与 Crowd_matrix_solution 存在 DAX 逻辑差异的度量值。
> 未列出的核心度量值（Cost / ROI / Click / CPC / CTR / CVR / Add to Cart / CPATC）
> = 原方案同名度量值仅加 "TA" 前缀（Crowd XXX → Crowd TA XXX），DAX 逻辑无变化。
> Display Folder 统一：Crowd → Crowd TA / Crowd > Display → Crowd TA > Display

================================================================================
变更 1：行维度 5→4 + 重排序
================================================================================

原：channel → crowed_layer → crowed_name → crowed_type → customer_type（5 级）
新：crowed_layer → channel → crowed_name → crowed_type（4 级）

Table 视觉对象行配置：
  * a05_e2e_paid_media_crowed_data_d[crowed_layer]
  * a05_e2e_paid_media_crowed_data_d[channel]
  * a05_e2e_paid_media_crowed_data_d[crowed_name]
  * a05_e2e_paid_media_crowed_data_d[crowed_type]

================================================================================
变更 2：Crowd TA Cost%（REMOVEFILTERS 4 字段）
================================================================================

Crowd TA Cost% =
// ========================================
// 度量值: Crowd TA Cost%
// 中文名: 花费占比
// Display Folder: Crowd TA
// 用途: 每行花费占总计花费的百分比
// 口径: DIVIDE(当前行 cost_amt, 总计 cost_amt)
//       分母不受行维度（crowed_layer / channel / crowed_name / crowed_type）筛选上下文影响
//       分母使用 REMOVEFILTERS 移除全部 4 个行维度 + FILTER(ALL()) 仅保留切片器筛选
//       注意：分母不能用 FILTER(VALUES()) 因为 VALUES 在行上下文中求值后
//             会固化当前行的值，导致 REMOVEFILTERS 被抵消，Cost% 始终为 1
// 类型: 比率类，不乘汇率
// 数据字典: cost_amt = 花费
// 与原方案差异: REMOVEFILTERS 从 5 字段减为 4 字段（移除 customer_type），
//              维度顺序调整为 crowed_layer → channel
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    VAR __SuperSeasonVals = VALUES(Dim_Crowd_Season_C_Label[Super Season])
    VAR __CategoryVals = VALUES(Dim_Crowd_Season_C_Label[Category])
    VAR __LabelVals = VALUES(Dim_Crowd_Season_C_Label[Label])

    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_crowed_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_crowed_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_crowed_data_d[platform] = __ChannelID))

    VAR __CostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[cost_amt]),
            __PlatformFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            // ── 分子：FILTER(VALUES()) 交集模式，保留行维度筛选 ──
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[crowed_layer]),
                a05_e2e_paid_media_crowed_data_d[crowed_layer] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[crowed_name]),
                a05_e2e_paid_media_crowed_data_d[crowed_name] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_crowed_data_d[crowed_type]),
                a05_e2e_paid_media_crowed_data_d[crowed_type] IN __LabelVals)
        )

    VAR __TotalCostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_crowed_data_d[cost_amt]),
            // ── 分母：移除全部 4 个行维度筛选（crowed_layer / channel / crowed_name / crowed_type）──
            REMOVEFILTERS(a05_e2e_paid_media_crowed_data_d[crowed_layer]),
            REMOVEFILTERS(a05_e2e_paid_media_crowed_data_d[channel]),
            REMOVEFILTERS(a05_e2e_paid_media_crowed_data_d[crowed_name]),
            REMOVEFILTERS(a05_e2e_paid_media_crowed_data_d[crowed_type]),
            __PlatformFilter,
            a05_e2e_paid_media_crowed_data_d[trans_cycle] = __TransCycle,
            // ── 分母：FILTER(ALL()) 仅保留切片器筛选（不用 FILTER(VALUES())）──
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[crowed_layer]),
                a05_e2e_paid_media_crowed_data_d[crowed_layer] IN __SuperSeasonVals),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[crowed_name]),
                a05_e2e_paid_media_crowed_data_d[crowed_name] IN __CategoryVals),
            FILTER(ALL(a05_e2e_paid_media_crowed_data_d[crowed_type]),
                a05_e2e_paid_media_crowed_data_d[crowed_type] IN __LabelVals)
        )

    RETURN
        DIVIDE(__CostAmt, __TotalCostAmt)

