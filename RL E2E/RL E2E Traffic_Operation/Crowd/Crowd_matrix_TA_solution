变更 3：Crowd TA Cell Font Color（ISINSCOPE 4 级）
================================================================================

Crowd TA Cell Font Color =
// ========================================
// 度量值: Crowd TA Cell Font Color
// 中文名: 人群单元格字体颜色
// Display Folder: Crowd TA > Formatting
// 用途: 根据矩阵视觉层级返回字体颜色
//       用于条件格式 → 字体颜色
// 矩阵结构: 行维度 = crowed_layer -> channel -> crowed_name -> crowed_type (四级)
// 颜色规则:
//   - 总计行 (Grand Total) -> #252423 (近黑，强调)
//   - 所有小计行和明细行     -> #5F6165 (深灰)
// 与原方案差异: ISINSCOPE 从 5 级减为 4 级（移除 __IsCustomerType），
//              维度判断顺序调整为 __IsLayer 在最外层
// ========================================
    VAR __IsType = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[crowed_type])
    VAR __IsName = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[crowed_name])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[channel])
    VAR __IsLayer = ISINSCOPE(a05_e2e_paid_media_crowed_data_d[crowed_layer])

    RETURN
        SWITCH(
            TRUE(),
            // ── 总计行：全部 ISINSCOPE = FALSE ──
            NOT(__IsLayer) && NOT(__IsChannel) && NOT(__IsName) && NOT(__IsType),
                "#252423",
            // ── 其余所有行（crowed_layer / channel / crowed_name / crowed_type）──
            "#5F6165"
        )

