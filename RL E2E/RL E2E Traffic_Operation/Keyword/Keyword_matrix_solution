变更 3：Keyword Cell Font Color（ISINSCOPE 4 级）
================================================================================

Keyword Cell Font Color =
// ========================================
// 度量值: Keyword Cell Font Color
// 中文名: 关键词单元格字体颜色
// Display Folder: Keyword > Formatting
// 用途: 根据矩阵视觉层级返回字体颜色
//       用于条件格式 → 字体颜色
// 矩阵结构: 行维度 = category -> keyword_type -> channel -> keyword_name (四级)
// 颜色规则:
//   - 总计行 (Grand Total) -> #252423 (近黑，强调)
//   - 所有小计行和明细行     -> #5F6165 (深灰)
// 与原方案差异: ISINSCOPE 从 5 级减为 4 级（移除 __IsCustomerType / __IsFramework / __IsBrand），
//              新增 __IsKWType / __IsKWName，维度判断顺序调整为 __IsCategory 在最外层
// ========================================
    VAR __IsKWName = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[keyword_name])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[channel])
    VAR __IsKWType = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[keyword_type])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[category])

    RETURN
        SWITCH(
            TRUE(),
            // ── 总计行：全部 ISINSCOPE = FALSE ──
            NOT(__IsCategory) && NOT(__IsKWType) && NOT(__IsChannel) && NOT(__IsKWName),
                "#252423",
            // ── 其余所有行（category / keyword_type / channel / keyword_name）──
            "#5F6165"
        )

