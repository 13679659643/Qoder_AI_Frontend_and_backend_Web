Keyword Cost% Display =
// ========================================
// 度量值: Keyword Cost% Display
// 中文名: 花费占比（格式化）
// Display Folder: Keyword > Display
// 用途: Keyword Cost% 的格式化显示
// 数据类型: 百分比（保留一位小数，负数带负号）
// 格式字符串: "0.0%;-0.0%;0.0%"
// 示例: 12.5% / -3.2% / 0.0%
// 与原方案差异: 引用名从 [Keyword X Cost%] 改为 [Keyword Cost%]
// ========================================
    FORMAT([Keyword Cost%], "0.0%;-0.0%;0.0%")

// 其余 8 个 Display 度量值 DAX 逻辑无变化，直接使用原方案对应度量值。

