变更 4：Keyword Cell Background Color（4 级层次）
================================================================================

Keyword Cell Background Color =
// ========================================
// 度量值: Keyword Cell Background Color
// 中文名: 关键词单元格行背景色
// Display Folder: Keyword > Formatting
// 用途: 根据矩阵行层级返回背景色（4 级层次）
// 矩阵结构: category -> keyword_type -> channel -> keyword_name
// 颜色规则:
//   - category 行 + 总计行  -> #DBC6A8 (深米色)
//   - keyword_type 行       -> #E6D9C7 (中米色)
//   - channel 行            -> #F4ECE4 (浅米色)
//   - keyword_name 明细行   -> #FAF6F1 (淡米色)
// 与原方案差异: 从 5 级减为 4 级（移除 customer_type #FFFFFF 白色层），
//              SWITCH 层级映射调整为 category=顶层 / keyword_type=二层
// ========================================
    VAR __IsKWName = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[keyword_name])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[channel])
    VAR __IsKWType = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[keyword_type])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[category])

    RETURN
        SWITCH(
            TRUE(),
            // ── 第4层：keyword_name 明细行（最深，优先判断）──
            __IsKWName, "#FFFFFF",
            // ── 第3层：channel 行 ──
            __IsChannel, "#F4ECE4",
            // ── 第2层：keyword_type 行 ──
            __IsKWType, "#E6D9C7",
            // ── 第1层：category 行 + 总计行（default）──
            "#DBC6A8"
        )

// ISINSCOPE 层级判断（自底向上）：
//   keyword_name 明细行：全部 4 个 ISINSCOPE = TRUE
//   channel 行：__IsCategory + __IsKWType + __IsChannel = TRUE
//   keyword_type 行：__IsCategory + __IsKWType = TRUE
//   category 行：仅 __IsCategory = TRUE
//   总计行：全部 = FALSE
//   SWITCH 从最深层级开始判断（自底向上），保证匹配到最具体层级

