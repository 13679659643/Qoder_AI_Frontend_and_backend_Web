3.1 公共筛选逻辑说明
────────────────────

所有度量值共享相同的筛选变量模式：

// ── 复用切片器（单选）──
VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

// ── 切片器值（提前变量化，集中管理字段引用）──
VAR __SuperSeasonVals = VALUES(Dim_Crowd_Season_C_Label[Super Season])
VAR __CategoryVals = VALUES(Dim_Crowd_Season_C_Label[Category])
VAR __LabelVals = VALUES(Dim_Crowd_Season_C_Label[Label])

// ── Platform FILTER 块（提前变量化，4 个双 CALCULATE 度量值复用）──
VAR __PlatformFilter =
    FILTER(
        ALL(a05_e2e_paid_media_keyword_data_d[platform]),
        IF(__ChannelID = "ALL",
            a05_e2e_paid_media_keyword_data_d[platform] IN {"TM", "JD"},
            a05_e2e_paid_media_keyword_data_d[platform] = __ChannelID))

// ── Platform 筛选语义 ──
// __ChannelID = "ALL" → platform IN {"TM","JD"}（精确圈定 TM+JD）
// __ChannelID = "TM"/"JD" → platform = __ChannelID（单平台精确筛选）

// ── Channel 固定数据范围筛选（SPEC：channel=直通车/引力魔方/全站推）──
// FILTER(VALUES()) 交集模式：保留行维度筛选，仅保留 channel 在 SPEC 范围内的行
// channel 同时是行维度第1级，交集模式下各行仅显示自身值
VAR __ChannelScopeFilter =
    FILTER(
        VALUES(a05_e2e_paid_media_keyword_data_d[channel]),
        a05_e2e_paid_media_keyword_data_d[channel] IN {"直通车", "引力魔方", "全站推"})

// ── 三个专属切片器 FILTER 块 ──
// FILTER(VALUES(事实表[season]),   事实表[season]   IN __SuperSeasonVals)
// FILTER(VALUES(事实表[category]), 事实表[category] IN __CategoryVals)
// FILTER(VALUES(事实表[brand]),    事实表[brand]    IN __LabelVals)

3.2 Keyword X Cost
──────────────

Keyword X Cost =
// ========================================
// 度量值: Keyword X Cost
// 中文名: 花费
// Display Folder: Keyword X
// 用途: 花费金额
// 口径: SUM(cost_amt) × ExchangeRate
// 类型: 金额类（唯一需要汇率换算的指标）
// 数据字典: cost_amt = 花费
// 数据格式: #,##0（千分位整数，带币种符号，见 Cost Display）
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")
    VAR __ExchangeRate = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)

    VAR __SuperSeasonVals = VALUES(Dim_Crowd_Season_C_Label[Super Season])
    VAR __CategoryVals = VALUES(Dim_Crowd_Season_C_Label[Category])
    VAR __LabelVals = VALUES(Dim_Crowd_Season_C_Label[Label])

    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_keyword_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_keyword_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_keyword_data_d[platform] = __ChannelID))

    VAR __ChannelScopeFilter =
        FILTER(
            VALUES(a05_e2e_paid_media_keyword_data_d[channel]),
            a05_e2e_paid_media_keyword_data_d[channel] IN {"直通车", "引力魔方", "全站推"})

    VAR __BaseValue =
        CALCULATE(
            SUM(a05_e2e_paid_media_keyword_data_d[cost_amt]),
            __PlatformFilter,
            __ChannelScopeFilter,
            a05_e2e_paid_media_keyword_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[season]),
                a05_e2e_paid_media_keyword_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[category]),
                a05_e2e_paid_media_keyword_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[brand]),
                a05_e2e_paid_media_keyword_data_d[brand] IN __LabelVals)
        )
    RETURN
        DIVIDE(__BaseValue, __ExchangeRate)

3.3 Keyword X Cost%
────────────────

Keyword X Cost% =
// ========================================
// 度量值: Keyword X Cost%
// 中文名: 花费占比
// Display Folder: Keyword X
// 用途: 每行花费占总计花费的百分比
// 口径: DIVIDE(当前行 cost_amt, 总计 cost_amt)
//       分母不受行维度（channel / brand / framework / category / season）筛选上下文影响
//       分母使用 REMOVEFILTERS 移除全部 5 个行维度 + FILTER(ALL()) 仅保留切片器筛选 + channel 固定范围
//       注意：分母不能用 FILTER(VALUES()) 因为 VALUES 在行上下文中求值后
//             会固化当前行的值，导致 REMOVEFILTERS 被抵消，Cost% 始终为 1
// 类型: 比率类，不乘汇率
// 数据字典: cost_amt = 花费
// 数据格式: #,##0.0%;#,##0.0%;0.0%（见 Cost% Display）
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    VAR __SuperSeasonVals = VALUES(Dim_Crowd_Season_C_Label[Super Season])
    VAR __CategoryVals = VALUES(Dim_Crowd_Season_C_Label[Category])
    VAR __LabelVals = VALUES(Dim_Crowd_Season_C_Label[Label])

    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_keyword_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_keyword_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_keyword_data_d[platform] = __ChannelID))

    VAR __CostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_keyword_data_d[cost_amt]),
            __PlatformFilter,
            // ── Channel 固定范围（分子用 FILTER(VALUES()) 交集模式，保留行维度）──
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[channel]),
                a05_e2e_paid_media_keyword_data_d[channel] IN {"直通车", "引力魔方", "全站推"}),
            a05_e2e_paid_media_keyword_data_d[trans_cycle] = __TransCycle,
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[season]),
                a05_e2e_paid_media_keyword_data_d[season] IN __SuperSeasonVals),
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[category]),
                a05_e2e_paid_media_keyword_data_d[category] IN __CategoryVals),
            FILTER(VALUES(a05_e2e_paid_media_keyword_data_d[brand]),
                a05_e2e_paid_media_keyword_data_d[brand] IN __LabelVals)
        )

    VAR __TotalCostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_keyword_data_d[cost_amt]),
            // ── 移除全部 5 个行维度筛选（channel / brand / framework / category / season）──
            REMOVEFILTERS(a05_e2e_paid_media_keyword_data_d[channel]),
            REMOVEFILTERS(a05_e2e_paid_media_keyword_data_d[brand]),
            REMOVEFILTERS(a05_e2e_paid_media_keyword_data_d[framework]),
            REMOVEFILTERS(a05_e2e_paid_media_keyword_data_d[category]),
            REMOVEFILTERS(a05_e2e_paid_media_keyword_data_d[season]),
            __PlatformFilter,
            a05_e2e_paid_media_keyword_data_d[trans_cycle] = __TransCycle,
            // ── Channel 固定范围（分母用 FILTER(ALL()) 仅保留范围筛选，不依赖行维度）──
            FILTER(ALL(a05_e2e_paid_media_keyword_data_d[channel]),
                a05_e2e_paid_media_keyword_data_d[channel] IN {"直通车", "引力魔方", "全站推"}),
            // ── 分母用 FILTER(ALL()) 仅保留切片器筛选（不用 FILTER(VALUES())）──
            FILTER(ALL(a05_e2e_paid_media_keyword_data_d[season]),
                a05_e2e_paid_media_keyword_data_d[season] IN __SuperSeasonVals),
            FILTER(ALL(a05_e2e_paid_media_keyword_data_d[category]),
                a05_e2e_paid_media_keyword_data_d[category] IN __CategoryVals),
            FILTER(ALL(a05_e2e_paid_media_keyword_data_d[brand]),
                a05_e2e_paid_media_keyword_data_d[brand] IN __LabelVals)
        )

    RETURN
        DIVIDE(__CostAmt, __TotalCostAmt)

