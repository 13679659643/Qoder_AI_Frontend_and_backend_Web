Keyword X Cell Font Color =
// ========================================
// 度量值: Keyword X Cell Font Color
// 中文名: 关键词单元格字体颜色
// Display Folder: Keyword X > Formatting
// 用途: 根据矩阵视觉层级返回字体颜色
//       用于条件格式 → 字体颜色
// 矩阵结构: 行维度 = channel -> brand -> framework -> category -> season (五级)
// 颜色规则:
//   - 总计行 (Grand Total) -> #252423 (近黑，强调)
//   - 所有小计行和明细行     -> #5F6165 (深灰)
// ========================================
    VAR __IsSeason = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[season])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[category])
    VAR __IsFramework = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[framework])
    VAR __IsBrand = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[brand])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_keyword_data_d[channel])

    RETURN
        SWITCH(
            TRUE(),
            NOT(__IsChannel) && NOT(__IsBrand) && NOT(__IsFramework) && NOT(__IsCategory) && NOT(__IsSeason),
                "#252423",
            "#5F6165"
        )

