-- ████████████████████████████████████████████████████████████████████████████████
-- PART 4: Cost% 分母验证 — 确认 REMOVEFILTERS + FILTER(ALL()) 语义
-- ████████████████████████████████████████████████████████████████████████████████
-- DAX 中 Cost% 分母使用 REMOVEFILTERS(channel, brand, framework, category, customer_type)
-- + FILTER(ALL()) 仅保留切片器筛选
-- 这意味着分母 = 全量聚合（忽略全部 5 个行维度），仅保留切片器筛选
-- SQL 中等价于：不 GROUP BY 任何行维度的全表聚合

-- 4.1 验证分母一致性 — 总计 Cost（切片器全选时）
-- 预期：此值 = PART 1.1 的 Cost_RMB = PART 2/3 中所有 Cost_Pct 的分母
SELECT
    'Cost%分母_全选'                        AS check_item,
    SUM(cost_amt)                           AS denominator_cost,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 4.2 验证分母一致性 — 单平台 TM 时
-- 预期：此值 = PART 2.2 的 Cost_RMB
SELECT
    'Cost%分母_TM'                          AS check_item,
    SUM(cost_amt)                           AS denominator_cost,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'TM'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 4.3 验证分母一致性 — 单平台 JD 时
-- 预期：此值 = PART 2.3 的 Cost_RMB
SELECT
    'Cost%分母_JD'                          AS check_item,
    SUM(cost_amt)                           AS denominator_cost,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'JD'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 4.4 Cost% 加和校验 — 所有 channel + brand 明细行 Cost% 之和应为 1.0
WITH
total_cost AS (
    SELECT SUM(cost_amt) AS cost
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
),
detail AS (
    SELECT
        channel,
        brand,
        SUM(cost_amt)                           AS row_cost,
        SUM(cost_amt) / NULLIF(tc.cost, 0)      AS row_cost_pct
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    CROSS JOIN total_cost tc
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
    GROUP BY channel, brand, tc.cost
)
SELECT
    'Cost%加和校验'                          AS check_item,
    SUM(row_cost_pct)                        AS sum_cost_pct,
    SUM(row_cost)                            AS sum_cost,
    MAX(tc.cost)                             AS total_cost,
    CASE
        WHEN ABS(SUM(row_cost_pct) - 1.0) < 0.0001 THEN 'PASS (≈100%)'
        ELSE 'FAIL (≠100%)'
    END                                      AS check_result
FROM detail
CROSS JOIN total_cost tc;


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 5: 专属切片器筛选模拟 — 模拟特定 Season / Category / Label 选择
-- ████████████████████████████████████████████████████████████████████████████████
-- DAX 中三个专属切片器使用 FILTER(VALUES()) 交集模式：
--   FILTER(VALUES(season),   season   IN VALUES(Season))
--   FILTER(VALUES(category), category IN VALUES(Category))
--   FILTER(VALUES(brand),    brand    IN VALUES(Label))
-- 全选时：交集 = 行维度值 → 等价于不筛选
-- 部分选：交集 = 行维度值 ∩ 选中值 → 仅保留选中行
-- SQL 中等价于：WHERE season IN (...) AND category IN (...) AND brand IN (...)

-- 5.0 先查看当前可用的维度值（辅助确定筛选条件）
SELECT DISTINCT season AS `Season`
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
ORDER BY season;

SELECT DISTINCT category AS `Category`
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
ORDER BY category;

SELECT DISTINCT brand AS `Label`
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
ORDER BY brand;


-- 5.1 模拟 Season 筛选 — 选择某一个 season 值
