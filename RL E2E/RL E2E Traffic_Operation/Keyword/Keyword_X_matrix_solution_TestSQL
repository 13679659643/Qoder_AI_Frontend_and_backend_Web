-- ████████████████████████████████████████████████████████████████████████████████
-- PART 7: 汇率转换验证（可选 — 验证 USD 展示值）
-- ████████████████████████████████████████████████████████████████████████████████
-- Power BI 选择 USD 时：Cost × 汇率乘数（Slicer_Currency_Selection[Currency_ExchangeRate]）
-- Cost% 不受汇率影响（分子分母同乘汇率后约掉）

-- 7.1 全平台 Cost — USD（假设汇率乘数 = 7，以实际 Slicer_Currency_Selection 配置为准）
SELECT
    'USD_全平台'                            AS check_item,
    SUM(cost_amt)                           AS cost_rmb,
    SUM(cost_amt) * 7                       AS cost_usd,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';
-- 注：Cost% 不受汇率影响，USD 时 Cost% 与 RMB 时完全一致


-- 7.2 按 channel + brand 的 Cost — USD
WITH
total_cost_usd AS (
    SELECT SUM(cost_amt) * 7 AS cost
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
)
SELECT
    channel,
    brand,
    SUM(cost_amt) * 7                       AS `Cost_USD`,
    (SUM(cost_amt) * 7) / NULLIF(tc.cost, 0) AS `Cost_Pct`,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
CROSS JOIN total_cost_usd tc
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY channel, brand, tc.cost
ORDER BY channel, brand;
-- 预期：Cost_USD = Cost_RMB × 7，Cost_Pct 与 RMB 时完全一致


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 8: 数据完整性检查
-- ████████████████████████████████████████████████████████████████████████████████

-- 8.1 检查日期范围是否有数据
SELECT
    'keyword_data_全平台'                   AS check_item,
    CASE WHEN COUNT(*) > 0 THEN 'OK' ELSE 'MISSING' END AS data_check,
