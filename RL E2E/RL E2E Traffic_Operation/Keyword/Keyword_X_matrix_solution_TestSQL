FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
CROSS JOIN filtered_total ft
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
  AND brand IN ('请替换为实际brand值')  -- ← 同上
GROUP BY channel, brand, ft.cost
ORDER BY channel, brand;


-- 5.4 模拟组合筛选 — Season + Category + Label 同时选择
-- 三个切片器同时筛选时，DAX 中三个 FILTER(VALUES()) 取交集
-- SQL 中等价于三个 WHERE 条件 AND
WITH
filtered_total AS (
    SELECT SUM(cost_amt) AS cost
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
      AND season   IN ('请替换为实际season值')        -- ← Season
      AND category IN ('请替换为实际category值')       -- ← Category
      AND brand    IN ('请替换为实际brand值')          -- ← Label
)
SELECT
    channel,
    brand,
    SUM(cost_amt)                           AS `Cost_RMB`,
    SUM(cost_amt) / NULLIF(ft.cost, 0)      AS `Cost_Pct`,
    COUNT(*)                                AS row_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
CROSS JOIN filtered_total ft
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
  AND season   IN ('请替换为实际season值')        -- ← Season
  AND category IN ('请替换为实际category值')       -- ← Category
  AND brand    IN ('请替换为实际brand值')          -- ← Label
GROUP BY channel, brand, ft.cost
ORDER BY channel, brand;
-- 预期：仅返回同时满足三个条件的行，Cost_Pct 之和 = 1.0


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 6: 日期粒度明细 — 按日展开验证（排查聚合差异时使用）
-- ████████████████████████████████████████████████████████████████████████████████
-- 如果 Power BI 总值与 SQL 不一致，通过日粒度对比定位差异日期

-- 6.1 按日聚合 Cost（全平台）
SELECT
    data_date,
    SUM(cost_amt)              AS cost,
    COUNT(*)                   AS row_cnt,
    COUNT(DISTINCT platform)   AS platform_cnt,
    COUNT(DISTINCT channel)    AS channel_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY data_date
ORDER BY data_date;


-- 6.2 按日 + 平台聚合 Cost
SELECT
    data_date,
    platform,
    SUM(cost_amt)              AS cost,
    COUNT(*)                   AS row_cnt,
    COUNT(DISTINCT channel)    AS channel_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY data_date, platform
