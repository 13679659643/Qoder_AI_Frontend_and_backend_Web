-- ================================================================================
-- Keyword X Matrix — 数据验证测试 SQL
-- ================================================================================
--
-- 用途：在火山引擎 ByteHouse / MySQL 中执行，验证数据库数据与 Power BI Keyword X 表一致性
-- 对标：Keyword_X_matrix_solution 中 Keyword X Cost / Keyword X Cost% 的 DAX 计算口径
-- 数据库：indep_rl_ads
-- 事实表：a05_e2e_paid_media_keyword_data_d（关键词粒度）
--
-- 使用说明：
--   1. 修改下方 ★参数区★ 中的日期范围、平台、数据口径、关键词筛选条件
--   2. 将参数值替换到各查询中对应的占位处
--   3. 逐段执行，将结果与 Power BI Table 中对应行/列比对
--   4. 本文件所有金额为 RMB 原始值（不含汇率转换）
--      Power BI 选择 RMB 时应与此一致；选择 USD 时 Cost = 此值 × 汇率乘数
--
-- ★参数区★（修改这里的值来匹配 Power BI 切片器选择）：
--   日期范围：     '2026-01-01' ~ '2026-06-17'
--   平台：         'ALL'（代表 TM + JD 精确聚合）
--   数据口径：     'T+1'
--   Season：        全选（不施加 season 筛选）
--   Category：      全选（不施加 category 筛选）
--   Label：         全选（不施加 brand 筛选）
--
-- DAX 筛选逻辑摘要：
--   Cost    = SUM(cost_amt) × ExchangeRate
--             FILTER(VALUES()) 交集模式（保留行维度）
--   Cost%   = DIVIDE(当前行 cost_amt, 总计 cost_amt)
--             分子：FILTER(VALUES()) 交集模式（保留行维度）
--             分母：REMOVEFILTERS(channel, brand, framework, category, customer_type)
--                   + FILTER(ALL()) 仅保留切片器
--
-- Table 视觉对象行维度：
--   一级行头：channel（广告点位）
--   二级行头：brand（品牌名称）
--   三级行头：framework
--   四级行头：category
--   五级行头：customer_type（客户类型）
--   总计行：所有行聚合
-- ================================================================================


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 0: 数据探查 — 确认表结构与数据可用性
-- ████████████████████████████████████████████████████████████████████████████████

-- 0.1 检查事实表可用的平台和数据口径
SELECT
    platform,
    trans_cycle,
    COUNT(*)                        AS row_cnt,
    COUNT(DISTINCT data_date)       AS date_cnt,
    MIN(data_date)                  AS min_date,
    MAX(data_date)                  AS max_date
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
GROUP BY platform, trans_cycle
ORDER BY platform, trans_cycle;


-- 0.2 检查切片器维度字段值分布（season / category / brand）
-- 说明：这三个字段对应 Power BI 三个专属切片器
--       Season   ← season
--       Category ← category
--       Label    ← brand
SELECT
    season,
    category,
    brand,
    COUNT(*)        AS row_cnt,
    SUM(cost_amt)   AS total_cost
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY season, category, brand
ORDER BY season, category, brand;


-- 0.3 检查 channel 字段值分布（一级行头维度）
SELECT
    channel,
    COUNT(*)                            AS row_cnt,
    COUNT(DISTINCT brand)               AS brand_cnt,
    SUM(cost_amt)                       AS total_cost
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY channel
ORDER BY channel;


-- 0.4 检查 NULL 值分布（可能导致聚合差异）
SELECT
    SUM(CASE WHEN cost_amt IS NULL THEN 1 ELSE 0 END)          AS null_cost_amt,
    SUM(CASE WHEN click IS NULL THEN 1 ELSE 0 END)             AS null_click,
    SUM(CASE WHEN pv IS NULL THEN 1 ELSE 0 END)                AS null_pv,
    SUM(CASE WHEN add_cart_cnt IS NULL THEN 1 ELSE 0 END)      AS null_add_cart,
    SUM(CASE WHEN sales_order_cnt IS NULL THEN 1 ELSE 0 END)   AS null_orders,
    SUM(CASE WHEN brand IS NULL THEN 1 ELSE 0 END)             AS null_brand,
    SUM(CASE WHEN framework IS NULL THEN 1 ELSE 0 END)         AS null_framework,
    SUM(CASE WHEN category IS NULL THEN 1 ELSE 0 END)          AS null_category,
    SUM(CASE WHEN customer_type IS NULL THEN 1 ELSE 0 END)     AS null_customer_type,
    SUM(CASE WHEN currency IS NULL THEN 1 ELSE 0 END)          AS null_currency,
    COUNT(*)                                                    AS total_rows
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 0.5 检查 currency 字段值分布（影响 Power BI 中 IF(currency is null, 'RMB', currency) 逻辑）
SELECT
    IF(currency IS NULL, 'RMB', currency)   AS currency_display,
    COUNT(*)                                 AS row_cnt,
    SUM(cost_amt)                            AS total_cost
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY IF(currency IS NULL, 'RMB', currency);


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 1: 总计行验证 — Cost & Cost%（对标 Power BI Table 总计行）
-- ████████████████████████████████████████████████████████████████████████████████
-- 对应 Power BI: Table 最底部的总计行
-- DAX 行为：
--   Cost  = SUM(cost_amt) × ExchangeRate（全量聚合，无行维度限制）
--   Cost% = DIVIDE(总计cost, 总计cost) = 1.0（即 100%）

-- 1.1 总计行 Cost（Platform = ALL → TM + JD）
-- DAX 口径：
--   CALCULATE(SUM(cost_amt),
--     FILTER(ALL(platform), platform IN {"TM","JD"}),
--     trans_cycle = "T+1",
--     FILTER(VALUES(season),   season   IN 切片器值),   -- 全选时 = 全部
--     FILTER(VALUES(category), category IN 切片器值),   -- 全选时 = 全部
--     FILTER(VALUES(brand),    brand    IN 切片器值))   -- 全选时 = 全部
SELECT
    '总计行'                              AS row_type,
    SUM(cost_amt)                         AS `Cost_RMB`,
    SUM(cost_amt)                         AS `Cost_USD_待乘汇率`,
    1.0                                   AS `Cost_Pct`,
    COUNT(*)                              AS row_cnt,
    COUNT(DISTINCT platform)              AS platform_cnt,
    COUNT(DISTINCT channel)               AS channel_cnt,
    COUNT(DISTINCT brand)                 AS brand_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';
-- 预期：Cost_Pct = 1.0（100%），总计行分子 = 分母


-- 1.2 总计行 Cost — 按平台分别验证（排查平台聚合差异）
SELECT
    platform,
    SUM(cost_amt)                         AS `Cost_RMB`,
    COUNT(*)                              AS row_cnt,
    COUNT(DISTINCT channel)               AS channel_cnt,
    COUNT(DISTINCT data_date)             AS date_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY platform
ORDER BY platform;


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 2: channel 行（一级行头）验证 — Cost & Cost%
-- ████████████████████████████████████████████████████████████████████████████████
-- 对应 Power BI: Table 中 channel 级别的行
-- DAX 行为：
--   Cost  = SUM(cost_amt) WHERE channel = 当前行值（行维度筛选）
--   Cost% = DIVIDE(channel行Cost, 总计Cost)
--          分母 REMOVEFILTERS(channel, brand, framework, category, customer_type)

-- 2.1 按 channel 聚合 Cost + Cost%
WITH
-- ── 总计 Cost（分母，等价于 PART 1.1 的结果）──
total_cost AS (
    SELECT SUM(cost_amt) AS cost
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
)
-- ── 按 channel 聚合 ──
SELECT
    channel,
    SUM(cost_amt)                           AS `Cost_RMB`,
    SUM(cost_amt) / NULLIF(tc.cost, 0)      AS `Cost_Pct`,
    COUNT(*)                                AS row_cnt,
    COUNT(DISTINCT brand)                   AS brand_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
CROSS JOIN total_cost tc
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY channel, tc.cost
ORDER BY channel;
-- 预期：各 channel Cost_Pct 之和 = 1.0


-- 2.2 按 channel 验证 — 单平台 TM（对标 Power BI Platform 切片器选 TM）
-- DAX 口径：
--   __ChannelID = "TM" → FILTER(ALL(platform), platform = "TM")
SELECT
    channel,
    SUM(cost_amt)                           AS `Cost_RMB`,
    COUNT(*)                                AS row_cnt,
    COUNT(DISTINCT brand)                   AS brand_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'TM'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY channel;


-- 2.3 按 channel 验证 — 单平台 JD（对标 Power BI Platform 切片器选 JD）
SELECT
    channel,
    SUM(cost_amt)                           AS `Cost_RMB`,
    COUNT(*)                                AS row_cnt,
    COUNT(DISTINCT brand)                   AS brand_cnt
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'JD'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'
GROUP BY channel;


-- ████████████████████████████████████████████████████████████████████████████████
-- PART 3: channel + brand 行（二级明细行）验证 — Cost & Cost%
-- ████████████████████████████████████████████████████████████████████████████████
-- 对应 Power BI: Table 中 channel 展开后的 brand 明细行
-- DAX 行为：
--   Cost  = SUM(cost_amt) WHERE channel = 当前行 AND brand = 当前行值
--   Cost% = DIVIDE(明细行Cost, 总计Cost)
--          分母 REMOVEFILTERS 全部 5 个行维度，保留切片器筛选

