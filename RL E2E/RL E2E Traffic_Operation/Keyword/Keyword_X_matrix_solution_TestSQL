FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'

UNION ALL

SELECT
    'keyword_data_TM'                       AS check_item,
    CASE WHEN COUNT(*) > 0 THEN 'OK' ELSE 'MISSING' END AS data_check,
    COUNT(DISTINCT data_date)               AS date_count,
    1                                       AS platform_count,
    COUNT(*)                                AS row_count
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'TM'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17'

UNION ALL

SELECT
    'keyword_data_JD'                       AS check_item,
    CASE WHEN COUNT(*) > 0 THEN 'OK' ELSE 'MISSING' END AS data_check,
    COUNT(DISTINCT data_date)               AS date_count,
    1                                       AS platform_count,
    COUNT(*)                                AS row_count
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform = 'JD'
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 8.2 检查 trans_cycle 字段可用值
SELECT
    trans_cycle,
    COUNT(*)                                AS row_cnt,
    MIN(data_date)                          AS min_date,
    MAX(data_date)                          AS max_date
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
GROUP BY trans_cycle
ORDER BY trans_cycle;


-- 8.3 检查 cost_amt = 0 或 NULL 的行占比（可能导致 Cost% 偏差）
SELECT
    SUM(CASE WHEN cost_amt = 0 THEN 1 ELSE 0 END)             AS zero_cost_rows,
    SUM(CASE WHEN cost_amt IS NULL THEN 1 ELSE 0 END)         AS null_cost_rows,
    SUM(CASE WHEN cost_amt > 0 THEN 1 ELSE 0 END)             AS positive_cost_rows,
    SUM(CASE WHEN cost_amt < 0 THEN 1 ELSE 0 END)             AS negative_cost_rows,
    COUNT(*)                                                    AS total_rows,
    ROUND(SUM(CASE WHEN cost_amt = 0 OR cost_amt IS NULL THEN 1 ELSE 0 END)
        * 100.0 / COUNT(*), 2)                                AS zero_or_null_pct
FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
WHERE platform IN ('TM', 'JD')
  AND trans_cycle = 'T+1'
  AND data_date >= '2026-01-01'
  AND data_date <= '2026-06-17';


-- 8.4 Cost 一致性交叉校验 — PART 1 总计 vs PART 2 channel 之和 vs PART 3 明细之和
WITH
-- 总计
total AS (
    SELECT SUM(cost_amt) AS cost
    FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
    WHERE platform IN ('TM', 'JD')
      AND trans_cycle = 'T+1'
      AND data_date >= '2026-01-01'
      AND data_date <= '2026-06-17'
),
-- 按 channel 之和
by_channel AS (
    SELECT SUM(cost_amt) AS cost
    FROM (
        SELECT channel, SUM(cost_amt) AS cost_amt
        FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
        WHERE platform IN ('TM', 'JD')
          AND trans_cycle = 'T+1'
          AND data_date >= '2026-01-01'
          AND data_date <= '2026-06-17'
        GROUP BY channel
    ) sub
),
-- 按 channel + brand 之和
by_detail AS (
    SELECT SUM(cost_amt) AS cost
    FROM (
        SELECT channel, brand, SUM(cost_amt) AS cost_amt
        FROM indep_rl_ads.a05_e2e_paid_media_keyword_data_d
        WHERE platform IN ('TM', 'JD')
          AND trans_cycle = 'T+1'
          AND data_date >= '2026-01-01'
          AND data_date <= '2026-06-17'
        GROUP BY channel, brand
    ) sub
)
SELECT
    t.cost                                  AS `total_cost`,
    c.cost                                  AS `channel_sum_cost`,
    d.cost                                  AS `detail_sum_cost`,
    CASE WHEN t.cost = c.cost AND c.cost = d.cost
         THEN 'PASS (三层一致)'
         ELSE 'FAIL (存在差异)'
    END                                     AS check_result
FROM total t, by_channel c, by_detail d;


-- ================================================================================
-- 比对方法说明
-- ================================================================================
--
-- 1. 在 Power BI 中设置切片器：
--    日期范围 = 2026-01-01 ~ 2026-06-17
--    Channel = ALL，数据口径 = T+1，币种 = RMB
--    Season / Category / Label = 全选
--
-- 2. 验证 Cost：
--    a) 执行 PART 1.1 → 比对 Power BI Table 总计行的 Cost 值
--    b) 执行 PART 2.1 → 比对 Power BI Table 中 channel 行的 Cost 值
--    c) 执行 PART 3.1 → 比对 Power BI Table 中 brand 明细行的 Cost 值
--    d) 切换 Platform = TM → 执行 PART 2.2 + PART 3.2 比对
--    e) 切换 Platform = JD → 执行 PART 2.3 + PART 3.3 比对
--
-- 3. 验证 Cost%：
--    a) 总计行 Cost% 应 = 100%
--    b) 执行 PART 2.1 / 3.1 → 比对 channel 行 / 明细行的 Cost%
--    c) 所有明细行 Cost% 之和应 = 100%（PART 4.4 自动校验）
--    d) 切换 Platform 后，Cost% 分母变为当前平台的总计（PART 4.2 / 4.3）
--
-- 4. 验证切片器筛选：
--    a) 在 Power BI 中选中特定 Season → 执行 PART 5.1 比对
--    b) 在 Power BI 中选中特定 Category → 执行 PART 5.2 比对
--    c) 在 Power BI 中选中特定 Label → 执行 PART 5.3 比对
--    d) 组合筛选 → 执行 PART 5.4 比对
--
-- 5. 如有差异，执行 PART 6 按日展开定位差异日期
--    执行 PART 8 检查数据完整性
--
-- 6. 验证 USD 时，执行 PART 7 → 比对 Power BI 币种切换为 USD 后的值
--    Cost 应 = RMB × 汇率乘数，Cost% 应不变
--
-- 7. 常见差异原因：
--    a) currency 字段：Power BI SQL 加载时使用 IF(currency is null, 'RMB', currency)
--       如数据库中存在非 RMB 的 currency 值，可能影响结果
--    b) NULL 处理：DAX SUM 忽略 NULL，SQL SUM 同样忽略 NULL
--       但 DIVIDE(x, 0) 在 DAX 返回 BLANK，SQL 中用 NULLIF 模拟
--    c) 日期边界：确认 Power BI 日期切片器选择的是闭区间（>= AND <=）
--    d) 浮点精度：比率类指标小数位可能有微小差异，属正常
--    e) FILTER(VALUES()) 交集模式：SQL 中用 WHERE IN 等价
--       但 DAX 中 VALUES 会先读取当前行维度值再取交集，SQL 无此语义差异
--       因为 SQL 的 GROUP BY + WHERE IN 天然实现了交集
--    f) Cost% 分母：分母始终为当前切片器条件下的总计 Cost
--       不受 channel / brand / framework / category / customer_type 行维度影响（REMOVEFILTERS）
--       如 Cost% 异常，先检查分母（PART 4）是否正确
--    g) 专属切片器级联：Power BI 中三个切片器基于同一张表
--       选 Season 后 Category / Label 自动过滤显示可选值
--       SQL 中需手动指定筛选值（PART 5 的占位符需替换为实际值）
-- ================================================================================
