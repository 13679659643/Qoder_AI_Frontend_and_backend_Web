5.1 本期指标 SWITCH 分发 — Media Mix Base Value
────────────────────────────────────────────────

Media Mix Base Value = 
// ========================================
// 度量值: Media Mix Base Value (v1.7)
// Display Folder: Media Mix
// 用途: 纯指标 SWITCH 分发器，13 列指标统一聚合分发
//
// 架构修订（v1.7 — 2026-06-01）：
//   1. [致命修复] 不再使用 FILTER(ALL(事实表), ...)，改用 CALCULATE + 列级条件
//      原因：ALL(事实表) 会把通过 Dim_Date_Current 关系传递的 data_date 筛选
//            一并清空，导致用户切换日期切片器无效，且 Cell Value 层 LP 日期
//            覆盖失效（Last Year ≡ This Year，YOY ≡ 0）
//      修复：列级筛选不影响关系传递，data_date 由 Dim_Date_Current 自然控制
//
//   2. [设计加固] CONTAINSSTRING 边界包裹（防子串误匹配）
//      "|" & __SummaryScope & "|" 包含 "|" & Channel_ID & "|"
//      避免 Channel_ID="TM_Z" 误命中 Summary_Scope="TM_ZTC|TM_YLMF"
//
//   3. [架构精简] DETAIL / SUMMARY 路径合并为统一 channel IN __Labels
//      DETAIL 行 Summary_Scope = 自身 Channel_ID → __Labels = {自身 Channel}（单元素）
//      SUMMARY 行 Summary_Scope = 底层 DETAIL 枚举 → __Labels = {多个 Channel}（多元素）
//      13 个指标的 CALCULATE 共用此 __Labels，代码量减半
//
//   4. [关联字段规范] __Labels 取 Channel 字段（原始渠道名）而非 Channel_Label（展示标签）
//      Channel_Label 用于页面展示，可能含全角空格等后缀（如 JD 去重处理）
//      Channel 与事实表 [channel] 字段保持一致，是正确的关联/筛选字段
//
// Platform 获取方式：
//   __RowPlatform = SELECTEDVALUE(Dim_Media_Mix_Channel[Platform])
//   由矩阵行上下文自然传入；无需读取外部切片器，无需 ALL/单平台分支判断
//
// Cost% 口径（v2.0 — 2026-07-02 修订）：
//   DETAIL 行分母 = 所属上级 SUMMARY 的 cost（如 直通车/RTB Total）
//   SUMMARY 行分母 = 最大汇总行 Total 的 cost（始终为全局汇总）
//   DETAIL 行通过 Parent_Channel_ID → __ParentScope → __ParentLabels 链路获取
//   SUMMARY 行通过 ALL(Dim_Media_Mix_Channel) 获取全平台 DETAIL → __GrandTotalLabels
//   Total 行 Cost% = 100%（分母 = 自身）
//
// 依赖: DIM_ColMetric_Media_Mix[Metric_ID]
//       Dim_Media_Mix_Channel[Channel_ID/Channel_Type/Channel/Summary_Scope/Parent_Channel_ID/Platform]
//       Slicer_DataCaliber_Selection[DataCaliber_ID]
//       a05_e2e_paid_media_channel_data_d
//       Dim_Date_Current（关系传递 data_date 筛选，本度量值不直接引用）
// ========================================

        // ── 列上下文 ──
    VAR __MetricID      = SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_ID])

    // ── 行上下文（来自 Dim_Media_Mix_Channel 断开维度）──
    VAR __SummaryScope  = SELECTEDVALUE(Dim_Media_Mix_Channel[Summary_Scope], "")
    VAR __RowPlatform   = SELECTEDVALUE(Dim_Media_Mix_Channel[Platform])

    // ── 数据口径上下文 ──
    VAR __TransCycle    = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ══════════════════════════════════════════════════════════════════
    // 第一部分：分子 — 当前行需聚合的 DETAIL Channel 名称集合
    // ══════════════════════════════════════════════════════════════════
    //
    // 作用：确定当前矩阵行的 Cost/Click/GMV 等所有指标聚合哪些 DETAIL 行数据。
    //
    // 原理：
    //   Dim_Media_Mix_Channel 每行有一个 Summary_Scope 字段（| 分隔的 Channel_ID 列表），
    //   表示"该行聚合哪些 DETAIL 行"。
    //     - DETAIL 行：Summary_Scope = 自身 Channel_ID（如 "TM_ZTC"）
    //     - SUMMARY 行：Summary_Scope = 底层所有 DETAIL 的 | 拼接
    //       （如 RTB Total = "TM_ZTC|TM_YLMF|TM_QZT|TM_DSP"）
    //
    // 示例（TM 平台）：
    //   矩阵行 = "直通车"（DETAIL）→ __Labels = {"直通车"}（单元素）
    //   矩阵行 = "RTB Total"（SUMMARY）→ __Labels = {"直通车","引力魔方","全站推/万象台","超级短视频"}
    //   矩阵行 = "Total"（SUMMARY）→ __Labels = 全部 6 个 DETAIL 渠道名
    //
    // ⚠️ ALL(Dim_Media_Mix_Channel)：清除外部行筛选上下文，
    //    否则在矩阵渲染时 Dim_Media_Mix_Channel 已被行上下文筛选，
    //    导致 SUMMARY 行只能看到自己，无法展开为多个 DETAIL。
    //
    VAR __ScopedSummary = "|" & __SummaryScope & "|"
    VAR __Labels =
        SELECTCOLUMNS(
            FILTER(
                ALL(Dim_Media_Mix_Channel),
                // 只取 DETAIL 行（SUMMARY 行的聚合结果就是这些 DETAIL 的合集）
                Dim_Media_Mix_Channel[Channel_Type] = "DETAIL"
                    // 同平台内操作（TM 的 Total 只聚合 TM 的 DETAIL，不会跨到 JD）
                    && Dim_Media_Mix_Channel[Platform] = __RowPlatform
                    // ⚠️ 边界保护：用 | 包裹后精确匹配，防止子串误命中
                    // 例如 Channel_ID="TM_Z" 不应命中 Summary_Scope="TM_ZTC|TM_YLMF"
                    // 加了 | 包裹后："|TM_ZTC|TM_YLMF|" CONTAINS "|TM_Z|" → FALSE ✓
                    && CONTAINSSTRING(
                           __ScopedSummary,
                           "|" & Dim_Media_Mix_Channel[Channel_ID] & "|"
                       )
            ),
            // 返回 Channel（原始渠道名，与事实表 [channel] 字段值一致）
            // ⚠️ 不能用 Channel_Label（展示标签，可能有重名/全角空格后缀），否则关联事实表失败
            // ⚠️ 列别名必须与事实表字段名完全一致（"channel"），否则 IN 运算符会报列名不匹配
            "channel", Dim_Media_Mix_Channel[Channel]
        )

    // ══════════════════════════════════════════════════════════════════
    // 第二部分：Cost% 分母路由（v2.0 — 2026-07-02）
    // ══════════════════════════════════════════════════════════════════
    //
    // Cost% 口径：当前行 Cost / 分母 Cost
    //   分母根据行类型不同而不同（三路路由）：
    //
    //   ┌─────────────────┬───────────────────────────────────────┬────────────┐
    //   │ 行类型           │ 分母                                   │ 示例（TM） │
    //   ├─────────────────┼───────────────────────────────────────┼────────────┤
    //   │ DETAIL 行        │ 所属上级 SUMMARY 的 Cost              │ 直通车/RTB Total│
    //   │ SUMMARY 行       │ 最大汇总行 Total 的 Cost（非自身!）    │ 直通车+.../Total │
    //   │ Total 行         │ 自身 Cost → Cost% = 100%              │ Total/Total  │
    //   └─────────────────┴───────────────────────────────────────┴────────────┘
    //
    // 设计意图：
    //   - DETAIL 行看"我在上级分组中的占比"（如直通车占 RTB Total 的百分比）
    //   - SUMMARY 行看"我在全平台的占比"（如 RTB Total 占 Total 的百分比）
    //     → 这就是与 v1.8 的关键差异：v1.8 的 SUMMARY 行分母=自身（恒为100%），
    //       v2.0 改为分母=Total（显示其在全平台中的真实占比）
    //   - Total 行自身 = 100%（基准线）
    //
    // 技术实现：
    //   分母 = CALCULATE(SUM(cost_amt), channel IN __CostDenominatorLabels, ...)
    //   所以核心是构造 __CostDenominatorLabels（一组 DETAIL 渠道名列表），
    //   不同行类型指向不同的 DETAIL 集合 → 聚合出不同的分母 Cost 值。
    //

    // ── 2.1 读取当前行类型和父级信息 ──
    //
    // __ChannelType: 当前行是 "DETAIL" 还是 "SUMMARY"
    //   → 决定走哪条分母路由
    VAR __ChannelType = SELECTEDVALUE(Dim_Media_Mix_Channel[Channel_Type])
    //
    // __ParentID: 当前行的父级 Channel_ID
    //   来自 Dim_Media_Mix_Channel SQL 中的 Parent_Channel_ID 字段：
    //     DETAIL 行 → 所属最近上级 SUMMARY（如 TM_ZTC → TM_RTB_TOTAL）
    //     SUMMARY 行 → 自身 Channel_ID（如 TM_RTB_TOTAL → TM_RTB_TOTAL）
    //   → 用于查找父级 SUMMARY 行的 Summary_Scope
    VAR __ParentID = SELECTEDVALUE(Dim_Media_Mix_Channel[Parent_Channel_ID])

    // ── 2.2 构造 DETAIL 行分母：__ParentLabels ──
    //
    // 目标：获取"当前行所属上级 SUMMARY"对应的全部 DETAIL Channel 名称
    //
    // 链路：
    //   __ParentID（如 "TM_RTB_TOTAL"）
    //     → 查 Dim_Media_Mix_Channel 找到该 Channel_ID 的 Summary_Scope
    //       （如 "TM_ZTC|TM_YLMF|TM_QZT|TM_DSP"）
    //         → 展开为 DETAIL Channel 名称列表 {"直通车","引力魔方","全站推/万象台","超级短视频"}
    //           → 聚合这些 Channel 的 cost → 上级 SUMMARY 的 Cost 值
    //
    // 示例（TM 平台）：
    //   矩阵行 = "直通车"（DETAIL）
    //     → __ParentID = "TM_RTB_TOTAL"
    //     → __ParentScope = "TM_ZTC|TM_YLMF|TM_QZT|TM_DSP"
    //     → __ParentLabels = {"直通车","引力魔方","全站推/万象台","超级短视频"}
    //     → Cost% = 直通车 Cost / (直通车+引力魔方+全站推+超级短视频) Cost
    //
    //   矩阵行 = "品销宝 Total"（SUMMARY）
    //     → __ParentID = "TM_JCGP_TOTAL"
    //     → __ParentScope = "TM_PPZQ|TM_PPTX"
    //     → __ParentLabels = {"品牌专区","品牌特秀"}
    //     → Cost% = 品销宝 Cost / (品牌专区+品牌特秀) Cost
    //
    VAR __ParentScope =
        CALCULATE(
            SELECTEDVALUE(Dim_Media_Mix_Channel[Summary_Scope]),
            FILTER(
                ALL(Dim_Media_Mix_Channel),
                // 在维度表中查找 ParentID 对应行的 Summary_Scope
                // ⚠️ 必须用 ALL 清除行上下文，否则只能看到当前行的 Summary_Scope
                Dim_Media_Mix_Channel[Channel_ID] = __ParentID
                    && Dim_Media_Mix_Channel[Platform] = __RowPlatform
            )
        )
    VAR __ScopedParent = "|" & __ParentScope & "|"  // | 包裹，防止子串误匹配
    VAR __ParentLabels =
        SELECTCOLUMNS(
            FILTER(
                ALL(Dim_Media_Mix_Channel),
                // 只取 DETAIL 行（与 __Labels 同理，SUMMARY 聚合的是底层 DETAIL）
                Dim_Media_Mix_Channel[Channel_Type] = "DETAIL"
                    && Dim_Media_Mix_Channel[Platform] = __RowPlatform
                    && CONTAINSSTRING(
                           __ScopedParent,
                           "|" & Dim_Media_Mix_Channel[Channel_ID] & "|"
                       )
            ),
            // ⚠️ 列别名必须与事实表字段名完全一致（"channel"），否则 IN 运算符会报列名不匹配
            "channel", Dim_Media_Mix_Channel[Channel]
        )

    // ── 2.3 构造 SUMMARY/Total 行分母：__GrandTotalLabels ──
    //
    // 目标：获取"当前平台最大汇总行 Total"对应的全部 DETAIL Channel 名称
    //
    // 为什么需要独立构造（不复用 __Labels）？
    //   - __Labels 是"当前行自身"的聚合范围（如 RTB Total → 4个 DETAIL）
    //   - __GrandTotalLabels 是"全平台 Total"的聚合范围（如 TM Total → 全部 6 个 DETAIL）
    //   - 两者在 RTB Total / 品销宝 Total / JCGP Total 等中间 SUMMARY 行上不同！
    //
    // 定位方式：
    //   约定 Channel_ID = "{Platform}_Total"（如 "TM_Total"、"JD_Total"）
    //   在 Dim_Media_Mix_Channel 中查找该行的 Summary_Scope → 得到全平台 DETAIL 列表
    //
    // 示例（TM 平台）：
    //   矩阵行 = "RTB Total"（SUMMARY）
    //     → __GrandTotalScope = "TM_ZTC|TM_YLMF|TM_QZT|TM_DSP|TM_PPZQ|TM_PPTX"（全部 6 个 DETAIL）
    //     → __GrandTotalLabels = {"直通车","引力魔方","全站推/万象台","超级短视频","品牌专区","品牌特秀"}
    //     → Cost% = RTB Total Cost / Total Cost（RTB 在全平台的真实占比）
    //
    //   矩阵行 = "Total"（SUMMARY / 最大汇总行）
    //     → __GrandTotalScope = 同上（Total 自身的 Summary_Scope）
    //     → __GrandTotalLabels = __Labels（Total 的聚合范围 = 全平台 DETAIL = Grand Total DETAIL）
    //     → Cost% = Total Cost / Total Cost = 100% ✓
    //
    VAR __GrandTotalScope =
        CALCULATE(
            SELECTEDVALUE(Dim_Media_Mix_Channel[Summary_Scope]),
            FILTER(
                ALL(Dim_Media_Mix_Channel),
                // 约定：Channel_ID = "{Platform}_Total" 是全平台最大汇总行
                // ⚠️ 如果 SQL 中 Channel_ID 命名规则变了，这里也要同步改
                Dim_Media_Mix_Channel[Channel_ID] = __RowPlatform & "_Total"
                    && Dim_Media_Mix_Channel[Platform] = __RowPlatform
            )
        )
    VAR __ScopedGrandTotal = "|" & __GrandTotalScope & "|"
    VAR __GrandTotalLabels =
        SELECTCOLUMNS(
            FILTER(
                ALL(Dim_Media_Mix_Channel),
                Dim_Media_Mix_Channel[Channel_Type] = "DETAIL"
                    && Dim_Media_Mix_Channel[Platform] = __RowPlatform
                    && CONTAINSSTRING(
                           __ScopedGrandTotal,
                           "|" & Dim_Media_Mix_Channel[Channel_ID] & "|"
                       )
            ),
            // ⚠️ 列别名必须与事实表字段名完全一致（"channel"），否则 IN 运算符会报列名不匹配
            "channel", Dim_Media_Mix_Channel[Channel]
        )

    // ── 2.4 最终路由：按行类型选择分母聚合（修复 v2.0.1）──
    //
    // ⚠️ 关键修复：DAX 的 IF/SWITCH 只能返回标量值（数字、文本等），
    //    不能返回表。如果写成 VAR x = IF(..., __ParentLabels, __GrandTotalLabels)，
    //    IF 只会提取表的第一行第一列作为字符串，导致后续 channel IN __x 报错。
    //
    // 正确做法：把 IF 判断移到 CALCULATE 外面，让 IF 决定执行哪个 CALCULATE 分支。
    // 两个分支的 CALCULATE 结构完全相同，仅 channel IN 后面的表变量不同：
    //   - DETAIL 行：IN __ParentLabels（所属上级 SUMMARY 的 DETAIL 集合）
    //   - SUMMARY 行（含 Total）：IN __GrandTotalLabels（全平台 Total 的 DETAIL 集合）
    //
    // ⚠️ Total 行也是 SUMMARY 类型（Channel_Type="SUMMARY"），
    //    走 __GrandTotalLabels 分支 → 恰好等于自身的 __Labels → Cost% = 100%（正确）
    //
    VAR __TotalCost =
        IF(
            __ChannelType = "DETAIL",
            CALCULATE(
                SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
                a05_e2e_paid_media_channel_data_d[channel] IN __ParentLabels,
                a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
                a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
            ),
            CALCULATE(
                SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
                a05_e2e_paid_media_channel_data_d[channel] IN __GrandTotalLabels,
                a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
                a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
            )
        )
    // ────────────────────────────────────────────────
    // 13 个指标的统一聚合（无 ALL，列级条件，日期通过关系传递）
    // ────────────────────────────────────────────────
    VAR __Cost =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    VAR __CostPct = DIVIDE(__Cost, __TotalCost)

    // ── ID 4: Impression — 展现量 ──
    VAR __Impression =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[pv]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    // ── ID 5: Click — 点击量 ──
    VAR __Click =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[click]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    // ── ID 6: Add to Cart — 加购数 ──
    VAR __AddToCart =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[add_cart_cnt]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    // ── ID 7: Orders — 成交订单数 ──
    VAR __Orders =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[media_sales_order_cnt]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    // ── ID 8: GMV — 成交金额 ──
    VAR __GMV =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[media_sales_amt]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

    // ── ID 3: ROI — 成交金额 / 花费 ──
    VAR __ROI = DIVIDE(__GMV, __Cost)

    // ── ID 9: CTR — 点击率 = Click / Impression ──
    VAR __CTR = DIVIDE(__Click, __Impression)

    // ── ID 10: CPC — 平均点击花费 = Cost / Click ──
    VAR __CPC = DIVIDE(__Cost, __Click)

    // ── ID 11: CPATC — 加购成本 = Cost / Add to Cart ──
    VAR __CPATC = DIVIDE(__Cost, __AddToCart)

    // ── ID 12: CVR — 点击转化率 = Orders / Click ──
    VAR __CVR = DIVIDE(__Orders, __Click)

    // ── ID 13: AOV — 客单价 = GMV / Orders ──
    VAR __AOV = DIVIDE(__GMV, __Orders)

    RETURN
    SWITCH(
        __MetricID,

        // ═══════════════════════════════════════════════════════
        // ID 1: Cost — 花费金额
        // 口径: SUM(cost_amt)，按 channel + platform + trans_cycle 过滤
        // ═══════════════════════════════════════════════════════
        1, __Cost,

        // ═══════════════════════════════════════════════════════
        // ID 2: Cost% — 花费占比
        // 口径: Cost / 分母
        //   DETAIL 行分母 = 所属上级 SUMMARY 的 cost（如 直通车/RTB Total）
        //   SUMMARY 行分母 = 最大汇总行 Total 的 cost（始终为全局汇总）
        //   Total 行 Cost% = 100%（分母 = 自身）
        // ═══════════════════════════════════════════════════════
        2, __CostPct,

        // ═══════════════════════════════════════════════════════
        // ID 3: ROI — 媒体 ROI
        // 口径: media_sales_amt / cost_amt = GMV / Cost
        // ═══════════════════════════════════════════════════════
        3, __ROI,

        // ═══════════════════════════════════════════════════════
        // ID 4: Impression — 展现量
        // 口径: SUM(pv)
        // ═══════════════════════════════════════════════════════
        4, __Impression,

        // ═══════════════════════════════════════════════════════
        // ID 5: Click — 点击量
        // 口径: SUM(click)
        // ═══════════════════════════════════════════════════════
        5, __Click,

        // ═══════════════════════════════════════════════════════
        // ID 6: Add to Cart — 加购数
        // 口径: SUM(add_cart_cnt)
        // ═══════════════════════════════════════════════════════
        6, __AddToCart,

        // ═══════════════════════════════════════════════════════
        // ID 7: Orders — 成交订单数
        // 口径: SUM(media_sales_order_cnt)
        // ═══════════════════════════════════════════════════════
        7, __Orders,

        // ═══════════════════════════════════════════════════════
        // ID 8: GMV — 成交金额
        // 口径: SUM(media_sales_amt)
        // ═══════════════════════════════════════════════════════
        8, __GMV,

        // ═══════════════════════════════════════════════════════
        // ID 9: CTR — 点击率
        // 口径: Click / Impression = DIVIDE(__Click, __Impression)
        // ═══════════════════════════════════════════════════════
        9, __CTR,

        // ═══════════════════════════════════════════════════════
        // ID 10: CPC — 平均点击花费
        // 口径: Cost / Click = DIVIDE(__Cost, __Click)
        // ═══════════════════════════════════════════════════════
        10, __CPC,

        // ═══════════════════════════════════════════════════════
        // ID 11: CPATC — 加购成本
        // 口径: Cost / Add to Cart = DIVIDE(__Cost, __AddToCart)
        // ═══════════════════════════════════════════════════════
        11, __CPATC,

        // ═══════════════════════════════════════════════════════
        // ID 12: CVR — 点击转化率
        // 口径: Orders / Click = DIVIDE(__Orders, __Click)
        // ═══════════════════════════════════════════════════════
        12, __CVR,

        // ═══════════════════════════════════════════════════════
        // ID 13: AOV — 客单价
        // 口径: GMV / Orders = DIVIDE(__GMV, __Orders)
        // ═══════════════════════════════════════════════════════
        13, __AOV,

        // ─── 默认 ──────────────────────────────────────────────
        BLANK()
    )

────────────────────────────────────────────────────────────────────────────────
后续指标口径填充模板（统一模式，与 __Cost 同构，复用 __Labels）
────────────────────────────────────────────────────────────────────────────────

新增指标 X（事实表 [字段] 求和）：
    VAR __MetricX =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[字段]),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

新增指标 Y（A/B 比率）：
    VAR __MetricY =
        CALCULATE(
            DIVIDE(SUM([字段A]), SUM([字段B])),
            a05_e2e_paid_media_channel_data_d[channel] IN __Labels,
            a05_e2e_paid_media_channel_data_d[platform]    = __RowPlatform,
            a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
        )

⚠️ 严禁在 CALCULATE 内部使用 FILTER(ALL(事实表), ...)，会破坏 Dim_Date_Current
   通过关系传递的 data_date 上下文，导致 Cell Value 层 LP 日期覆盖失效

