5. 核心度量值
================================================================================

5.1 本期指标 SWITCH 分发 — Media Mix Base Value
────────────────────────────────────────────────

Media Mix Base Value = 
// ========================================
// 度量值: Media Mix Base Value
// Display Folder: Media Mix
// 用途: 纯指标 SWITCH 分发器
//       根据 DIM_ColMetric_Media_Mix[Metric_ID] 路由到 13 个指标计算逻辑
//       根据 Dim_Media_Mix_Channel[Channel_Type] 决定聚合方式：
//         DETAIL → FILTER 事实表 channel = Channel_Label（精确单渠道）
//         SUMMARY → FILTER 事实表 channel IN 对应明细 Channel_Label 集合
//
// Platform 获取方式：
//   __RowPlatform = SELECTEDVALUE(Dim_Media_Mix_Channel[Platform])
//   由矩阵行上下文自然传入（用户切换 Platform 切片器时，行上下文已被限定）
//   无需读取外部切片器，无需 IF(ALL/单平台) 分支判断
//   ⚠️ 若 Platform 切片器未选（显示所有行），__RowPlatform 在每个矩阵行上下文中仍
//      唯一确定为该行的 Platform 值（TM 行 = "TM"，JD 行 = "JD"），聚合不会跨平台混淆
//
// Cost% 口径：当前行 cost_amt / 当前平台所有 DETAIL channel cost_amt 之和
//   分母为 __RowPlatform 下所有 DETAIL 行的 channel 集合聚合（不受 Channel 切片器影响）
//
// 依赖: DIM_ColMetric_Media_Mix[Metric_ID]
//       Dim_Media_Mix_Channel[Channel_ID/Channel_Type/Channel_Label/Summary_Scope/Platform]
//       Slicer_DataCaliber_Selection[DataCaliber_ID]
//       a05_e2e_paid_media_channel_data_d
// ========================================

    // ── 列上下文 ──
    VAR __MetricID      = SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_ID])

    // ── 行上下文（来自 Dim_Media_Mix_Channel 断开维度）──
    VAR __ChannelLabel  = SELECTEDVALUE(Dim_Media_Mix_Channel[Channel_Label])
    VAR __ChannelType   = SELECTEDVALUE(Dim_Media_Mix_Channel[Channel_Type])
    VAR __SummaryScope  = SELECTEDVALUE(Dim_Media_Mix_Channel[Summary_Scope], "")
    VAR __RowPlatform   = SELECTEDVALUE(Dim_Media_Mix_Channel[Platform])

    // ── 数据口径上下文 ──
    VAR __TransCycle    = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ── SUMMARY 行：解析 Summary_Scope 中的 Channel_ID，映射回 Channel_Label ──
    // Summary_Scope 格式："TM_ZTC|TM_YLMF|TM_QZT|TM_DSP"（| 分隔 Channel_ID）
    // 通过 Dim_Media_Mix_Channel 辅助表，将 Channel_ID 转换为 Channel_Label 集合
    VAR __ScopeIDs      =
        SELECTCOLUMNS(
            FILTER(
                Dim_Media_Mix_Channel,
                CONTAINSSTRING(__SummaryScope, Dim_Media_Mix_Channel[Channel_ID])
                    && Dim_Media_Mix_Channel[Channel_Type] = "DETAIL"
            ),
            "@Label", Dim_Media_Mix_Channel[Channel_Label]
        )
    // __ScopeIDs 为包含各 DETAIL 行 Channel_Label 的单列虚拟表
    // 用于 FILTER 事实表 channel IN __ScopeIDs

    // ── 构建事实表筛选条件（channel 字段过滤）──
    // DETAIL 行：channel = 当前行 Channel_Label
    // SUMMARY 行：channel IN 对应 DETAIL Channel_Label 集合
    VAR __IsDetail      = (__ChannelType = "DETAIL")
    VAR __IsSummary     = (__ChannelType = "SUMMARY")

    // ── 辅助：计算单个指标在指定 channel 过滤下的 SUM ──
    // DETAIL 路径
    VAR __Cost_Detail   =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
            FILTER(
                ALL(a05_e2e_paid_media_channel_data_d),
                a05_e2e_paid_media_channel_data_d[channel]      = __ChannelLabel
                    && a05_e2e_paid_media_channel_data_d[platform]  = __RowPlatform
                    && a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
            )
        )
    // SUMMARY 路径
    VAR __Cost_Summary  =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
            FILTER(
                ALL(a05_e2e_paid_media_channel_data_d),
                a05_e2e_paid_media_channel_data_d[channel] IN __ScopeIDs
                    && a05_e2e_paid_media_channel_data_d[platform]  = __RowPlatform
                    && a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
            )
        )
    VAR __Cost          = IF(__IsDetail, __Cost_Detail, IF(__IsSummary, __Cost_Summary, BLANK()))

    // ── Cost%：分母为当前平台 Total（所有 DETAIL channel 之和）──
    VAR __TotalScopeIDs =
        SELECTCOLUMNS(
            FILTER(
                Dim_Media_Mix_Channel,
                Dim_Media_Mix_Channel[Platform]      = __RowPlatform
                    && Dim_Media_Mix_Channel[Channel_Type] = "DETAIL"
            ),
            "@Label", Dim_Media_Mix_Channel[Channel_Label]
        )
    VAR __TotalCost     =
        CALCULATE(
            SUM(a05_e2e_paid_media_channel_data_d[cost_amt]),
            FILTER(
                ALL(a05_e2e_paid_media_channel_data_d),
                a05_e2e_paid_media_channel_data_d[channel] IN __TotalScopeIDs
                    && a05_e2e_paid_media_channel_data_d[platform]  = __RowPlatform
                    && a05_e2e_paid_media_channel_data_d[trans_cycle] = __TransCycle
            )
        )
    VAR __CostPct       = DIVIDE(__Cost, __TotalCost)

    RETURN
    SWITCH(
        __MetricID,

        // ═══════════════════════════════════════════════════════
        // ID 1: Cost — 花费金额
        // 口径: SUM(a05_e2e_paid_media_channel_data_d[cost_amt])
        //       按当前行 channel（DETAIL）或 channel IN 枚举集（SUMMARY）过滤
        //       Platform 由行维度 __RowPlatform 锁定
        // ═══════════════════════════════════════════════════════
        1, __Cost,

        // ═══════════════════════════════════════════════════════
        // ID 2: Cost% — 花费占总花费的百分比
        // 口径: 当前行 cost_amt / 当前平台所有 DETAIL channel cost_amt 之和
        //       示例：直通车 Cost% = 直通车 cost / TM 所有 DETAIL channel cost 之和
        //             RTB Total Cost% = RTB Total cost / TM 所有 DETAIL channel cost 之和
        // ═══════════════════════════════════════════════════════
        2, __CostPct,

        // ═══════════════════════════════════════════════════════
        // ID 3: ROI — 媒体投资回报率（暂无口径）
        // 待填充口径: media_sales_amt / adj_cost_amt（来源待确认）
        // ═══════════════════════════════════════════════════════
        3, 1,

        // ═══════════════════════════════════════════════════════
        // ID 4: Impression — 展现量（暂无口径）
        // 待填充口径: SUM(a05_e2e_paid_media_channel_data_d[pv])
        // ═══════════════════════════════════════════════════════
        4, 1,

        // ═══════════════════════════════════════════════════════
        // ID 5: Click — 点击量（暂无口径）
        // 待填充口径: SUM(a05_e2e_paid_media_channel_data_d[click])
        // ═══════════════════════════════════════════════════════
        5, 1,

        // ═══════════════════════════════════════════════════════
        // ID 6: Add to Cart — 加购量（暂无口径）
        // 待填充口径: SUM(a05_e2e_paid_media_channel_data_d[add_cart_cnt])
        // ═══════════════════════════════════════════════════════
        6, 1,

        // ═══════════════════════════════════════════════════════
        // ID 7: Orders — 成交笔数（暂无口径）
        // 待填充口径: SUM(a05_e2e_paid_media_channel_data_d[sales_order_cnt])
        // ═══════════════════════════════════════════════════════
        7, 1,

        // ═══════════════════════════════════════════════════════
        // ID 8: GMV — 总成交金额（暂无口径）
        // 待填充口径: SUM(a05_e2e_paid_media_channel_data_d[sales_amt])
        // ═══════════════════════════════════════════════════════
        8, 1,

        // ═══════════════════════════════════════════════════════
        // ID 9: CTR — 点击率（暂无口径）
        // 待填充口径: DIVIDE(SUM([click]), SUM([pv]))
        // ═══════════════════════════════════════════════════════
        9, 1,

        // ═══════════════════════════════════════════════════════
        // ID 10: CPC — 单次点击成本（暂无口径）
        // 待填充口径: DIVIDE(SUM([cost_amt]), SUM([click]))
        // ═══════════════════════════════════════════════════════
        10, 1,

        // ═══════════════════════════════════════════════════════
        // ID 11: CPATC — 加购成本（暂无口径）
        // 待填充口径: DIVIDE(SUM([cost_amt]), SUM([add_cart_cnt]))
        // ═══════════════════════════════════════════════════════
        11, 1,

        // ═══════════════════════════════════════════════════════
        // ID 12: CVR — 成交转化率（暂无口径）
        // 待填充口径: DIVIDE(SUM([sales_order_cnt]), SUM([click]))
        // ═══════════════════════════════════════════════════════
        12, 1,

        // ═══════════════════════════════════════════════════════
        // ID 13: AOV — 客单价（暂无口径）
        // 待填充口径: DIVIDE(SUM([sales_amt]), SUM([sales_order_cnt]))
        // ═══════════════════════════════════════════════════════
        13, 1,

        // ─── 默认 ──────────────────────────────────────────────
        BLANK()
    )

