Media Mix Cell Font Color = 
// ========================================
// 度量值: Media Mix Cell Font Color
// Display Folder: Media Mix > Formatting
// 用途: 根据行类型、指标列、YOY 值返回字体颜色
//
// 颜色规则（v2.0 — 2026-07-02）：
//   1. This Year / Last Year 行：
//      SUMMARY → "#000000"（纯黑），DETAIL → "#5f6165"（灰色）
//   2. YOY 行：
//      a) Cost / Cost% / ROI 三列（ID 1~3）启用阈值着色：
//         - YOY ≥ +10% → "#1A9018"（绿色，显著增长）
//         - YOY ≤ −10% → "#D64550"（红色，显著下降）
//         - −10% < YOY < +10% → 走默认行颜色（SUMMARY 黑 / DETAIL 灰）
//      b) 其他列：同规则 1（SUMMARY 黑 / DETAIL 灰）
//   3. 兜底默认色："#5f6165"
//
// 依赖: [Media Mix Cell Value],
//       DIM_RowKPIs_Media_Mix[Indicator Type],
//       DIM_ColMetric_Media_Mix[Metric_ID],
//       Dim_Media_Mix_Channel[Channel_Type]
// ========================================

// ── 1. 获取当前上下文 ──
VAR __Indicator   = SELECTEDVALUE(DIM_RowKPIs_Media_Mix[Indicator Type])  // This Year / Last Year / YOY
VAR __ChannelType = SELECTEDVALUE(Dim_Media_Mix_Channel[Channel_Type])    // DETAIL / SUMMARY
VAR __CellValue   = [Media Mix Cell Value]                                 // 当前单元格数值（YOY 行时即 YOY 变化率）
VAR __MetricID    = SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_ID])     // 指标列 ID（1~13）
VAR __IsSummary   = (__ChannelType = "SUMMARY")

// ── 2. 默认行颜色（非阈值着色场景使用）──
//    SUMMARY → 纯黑，DETAIL → 灰色
VAR __DefaultColor = IF(__IsSummary, "#000000", "#5f6165")

// ── 3. YOY 阈值着色（仅 Cost / Cost% / ROI 三列启用）──
//    阈值：+10% / -10%
//    __CellValue 在 YOY 行 = YOY 变化率（如 0.145 表示 +14.5%）
VAR __YOY_Threshold_Color =
    SWITCH(
        TRUE(),
        ISBLANK(__CellValue), __DefaultColor,   // 空值 → 走默认行颜色
        __CellValue >= 0.10,  "#1A9018",        // YOY ≥ +10% → 绿色（显著增长）
        __CellValue <= -0.10, "#D64550",        // YOY ≤ -10% → 红色（显著下降）
        __DefaultColor                           // -10% < YOY < +10% → 走默认行颜色
    )

// ── 4. 最终路由 ──
RETURN
    SWITCH(
        TRUE(),
        // This Year / Last Year → 默认行颜色（SUMMARY 黑 / DETAIL 灰）
        __Indicator <> "YOY", __DefaultColor,
        // YOY + Cost/Cost%/ROI（ID 1~3）→ 阈值着色
        __MetricID >= 1 && __MetricID <= 3, __YOY_Threshold_Color,
        // YOY + 其他列 → 默认行颜色（SUMMARY 黑 / DETAIL 灰）
        __DefaultColor
    )


