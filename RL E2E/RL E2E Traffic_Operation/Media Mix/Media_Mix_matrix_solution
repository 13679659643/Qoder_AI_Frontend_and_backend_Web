Media Mix Cell Display = 
// ========================================
// 度量值: Media Mix Cell Display
// Display Folder: Media Mix > Formatting
// 用途: 根据行类型 + 列指标格式，返回格式化文本
//       格式类型从 DIM_ColMetric_Media_Mix 动态读取
//       货币符号从 Slicer_Currency_Selection 动态读取
// 依赖: [Media Mix Cell Value],
//       DIM_ColMetric_Media_Mix[Metric_Format_*],
//       DIM_RowKPIs_Media_Mix[Indicator Type],
//       Slicer_Currency_Selection[Currency_Symbol]
// ========================================

    VAR __Value          = [Media Mix Cell Value]
    VAR __Indicator      = SELECTEDVALUE(DIM_RowKPIs_Media_Mix[Indicator Type])
    VAR __Format         =
        SWITCH(
            __Indicator,
            "This Year", SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_Format_Current]),
            "Last Year", SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_Format_LP]),
            "YOY",       SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_Format_VsLP]),
            SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_Format_Current])
        )
    VAR __CurrencySymbol =
        SELECTEDVALUE(Slicer_Currency_Selection[Currency_Symbol], "¥")

    RETURN
        IF(
            ISBLANK(__Value),
            "-",
            SWITCH(
                __Format,
                "currency",
                    __CurrencySymbol & FORMAT(__Value, "#,##0"),
                "integer",
                    FORMAT(__Value, "#,##0"),
                "decimal_2",
                    FORMAT(__Value, "#,##0.00"),
                "percent_1dp",
                    FORMAT(__Value, "0.0%"),
                "delta_pct_1dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.0%"),
                "currency_k",
                    __CurrencySymbol & FORMAT(__Value / 1000, "#,##0") & "k",
                "percent_2dp",
                    FORMAT(__Value, "0.00%"),
                "delta_pct_2dp",
                    IF(__Value > 0, "+", "") & FORMAT(__Value, "0.00%"),
                "delta_bp",
                    IF(__Value >= 0, "+", "") & FORMAT(__Value * 10000, "#,##0") & "bp",
                FORMAT(__Value, "#,##0.00")
            )
        )

