Media Mix Cell Value = 
// ========================================
// 度量值: Media Mix Cell Value
// Display Folder: Media Mix
// 用途: 根据行维度（This Year / Last Year / YOY）路由到不同的计算逻辑
//       - This Year：调用 [Media Mix Base Value]，金额类指标乘以汇率
//       - Last Year：CALCULATE([Media Mix Base Value], LP 日期覆盖)，金额类指标乘以汇率
//       - YOY：This Year / Last Year - 1，增长率不受汇率影响
//
// 同期日期覆盖机制与 KPIs Overview Cell Value 完全一致：
//   REMOVEFILTERS(Dim_Date_Current) + FILTER(ALL(Dim_Date_Current), 日期范围)
//
// 依赖: DIM_RowKPIs_Media_Mix[Indicator Type], Dim_Date_Ly,
//       Slicer_Currency_Selection[Currency_ExchangeRate],
//       DIM_ColMetric_Media_Mix[Metric_IsCurrencyAmount]
// ========================================

    // ── 行上下文 ──
    VAR __Indicator     = SELECTEDVALUE(DIM_RowKPIs_Media_Mix[Indicator Type])

    // ── 汇率上下文 ──
    VAR __ExchangeRate  = SELECTEDVALUE(Slicer_Currency_Selection[Currency_ExchangeRate], 1)
    VAR __IsCurrencyAmt = SELECTEDVALUE(DIM_ColMetric_Media_Mix[Metric_IsCurrencyAmount], FALSE)

    // ── 同期日期范围 ──
    VAR __LP_Start      = MIN(Dim_Date_Ly[LY_数据日期])
    VAR __LP_End        = MAX(Dim_Date_Ly[LY_数据日期])

    // ── This Year 值 ──
    VAR __CurrentValue  = [Media Mix Base Value]

    // ── Last Year 值（覆盖日期上下文为 LP 日期范围）──
    VAR __LP_Value      =
        IF(
            ISBLANK(__LP_Start) || ISBLANK(__LP_End),
            BLANK(),
            CALCULATE(
                [Media Mix Base Value],
                REMOVEFILTERS(Dim_Date_Current),
                FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] >= __LP_Start
                        && Dim_Date_Current[数据日期] <= __LP_End
                )
            )
        )

    // ── 汇率换算 ──
    VAR __CurrentConverted =
        IF(__IsCurrencyAmt, __CurrentValue * __ExchangeRate, __CurrentValue)
    VAR __LP_Converted     =
        IF(__IsCurrencyAmt, __LP_Value * __ExchangeRate, __LP_Value)

    // ── YOY 同比计算 ──
    VAR __CurrIsEmpty   = ISBLANK(__CurrentValue) || __CurrentValue = 0
    VAR __LPIsEmpty     = ISBLANK(__LP_Value)     || __LP_Value = 0
    VAR __YOY_Result    =
        IF(
            __LPIsEmpty,
            BLANK(),
            IF(__CurrIsEmpty, -1, DIVIDE(__CurrentValue - __LP_Value, __LP_Value))
        )

    RETURN
    SWITCH(
        TRUE(),
        __Indicator = "This Year", __CurrentConverted,
        __Indicator = "Last Year", __LP_Converted,
        __Indicator = "YOY",       __YOY_Result,
        BLANK()
    )

