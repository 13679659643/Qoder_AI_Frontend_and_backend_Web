Category Growth SLS% VS LP =
// ========================================
// 度量值: Category Growth SLS% VS LP
// 中文名: 退后销售额占比同期
// Display Folder: Category Growth
// 用途: Net Sales% 同比增长率
// 口径: YOY同比 = 本期 Net Sales% / 同期(LP) Net Sales% - 1
//       本期 Net Sales% = 本期品类 net_sales_amt / 本期 TTL net_sales_amt
//       同期 Net Sales% = 同期品类 net_sales_amt / 同期 TTL net_sales_amt
// 类型: 同比增长率，不乘汇率
// 数据格式: #,##0.0%;#,##0.0%;0.0%
// 数据底表: a05_e2e_paid_media_product_data_d
// 同比机制:
//   本期 = Dim_Date_Current 关系自然筛选
//   同期 = Dim_Date_Ly 断开维度，MIN/MAX 取范围，CALCULATE 覆盖日期上下文
//   增长率 = (本期 - 同期) / 同期
//   边界: 同期为 0/空 → BLANK；本期为 0/空且同期有值 → -1
// ========================================
    // ── 本期 Net Sales% ──
    VAR __CurrentNetSalesPct = [Category Growth Net Sales%]

    // ── 同期 Net Sales%（覆盖日期上下文为 LP 日期范围）──
    VAR __LP_Start = MIN(Dim_Date_Ly[LY_数据日期])
    VAR __LP_End = MAX(Dim_Date_Ly[LY_数据日期])
    VAR __LPNetSalesPct =
        IF(
            ISBLANK(__LP_Start) || ISBLANK(__LP_End),
            BLANK(),
            CALCULATE(
                [Category Growth Net Sales%],
                REMOVEFILTERS(Dim_Date_Current),
                FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] >= __LP_Start
                        && Dim_Date_Current[数据日期] <= __LP_End
                )
            )
        )

    // ── 同比增长率（含边界判断）──
    VAR __CurrIsEmpty = ISBLANK(__CurrentNetSalesPct) || __CurrentNetSalesPct = 0
    VAR __LPIsEmpty = ISBLANK(__LPNetSalesPct) || __LPNetSalesPct = 0
    RETURN
        IF(
            __LPIsEmpty,
            BLANK(),
            IF(__CurrIsEmpty, -1, DIVIDE(__CurrentNetSalesPct - __LPNetSalesPct, __LPNetSalesPct))
        )

