Category Growth Active IDs =
// ========================================
// 度量值: Category Growth Active IDs
// 中文名: 在推ID数量
// Display Folder: Category Growth
// 用途: 推广中SKU数，统计周期最后一天仍在推的商品ID去重计数
// 口径: 获取当前时间周期的最大日期，然后对 living_sku_cnt 聚合 SUM
// 类型: 计数类，不乘汇率
// 数据格式: #,##0;(#,##0);0
// 数据底表: a05_e2e_paid_media_product_data_d
// 筛选: 层级过滤
//       第5层级（mix_msg）：其他四个层级字段值为 ALL
//       其他层级：同理，过滤其他层级字段值为 ALL
//       Platform（单选含 ALL，ALL → platform IN {"TM","JD"}）
//       trans_cycle（单选，数据口径）
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")
    // ── 获取当前时间周期的最大日期──
    VAR __Current_End = MAX(Dim_Date_Current[数据日期])

    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_product_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_product_data_d[platform] = __ChannelID)
        )
    
    VAR __TransCycleFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[trans_cycle]),
            a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
        )

    // ── 层级判断 ──
    VAR __IsFramework = ISINSCOPE(a05_e2e_paid_media_product_data_d[framework])
    VAR __IsBrand     = ISINSCOPE(a05_e2e_paid_media_product_data_d[brand])
    VAR __IsCategory  = ISINSCOPE(a05_e2e_paid_media_product_data_d[category])
    VAR __IsChannel   = ISINSCOPE(a05_e2e_paid_media_product_data_d[channel])
    VAR __IsMixMsg    = ISINSCOPE(a05_e2e_paid_media_product_data_d[mix_msg])

    // 获取当前行上下文的值
    VAR __CurrentFramework = SELECTEDVALUE(a05_e2e_paid_media_product_data_d[framework])
    VAR __CurrentBrand = SELECTEDVALUE(a05_e2e_paid_media_product_data_d[brand])
    VAR __CurrentCategory = SELECTEDVALUE(a05_e2e_paid_media_product_data_d[category])
    VAR __CurrentChannel = SELECTEDVALUE(a05_e2e_paid_media_product_data_d[channel])
    VAR __CurrentMixMsg = SELECTEDVALUE(a05_e2e_paid_media_product_data_d[mix_msg])

        // ── 层级过滤：严格隔离层级，防止重复汇总 ──
    // 规则1：1~4层之间，当前层级字段有具体值(<>ALL)，其他三个层级字段必须为 "ALL"，且 mix_msg 必须为空
    // 规则2：第5层，其他四个字段必须为 "ALL"，且 mix_msg 必须有具体值(不为空)
    VAR __LevelFilter =
        FILTER(
            // 必须把所有五个层级字段放入 ALL，彻底清除外部矩阵/切片器对它们的筛选干扰
            ALLSELECTED(
                a05_e2e_paid_media_product_data_d[mix_msg],
                a05_e2e_paid_media_product_data_d[framework],
                a05_e2e_paid_media_product_data_d[brand],
                a05_e2e_paid_media_product_data_d[category],
                a05_e2e_paid_media_product_data_d[channel]
            ),
            
            // ── 核心防重逻辑 ──
            SWITCH(
                TRUE(),
                
                // ── 第5层：mix_msg 明细行 ──
                // 五个字段值与当前行上下文一致，mix_msg 不为空
                __IsMixMsg,
                    NOT ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[framework] = __CurrentFramework
                && a05_e2e_paid_media_product_data_d[brand] = __CurrentBrand
                && a05_e2e_paid_media_product_data_d[category] = __CurrentCategory
                && a05_e2e_paid_media_product_data_d[channel] = __CurrentChannel
                && a05_e2e_paid_media_product_data_d[mix_msg] = __CurrentMixMsg,

                // ── 第4层：channel 小计行 ──
                // 限制 mix_msg 为空，不限制 channel = 'ALL' (保留当前 channel 上下文)
                __IsChannel,
                    ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[framework] = __CurrentFramework
                && a05_e2e_paid_media_product_data_d[brand] = __CurrentBrand
                && a05_e2e_paid_media_product_data_d[category] = __CurrentCategory
                && a05_e2e_paid_media_product_data_d[channel] = __CurrentChannel,

                // ── 第3层：category 小计行 ──
                // 限制 mix_msg 为空，且子级 channel 必须为 "ALL"
                __IsCategory,
                    ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[framework] = __CurrentFramework
                && a05_e2e_paid_media_product_data_d[brand] = __CurrentBrand
                && a05_e2e_paid_media_product_data_d[category] = __CurrentCategory
                && a05_e2e_paid_media_product_data_d[channel] = "ALL",

                // ── 第2层：brand 小计行 ──
                // 限制 mix_msg 为空，且子级 category, channel 必须为 "ALL"
                __IsBrand,
                    ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[framework] = __CurrentFramework
                && a05_e2e_paid_media_product_data_d[brand] = __CurrentBrand
                && a05_e2e_paid_media_product_data_d[channel] = "ALL",

                // ── 第1层：framework 行 ──
                // 限制 mix_msg 为空，且子级 brand, category, channel 必须为 "ALL"
                __IsFramework,
                    ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[framework] = __CurrentFramework
                && a05_e2e_paid_media_product_data_d[channel] = "ALL",
                
                // ── 总计行 ──
                // 限制所有层级字段必须为 "ALL"，且 mix_msg 为空
                TRUE(),
                    ISBLANK(a05_e2e_paid_media_product_data_d[mix_msg])
                && a05_e2e_paid_media_product_data_d[channel] = "ALL"
            )
        )

    RETURN
        CALCULATE(
            SUM(a05_e2e_paid_media_product_data_d[living_sku_cnt]),
            REMOVEFILTERS(Dim_Date_Current),
            FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] = __Current_End
                ),
            NOT ISBLANK(a05_e2e_paid_media_product_data_d[cost_amt]),
            __PlatformFilter,
            __TransCycleFilter,
            __LevelFilter
        )
        

