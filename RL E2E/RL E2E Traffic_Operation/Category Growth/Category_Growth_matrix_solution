Category Growth EOH(OMS)% = 
// ========================================
// 度量值: Category Growth EOH(OMS)%
// 中文名: 库存%
// Display Folder: Category Growth
// 用途: 库存占比指标
// 口径: 该分组 stock_qty / 总 stock_qty
//       分子 = 当前分组 SUM(stock_qty)
//       分母 = 全店 SUM(stock_qty)（移除全部 5 个行维度）
// 类型: 比率类，不乘汇率
// 数据格式: #,##0.0%;#,##0.0%;0.0%
// 数据底表: a05_e2e_paid_media_product_data_d
// 筛选: 全局筛选（mix_msg IS NULL / IS NOT NULL）
//       Platform（单选含 ALL，ALL → platform IN {"TM","JD"}）
//       trans_cycle（单选，数据口径）
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    // ── 1. 平台筛选 ──
    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[platform]),
            // 如果 __ChannelID = "ALL"，返回 IN {"TM", "JD"}，否则返回 = __ChannelID
            IF(
                __ChannelID = "ALL",
                a05_e2e_paid_media_product_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_product_data_d[platform] = __ChannelID
            )
        )

    // ── 2. 层级判断 ──
    VAR __IsFramework = ISINSCOPE(a05_e2e_paid_media_product_data_d[framework])
    VAR __IsBrand     = ISINSCOPE(a05_e2e_paid_media_product_data_d[brand])
    VAR __IsCategory  = ISINSCOPE(a05_e2e_paid_media_product_data_d[category])
    VAR __IsChannel   = ISINSCOPE(a05_e2e_paid_media_product_data_d[channel])
    VAR __IsMixMsg    = ISINSCOPE(a05_e2e_paid_media_product_data_d[mix_msg])

    // ── 3. 层级过滤 (转为显式的 FILTER 表) ──
    // 明确告诉引擎：这是一个针对 mix_msg 列的筛选表
    VAR __LevelFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[mix_msg]),
            SWITCH(
                TRUE(),
                __IsMixMsg, a05_e2e_paid_media_product_data_d[mix_msg] <> BLANK(),
                a05_e2e_paid_media_product_data_d[mix_msg] = BLANK()
            )
        )
        
    // ── 4. 周期筛选 (显式声明，覆盖该列原有上下文) ──
    VAR __TransCycleFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[trans_cycle]),
            a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
        )

    // ── 5. 分子计算：当前分组 stock_qty ──
    VAR __Numerator =
        CALCULATE(
            SUM(a05_e2e_paid_media_product_data_d[stock_qty]),
            __PlatformFilter,   // 交集 1：限定平台
            __TransCycleFilter, // 交集 2：限定周期
            __LevelFilter       // 交集 3：限定层级与 mix_msg 状态
        )


    // ── 分母：全店 stock_qty（移除全部 5 个行维度）──
    VAR __Denominator =
        CALCULATE(
            SUM(a05_e2e_paid_media_product_data_d[stock_qty]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[framework]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[brand]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[category]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[channel]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[mix_msg]),
            __PlatformFilter,   // 交集 1：限定平台
            __TransCycleFilter, // 交集 2：限定周期
            __LevelFilter       // 交集 3：限定层级与 mix_msg 状态
        )

    RETURN
        DIVIDE(__Numerator, __Denominator)

