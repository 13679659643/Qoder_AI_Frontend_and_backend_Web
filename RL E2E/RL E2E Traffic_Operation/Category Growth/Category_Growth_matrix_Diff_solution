变更 3：Category Growth Diff Cost% VS LP（引用名 [Category Growth Cost%] → [Category Growth Diff Cost%]）
================================================================================

Category Growth Diff Cost% VS LP =
// ========================================
// 度量值: Category Growth Diff Cost% VS LP
// 中文名: 推广花费占比同比增长率
// Display Folder: Category Growth Diff
// 用途: Cost% 同比增长率
// 口径: (本期 Cost% - 同期 Cost%) / 同期 Cost%
// 类型: 同比增长率，不乘汇率
// 同比机制:
//   本期 Cost% = 本期当前行 promotion_cost_amt / 本期总计 promotion_cost_amt
//   同期 Cost% = 同期当前行 promotion_cost_amt / 同期总计 promotion_cost_amt
//   同期通过 CALCULATE 覆盖日期上下文为 LP 日期范围，Cost% 内部分子分母同步切换到同期
//   边界: 同期为 0/空 → BLANK；本期为 0/空且同期有值 → -1
// 数据字典: promotion_cost_amt = 推广花费
// 与原方案差异: 内部引用名从 [Category Growth Cost%] 改为 [Category Growth Diff Cost%]
//              原因: Cost% 的 REMOVEFILTERS 已从 framework 改为 gender（变更 2），
//                    Cost% VS LP 必须引用 Diff 版本的 Cost% 才能继承 gender 行维度逻辑，
//                    否则会引用原方案 Cost%（REMOVEFILTERS framework），导致 Cost% VS LP 计算错误
// ========================================
    // ── 本期 Cost% ──
    VAR __CurrentCostPct = [Category Growth Diff Cost%]

    // ── 同期 Cost%（覆盖日期上下文为 LP 日期范围）──
    VAR __LP_Start = MIN(Dim_Date_Ly[LY_数据日期])
    VAR __LP_End = MAX(Dim_Date_Ly[LY_数据日期])
    VAR __LPCostPct =
        IF(
            ISBLANK(__LP_Start) || ISBLANK(__LP_End),
            BLANK(),
            CALCULATE(
                [Category Growth Diff Cost%],
                REMOVEFILTERS(Dim_Date_Current),
                FILTER(
                    ALL(Dim_Date_Current),
                    Dim_Date_Current[数据日期] >= __LP_Start
                        && Dim_Date_Current[数据日期] <= __LP_End
                )
            )
        )

    // ── 同比增长率（含边界判断）──
    VAR __CurrIsEmpty = ISBLANK(__CurrentCostPct) || __CurrentCostPct = 0
    VAR __LPIsEmpty = ISBLANK(__LPCostPct) || __LPCostPct = 0
    RETURN
        IF(
            __LPIsEmpty,
            BLANK(),
            IF(__CurrIsEmpty, -1, DIVIDE(__CurrentCostPct - __LPCostPct, __LPCostPct))
        )

