Category Growth Diff Cell Font Color =
// ========================================
// 度量值: Category Growth Diff Cell Font Color
// 中文名: 品类增长 Diff 单元格字体颜色
// Display Folder: Category Growth Diff > Formatting
// 用途: 根据表视觉层级返回字体颜色
//       用于条件格式 → 字体颜色
// 表结构: 行维度 = season -> brand -> category -> channel -> gender（五级）
// 颜色规则:
//   - 总计行 (Grand Total) -> #252423（近黑，强调）
//   - 所有小计行和明细行     -> #5F6165（深灰）
// 与原方案差异: ISINSCOPE 字段变化，移除 __IsFramework，新增 __IsGender，
//              维度判断顺序调整为 __IsSeason 在最外层
// ========================================
    VAR __IsGender = ISINSCOPE(a05_e2e_paid_media_product_data_d[gender])
    VAR __IsChannel = ISINSCOPE(a05_e2e_paid_media_product_data_d[channel])
    VAR __IsCategory = ISINSCOPE(a05_e2e_paid_media_product_data_d[category])
    VAR __IsBrand = ISINSCOPE(a05_e2e_paid_media_product_data_d[brand])
    VAR __IsSeason = ISINSCOPE(a05_e2e_paid_media_product_data_d[season])

    RETURN
        SWITCH(
            TRUE(),
            // ── 总计行：全部 ISINSCOPE = FALSE ──
            NOT(__IsSeason) && NOT(__IsBrand) && NOT(__IsCategory) && NOT(__IsChannel) && NOT(__IsGender),
                "#252423",
            // ── 其余所有行（season / brand / category / channel / gender）──
            "#5F6165"
        )

