变更 2：Category Growth Diff Cost%（REMOVEFILTERS 5 字段，framework → gender）
================================================================================

Category Growth Diff Cost% =
// ========================================
// 度量值: Category Growth Diff Cost%
// 中文名: 推广花费占比
// Display Folder: Category Growth Diff
// 用途: 每行推广花费占总计推广花费的百分比
// 口径: DIVIDE(当前行 promotion_cost_amt, 总计 promotion_cost_amt)
//       分母不受行维度（season / brand / category / channel / gender）筛选上下文影响
//       分母使用 REMOVEFILTERS 移除全部 5 个行维度 + 保留切片器筛选
// 类型: 比率类，不乘汇率
// 数据字典: promotion_cost_amt = 推广花费
// 与原方案差异: REMOVEFILTERS 字段集合变化，
//              移除 framework，新增 gender，
//              维度顺序调整为 season → brand → category → channel → gender
// ========================================
    VAR __ChannelID = SELECTEDVALUE(Slicer_Platform_Selection[Platform_ID], "ALL")
    VAR __TransCycle = SELECTEDVALUE(Slicer_DataCaliber_Selection[DataCaliber_ID], "T+1")

    VAR __PlatformFilter =
        FILTER(
            ALL(a05_e2e_paid_media_product_data_d[platform]),
            IF(__ChannelID = "ALL",
                a05_e2e_paid_media_product_data_d[platform] IN {"TM", "JD"},
                a05_e2e_paid_media_product_data_d[platform] = __ChannelID))

    // ── 分子：当前行 promotion_cost_amt ──
    VAR __CostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
            __PlatformFilter,
            a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
        )

    // ── 分母：总计 promotion_cost_amt（移除全部 5 个行维度）──
    VAR __TotalCostAmt =
        CALCULATE(
            SUM(a05_e2e_paid_media_product_data_d[promotion_cost_amt]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[season]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[brand]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[category]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[channel]),
            REMOVEFILTERS(a05_e2e_paid_media_product_data_d[gender]),
            __PlatformFilter,
            a05_e2e_paid_media_product_data_d[trans_cycle] = __TransCycle
        )

    RETURN
        DIVIDE(__CostAmt, __TotalCostAmt)

