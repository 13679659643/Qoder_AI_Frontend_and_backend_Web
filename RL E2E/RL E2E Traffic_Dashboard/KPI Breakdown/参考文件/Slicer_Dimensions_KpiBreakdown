// ─────────────────────────────────────
// 1. Brand 品牌筛选器
// ─────────────────────────────────────

Slicer_Brand_Selection = 
// 功能：创建品牌维度表，用于报表中的品牌筛选和分组
// 用途：用户可通过此表选择不同品牌线进行 KPI 对比分析
// 参数表名称：Brand
// 遵循通用参数表模板规范
DATATABLE(
    // 基础字段 - 必选字段
    "Brand_ID", STRING,           // 主键标识，用于唯一标识每个品牌选项
    "Brand_Label", STRING,        // 显示标签，在报表界面中向用户展示的品牌名称
    "Brand_Sort", INTEGER,        // 排序顺序，控制选项在切片器中的显示顺序
    "Brand_Description", STRING,  // 详细描述，说明该品牌的具体定位和业务含义
    
    // 扩展字段 - 可选字段
    "Brand_IsDefault", BOOLEAN,   // 是否默认选中，TRUE 表示用户打开报表时默认选择此品牌
    "Brand_IsActive", BOOLEAN,    // 是否激活状态，控制该品牌选项是否可用
    
    // 数据行
    {
        // M polo - 男装 Polo 系列
        {
            "M polo",             // 品牌代码，男装 Polo 的标识
            "M POLO",             // 品牌显示名称
            1,                    // 排序顺序，优先级最高
            "男装 Polo 系列，涵盖男士 Polo 衫及相关产品线",  // 品牌描述
            TRUE,                 // 默认选中
            TRUE                  // 激活状态，当前可用
        },
        
        // W polo - 女装 Polo 系列
        {
            "W polo",             // 品牌代码，女装 Polo 的标识
            "W POLO",             // 品牌显示名称
            2,                    // 排序顺序
            "女装 Polo 系列，涵盖女士 Polo 衫及相关产品线",  // 品牌描述
            FALSE,                // 非默认选项
            TRUE                  // 激活状态，当前可用
        }
    }
)


