    "MetricGroup_Sort",      INTEGER,     // Level 1 排序（TM×1, JD×10, RLE×100, DY×1000）
    "MetricName_Sort",       INTEGER,     // Level 2 排序（TM×1, JD×10, RLE×100, DY×1000）
