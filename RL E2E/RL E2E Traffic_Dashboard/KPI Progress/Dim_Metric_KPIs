        // ═══════════════════════════════════════
        { 9,  "New Customer Cost%",     9,  "percent",   "Major", 0,  3,  "#212121", "#212121", "#212121", "#212121" },
        { 10, "vs LY",                  10, "delta_bp",  "Sub",   9,  3,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 11, "TAR ACH%",               11, "delta_bp",  "Sub",   9,  3,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 4: New Customer Cost ROI（第一行）
        // ═══════════════════════════════════════
        { 12, "New Customer Cost ROI",  12, "number",    "Major", 0,  4,  "#212121", "#212121", "#212121", "#212121" },
        { 13, "vs LY",                  13, "delta_pct", "Sub",   12, 4,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 14, "vs AVG ROI",             14, "delta_pct", "Sub",   12, 4,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 5: Cost Per New Acquisition（第一行）
        // ═══════════════════════════════════════
        { 15, "Cost Per New Acquisition", 15, "number",  "Major", 0,  5,  "#212121", "#212121", "#212121", "#212121" },
        { 16, "vs LY",                    16, "delta_pct", "Sub", 15, 5,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 17, "TAR ACH%",                 17, "delta_pct", "Sub", 15, 5,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
