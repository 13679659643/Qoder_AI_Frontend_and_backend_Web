        // ═══════════════════════════════════════
        { 18, "Acceleration SLS",       18, "currency",  "Major", 0,  6,  "#212121", "#212121", "#212121", "#212121" },
        { 19, "vs LY",                  19, "delta_pct", "Sub",   18, 6,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 20, "TAR ACH%",               20, "delta_pct", "Sub",   18, 6,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 7: Acceleration SLS MOB%（第二行）
        // ═══════════════════════════════════════
        { 21, "Acceleration SLS MOB%",  21, "percent",   "Major", 0,  7,  "#212121", "#212121", "#212121", "#212121" },
        { 22, "vs LY",                  22, "delta_bp",  "Sub",   21, 7,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 23, "TAR ACH%",               23, "delta_bp",  "Sub",   21, 7,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 8: Acceleration Cost%（第二行）
        // ═══════════════════════════════════════
        { 24, "Acceleration Cost%",     24, "percent",   "Major", 0,  8,  "#212121", "#212121", "#212121", "#212121" },
        { 25, "vs LY",                  25, "delta_bp",  "Sub",   24, 8,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 26, "TAR ACH%",               26, "delta_bp",  "Sub",   24, 8,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 9: Acceleration ROI（第二行）
        // ═══════════════════════════════════════
        { 27, "Acceleration ROI",       27, "number",    "Major", 0,  9,  "#212121", "#212121", "#212121", "#212121" },
        { 28, "vs LY",                  28, "delta_bp",  "Sub",   27, 9,  "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 29, "vs AVG ROI",             29, "delta_bp",  "Sub",   27, 9,  "#1A9018", "#D64550", "#E1C233", "#212121" },

        // ═══════════════════════════════════════
        // Card 10: New Customer Cost（第一行）
        // ═══════════════════════════════════════
        { 30, "New Customer Cost",      30, "currency",  "Major", 0,  10, "#212121", "#212121", "#212121", "#212121" },
        { 31, "vs LY",                  31, "delta_pct", "Sub",   30, 10, "#1A9018", "#D64550", "#E1C233", "#212121" },
        { 32, "vs AVG ROI",             32, "delta_pct", "Sub",   30, 10, "#1A9018", "#D64550", "#E1C233", "#212121" }
    }
)
