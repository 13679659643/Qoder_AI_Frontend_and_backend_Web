Slicer_Platform_Selection = 
// 功能：创建一个平台维度表，用于报表中的平台筛选和分组
// 用途：用户可以通过此表选择不同的电商平台进行分析
// 参数表名称：Platform
// 遵循通用参数表模板规范
DATATABLE(
    // 基础字段 - 必选字段
    "Platform_ID", STRING,         // 主键标识，用于唯一标识每个平台选项，也用于与店铺表关联
    "Platform_Label", STRING,      // 显示标签，在报表界面中向用户展示的平台名称
    "Platform_Sort", INTEGER,      // 排序顺序，控制选项在切片器中的显示顺序
    "Platform_Description", STRING, // 详细描述，说明该平台的具体特点和业务含义
    
    // 扩展字段 - 可选字段
    "Platform_IsDefault", BOOLEAN,  // 是否默认选中，TRUE表示用户打开报表时默认选择此平台
    "Platform_IsActive", BOOLEAN,   // 是否激活状态，控制该平台选项是否可用
    "Platform_Group", STRING,       // 分组标识，用于对相关平台进行逻辑分组（如国内/国际、B2C/C2C等）
    
    // 自定义扩展字段 - 根据业务需求添加
    "Platform_Type", STRING,       // 平台类型：综合电商/社交电商/内容电商等
    "Platform_Icon", STRING,       // 图标标识，可用于报表中的可视化显示
    
    // 数据行
    {
        // 格式说明：每个花括号{}包含一行数据，顺序与上方字段定义一致
        
        // TM - 天猫平台
        {
            "TM",                  // 平台代码，天猫的英文缩写
            "天猫",                 // 平台显示名称
            5,                     // 排序顺序，优先级最高
            "阿里巴巴集团旗下的B2C电商平台，定位为品质购物商城，主要销售品牌商品",  // 平台描述
            TRUE,                  // 默认选中，通常天猫是主要分析平台
            TRUE,                  // 激活状态，当前可用
            "B2C综合平台",         // 分组，属于B2C综合电商平台
            "综合电商",             // 平台类型，综合性电商平台
            "🐱"                   // 图标标识，天猫猫头形象
        },
        
        // JD - 京东平台
        {
            "JD",                  // 平台代码，京东的英文缩写
            "京东",                 // 平台显示名称
            6,                     // 排序顺序
            "中国自营式电商平台，以物流快速和正品保障著称，主要销售电子产品、家电等",  // 平台描述
            FALSE,                 // 非默认选项
            TRUE,                  // 激活状态，当前可用
            "B2C综合平台",         // 分组，属于B2C综合电商平台
            "综合电商",             // 平台类型，综合性电商平台
            "🐶"                   // 图标标识，京东狗形象
        },
        
        // DY - 抖音平台
        {
            "DY",                  // 平台代码，抖音的英文缩写
            "抖音",                 // 平台显示名称
            7,                     // 排序顺序
            "字节跳动旗下的短视频社交平台，已发展成为重要的内容电商和直播电商平台",  // 平台描述
            FALSE,                 // 非默认选项
            TRUE,                  // 激活状态，当前可用
            "社交电商平台",         // 分组，属于社交电商平台
            "社交电商",             // 平台类型，社交内容电商
            "🎵"                   // 图标标识，音乐符号代表抖音
        },
        
        // RLE - 小红书平台
        {
            "RLE",                 // 平台代码，小红书的英文缩写
            "小红书",               // 平台显示名称
            8,                     // 排序顺序
            "生活方式分享社区和电商平台，以用户生成内容和社区推荐为特色，主打美妆、时尚等",  // 平台描述
            FALSE,                 // 非默认选项
            TRUE,                  // 激活状态，当前可用
            "社交电商平台",         // 分组，属于社交电商平台
            "内容电商",             // 平台类型，内容社区电商
            "📕"                   // 图标标识，小红书书本形象
        }
    }
)